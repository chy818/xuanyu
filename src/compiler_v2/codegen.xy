/* ============ 优化 Pass 函数 ============ */

/**
 * 常量折叠评估（实际执行计算）
 */
函数 codegen常量折叠评估(exprKind: 整数, leftVal: 整数, rightVal: 整数, op: 文本): 整数 {
    若 exprKind != 10 则 { 返回 -1 }

    若 op == "+" 则 { 返回 leftVal + rightVal }
    若 op == "-" 则 { 返回 leftVal - rightVal }
    若 op == "*" 则 { 返回 leftVal * rightVal }
    若 op == "/" 则 {
        若 rightVal != 0 则 { 返回 leftVal / rightVal }
    }
    若 op == "%" 则 {
        若 rightVal != 0 则 { 返回 leftVal % rightVal }
    }
    若 op == "&" 则 { 返回 leftVal & rightVal }
    若 op == "|" 则 { 返回 leftVal | rightVal }
    若 op == "^" 则 { 返回 leftVal ^ rightVal }

    返回 -1
}

/**
 * 代数简化（检测并简化恒等式）
 */
函数 codegen代数简化(exprKind: 整数, op: 文本, operand: 整数): 整数 {
    若 op == "+" && operand == 0 则 { 返回 0 }
    若 op == "-" && operand == 0 则 { 返回 0 }
    若 op == "*" && operand == 1 则 { 返回 0 }
    若 op == "/" && operand == 1 则 { 返回 0 }
    若 op == "*" && operand == 0 则 { 返回 0 }
    若 op == "|" && operand == 0 则 { 返回 0 }
    若 op == "&" && operand == -1 则 { 返回 0 }
    
    若 op == "*" && operand == 2 则 { 返回 1 }
    若 op == "<<" && operand == 1 则 { 返回 2 }
    若 op == ">>" && operand == 1 则 { 返回 3 }

    返回 -1
}

