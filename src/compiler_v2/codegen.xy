/* ============ SIMD 和向量化支持 ============ */

/**
 * 生成向量相加 IR
 */
函数 codegenVectorAdd(cg: Codegen, lhs: 文本, rhs: 文本, width: 整数): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = add <" + 整数转文本(width) + " x i64> %" + lhs + ", %" + rhs
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成向量广播 IR
 */
函数 codegenVectorBroadcast(cg: Codegen, value: 文本, width: 整数): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = insertelement <" + 整数转文本(width) + " x i64> undef, i64 %" + value + ", i32 0"
    codegenEmit(cg, line)

    返回 result
}

