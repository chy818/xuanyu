/**
 * @file codegen.xy
 * @brief 代码生成器 - 自展编译器
 * @description 生成 LLVM IR 指令，实现真实 AST 遍历
 */

// 引入 "src/compiler_v2/parser.xy"  // 暂时注释，独立编译测试
// 引入 "src/compiler_v2/sema.xy"    // 暂时注释，独立编译测试
// 引入 "src/compiler_v2/runtime.xy" // 暂时注释，独立编译测试

/* ============ AST 节点类型 (与 parser.xy 和 sema.xy 一致) ============ */

枚举 AST节点类型 {
    程序 = 0,
    函数定义 = 1,
    参数列表 = 2,
    变量定义 = 3,
    赋值语句 = 4,
    if语句 = 5,
    while语句 = 6,
    循环语句 = 7,
    返回语句 = 8,
    表达式语句 = 9,
    二元表达式 = 10,
    一元表达式 = 11,
    调用表达式 = 12,
    标识符表达式 = 13,
    字面量表达式 = 14,
    类型转换 = 15,
    break语句 = 16,
    continue语句 = 17,
    块语句 = 18,
    赋值表达式 = 19,
    for循环 = 20,
    结构体定义 = 21,
    枚举定义 = 22,
    结构体字段 = 23,
    枚举成员 = 24,
    match语句 = 25,
    match分支 = 26,
    match默认分支 = 27,
    导入语句 = 28,
    模块定义 = 29,
    外部声明 = 30
}

/* ============ AST 节点结构体 ============ */

结构体 AST节点 {
    id: 整数,
    kind: 整数,
    name: 文本,
    value: 文本,
    intValue: 整数,
    line: 整数,
    children: 列表
}

/* ============ 循环上下文（用于 break/continue） ============ */

结构体 循环上下文 {
    循环开始标签: 文本,   // 循环条件判断入口
    循环体标签: 文本,     // 循环体入口
    continue标签: 文本,   // continue 跳转目标
    结束标签: 文本        // 循环结束标签
}

/* ============ Codegen 结构 ============ */

结构体 Codegen {
    moduleName: 文本,
    tempCount: 整数,
    labelCount: 整数,
    funcCount: 整数,
    output: 列表,
    indent: 整数,
    stringConstCount: 整数,
    funcDefs: 列表,
    currentFunc: 文本,
    currentReturnType: 文本,
    // 变量名到 SSA 值的映射
    variableMap: 列表,  // 列表包含文本对：[变量名, SSA值]
    // 变量名到类型的映射
    variableTypes: 列表,  // 列表包含文本对：[变量名, 类型]
    // 字符串常量表
    stringConstants: 列表,  // 列表包含文本对：[字符串, 常量名]
    // 循环上下文栈（用于 break/continue）
    loopContextStack: 列表,  // 列表包含循环上下文
    // 当前函数索引（用于生成唯一标签前缀）
    currentFunctionIndex: 整数,
    // 函数索引计数器
    functionIndexCounter: 整数
}

/* ============ LLVM 类型映射 ============ */

函数 getLLVMType(typeName: 文本): 文本 {
    若 typeName == "整数" || typeName == "长整数" 则 { 返回 "i64" }
    若 typeName == "浮点数" || typeName == "双精度" 则 { 返回 "double" }
    若 typeName == "布尔" 则 { 返回 "i1" }
    若 typeName == "文本" || typeName == "字符" 则 { 返回 "i8*" }
    若 typeName == "无返回" 则 { 返回 "void" }
    返回 "i64"
}

/* ============ 初始化 ============ */

函数 codegenInit(): Codegen {
    定义 可变 cg: Codegen
    cg.moduleName = "xuanyu_module"
    cg.tempCount = 0
    cg.labelCount = 0
    cg.funcCount = 0
    cg.output = 列表()
    cg.indent = 0
    cg.stringConstCount = 0
    cg.funcDefs = 列表()
    cg.currentFunc = ""
    cg.currentReturnType = "i64"
    // 初始化新增字段
    cg.variableMap = 列表()
    cg.variableTypes = 列表()
    cg.stringConstants = 列表()
    cg.loopContextStack = 列表()
    cg.currentFunctionIndex = 0
    cg.functionIndexCounter = 0
    返回 cg
}

/* ============ 输出函数 ============ */

函数 codegenEmitLine(cg: Codegen, line: 文本) {
    定义 可变 i: 整数
    i = 0
    当 i < cg.indent 则 {
        打印("  ")
        i = i + 1
    }
    打印(line)
}

函数 codegenEmit(cg: Codegen, content: 文本) {
    codegenEmitLine(cg, content)
    列表添加(cg.output, content)
}

/* ============ 标签和临时变量 ============ */

函数 codegenNewLabel(cg: Codegen): 文本 {
    定义 可变 num: 整数
    num = cg.labelCount
    cg.labelCount = cg.labelCount + 1
    定义 可变 result: 文本
    result = "L"
    定义 可变 numStr: 文本
    numStr = 整数转文本(num)
    result = result + numStr
    返回 result
}

函数 codegenNewTemp(cg: Codegen): 文本 {
    定义 可变 num: 整数
    num = cg.tempCount
    cg.tempCount = cg.tempCount + 1
    定义 可变 result: 文本
    result = "tmp"
    定义 可变 tmpStr: 文本
    tmpStr = 整数转文本(num)
    result = result + tmpStr
    返回 result
}

/* ============ 变量映射管理 ============ */

/**
 * 添加变量到映射表
 */
函数 codegen添加变量(cg: Codegen, varName: 文本, ssaValue: 文本, varType: 文本): 无返回 {
    // 变量名和值作为一对添加到列表
    列表追加(cg.variableMap, varName)
    列表追加(cg.variableMap, ssaValue)
    
    // 变量名和类型作为一对添加到列表
    列表追加(cg.variableTypes, varName)
    列表追加(cg.variableTypes, varType)
}

/**
 * 查找变量的 SSA 值
 */
函数 codegen查找变量(cg: Codegen, varName: 文本): 文本 {
    定义 可变 i: 整数
    i = 0
    当 i < 列表长度(cg.variableMap) 则 {
        若 cg.variableMap[i] == varName 则 {
            返回 cg.variableMap[i + 1]
        }
        i = i + 2
    }
    返回 ""  // 未找到
}

/**
 * 查找变量的类型
 */
函数 codegen查找变量类型(cg: Codegen, varName: 文本): 文本 {
    定义 可变 i: 整数
    i = 0
    当 i < 列表长度(cg.variableTypes) 则 {
        若 cg.variableTypes[i] == varName 则 {
            返回 cg.variableTypes[i + 1]
        }
        i = i + 2
    }
    返回 "i64"  // 默认类型
}

/**
 * 清空变量映射（进入新作用域时使用）
 */
函数 codegen清空变量(cg: Codegen): 无返回 {
    cg.variableMap = 列表()
    cg.variableTypes = 列表()
}

/* ============ 循环上下文管理 ============ */

/**
 * 推入循环上下文
 */
函数 codegen推入循环上下文(cg: Codegen, ctx: 循环上下文): 无返回 {
    列表追加(cg.loopContextStack, ctx)
}

/**
 * 弹出循环上下文
 */
函数 codegen弹出循环上下文(cg: Codegen): 循环上下文 {
    定义 可变 ctx: 循环上下文
    若 列表长度(cg.loopContextStack) > 0 则 {
        定义 可变 lastIdx: 整数
        lastIdx = 列表长度(cg.loopContextStack) - 1
        ctx = cg.loopContextStack[lastIdx]
        // 注意：这里简化处理，因为玄语不支持从列表中删除元素
        // 实际使用时，需要用更复杂的数据结构
    }
    返回 ctx
}

/**
 * 获取当前循环上下文
 */
函数 codegen获取当前循环上下文(cg: Codegen): 循环上下文 {
    定义 可变 ctx: 循环上下文
    若 列表长度(cg.loopContextStack) > 0 则 {
        定义 可变 lastIdx: 整数
        lastIdx = 列表长度(cg.loopContextStack) - 1
        ctx = cg.loopContextStack[lastIdx]
    }
    返回 ctx
}

/* ============ 字符串常量管理 ============ */

/**
 * 添加字符串常量
 */
函数 codegen添加字符串常量(cg: Codegen, str: 文本): 文本 {
    // 先检查是否已存在
    定义 可变 i: 整数
    i = 0
    当 i < 列表长度(cg.stringConstants) 则 {
        若 cg.stringConstants[i] == str 则 {
            返回 cg.stringConstants[i + 1]
        }
        i = i + 2
    }
    
    // 创建新的字符串常量
    定义 可变 constName: 文本
    constName = "str"
    定义 可变 idxStr: 文本
    idxStr = 整数转文本(cg.stringConstCount)
    constName = constName + idxStr
    cg.stringConstCount = cg.stringConstCount + 1
    
    // 添加到常量表
    列表追加(cg.stringConstants, str)
    列表追加(cg.stringConstants, constName)
    
    返回 constName
}

/**
 * 查找字符串常量
 */
函数 codegen查找字符串常量(cg: Codegen, str: 文本): 文本 {
    定义 可变 i: 整数
    i = 0
    当 i < 列表长度(cg.stringConstants) 则 {
        若 cg.stringConstants[i] == str 则 {
            返回 cg.stringConstants[i + 1]
        }
        i = i + 2
    }
    返回 ""
}

/* ============ AST 遍历和 IR 生成函数 ============ */

/**
 * 生成字面量值 IR
 */
函数 codegenLiteral(cg: Codegen, value: 文本, type: 整数): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    若 type == 1 则 {
        // 整数 - 但由于返回类型是文本，我们需要返回指针类型
        // 我们将 i64 转换为 i8* (inttoptr)
        定义 可变 intTmp: 文本
        intTmp = codegenNewTemp(cg)
        codegenEmit(cg, "%" + intTmp + " = add i64 0, " + value)
        codegenEmit(cg, "%" + result + " = inttoptr i64 %" + intTmp + " to i8*")
    } 否则 {
        若 type == 2 则 {
            // 字符串 - 直接返回指针
            定义 可变 tmpPtr: 文本
            tmpPtr = codegenNewTemp(cg)
            codegenEmit(cg, "%" + tmpPtr + " = getelementptr [0 x i8], [0 x i8]* null, i64 0, i64 0")
            result = tmpPtr
        } 否则 {
            // 默认 - 返回空指针
            codegenEmit(cg, "%" + result + " = inttoptr i64 0 to i8*")
        }
    }

    返回 result
}

/**
 * 生成二元表达式 IR
 */
函数 codegenBinaryOp(cg: Codegen, op: 文本, left: 文本, right: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 llOp: 文本
    llOp = "add"

    若 op == "+" 则 { llOp = "add" }
    若 op == "-" 则 { llOp = "sub" }
    若 op == "*" 则 { llOp = "mul" }
    若 op == "/" 则 { llOp = "sdiv" }
    若 op == "%" 则 { llOp = "srem" }

    定义 可变 line: 文本
    line = "%" + result + " = " + llOp + " i64 %" + left + ", %" + right
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成比较表达式 IR
 */
函数 codegenCompare(cg: Codegen, op: 文本, left: 文本, right: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 llOp: 文本
    llOp = "eq"

    若 op == "==" 则 { llOp = "eq" }
    若 op == "!=" 则 { llOp = "ne" }
    若 op == "<" 则 { llOp = "slt" }
    若 op == ">" 则 { llOp = "sgt" }
    若 op == "<=" 则 { llOp = "sle" }
    若 op == ">=" 则 { llOp = "sge" }

    定义 可变 line: 文本
    line = "%" + result + " = icmp " + llOp + " i64 %" + left + ", %" + right
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成逻辑与 (&&) IR
 */
函数 codegenLogicalAnd(cg: Codegen, left: 文本, right: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = and i1 %" + left + ", %" + right
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成逻辑或 (||) IR
 */
函数 codegenLogicalOr(cg: Codegen, left: 文本, right: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = or i1 %" + left + ", %" + right
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成逻辑非 (!) IR
 */
函数 codegenLogicalNot(cg: Codegen, value: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = xor i1 %" + value + ", 1"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成一元减法 IR
 */
函数 codegenNegate(cg: Codegen, value: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = sub i64 0, %" + value
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成符号扩展 IR
 */
函数 codegenSignExt(cg: Codegen, value: 文本, fromType: 文本, toType: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = sext " + fromType + " %" + value + " to " + toType
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成零扩展 IR
 */
函数 codegenZeroExt(cg: Codegen, value: 文本, fromType: 文本, toType: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = zext " + fromType + " %" + value + " to " + toType
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成截断 IR
 */
函数 codegenTrunc(cg: Codegen, value: 文本, fromType: 文本, toType: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = trunc " + fromType + " %" + value + " to " + toType
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成浮点到整数的转换 IR
 */
函数 codegenFptoSI(cg: Codegen, value: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = fptosi double %" + value + " to i64"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成整数到浮点的转换 IR
 */
函数 codegenSIToFP(cg: Codegen, value: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = sitofp i64 %" + value + " to double"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成数组分配 IR
 */
函数 codegenArrayAlloca(cg: Codegen, elementType: 文本, numElements: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = alloca " + elementType + ", i64 %" + numElements
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成数组元素访问 IR
 */
函数 codegenArrayAccess(cg: Codegen, arrayPtr: 文本, index: 文本, elementType: 文本): 文本 {
    定义 可变 tmpPtr: 文本
    tmpPtr = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + tmpPtr + " = getelementptr " + elementType + ", " + elementType + "* %" + arrayPtr + ", i64 %" + index
    codegenEmit(cg, line)

    定义 可变 value: 文本
    value = codegenNewTemp(cg)
    line = "%" + value + " = load " + elementType + ", " + elementType + "* %" + tmpPtr
    codegenEmit(cg, line)

    返回 value
}

/**
 * 生成数组元素存储 IR
 */
函数 codegenArrayStore(cg: Codegen, arrayPtr: 文本, index: 文本, value: 文本, elementType: 文本): 无返回 {
    定义 可变 tmpPtr: 文本
    tmpPtr = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + tmpPtr + " = getelementptr " + elementType + ", " + elementType + "* %" + arrayPtr + ", i64 %" + index
    codegenEmit(cg, line)

    line = "store " + elementType + " %" + value + ", " + elementType + "* %" + tmpPtr
    codegenEmit(cg, line)
}

/**
 * 生成结构体分配 IR
 */
函数 codegenStructAlloca(cg: Codegen, structType: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = alloca " + structType
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成结构体字段访问 IR (使用字段索引)
 */
函数 codegenStructFieldAccess(cg: Codegen, structPtr: 文本, fieldIndex: 整数, fieldType: 文本): 文本 {
    定义 可变 tmpPtr: 文本
    tmpPtr = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + tmpPtr + " = getelementptr " + fieldType + ", " + fieldType + "* %" + structPtr + ", i32 0, i32 " + 整数转文本(fieldIndex)
    codegenEmit(cg, line)

    定义 可变 value: 文本
    value = codegenNewTemp(cg)
    line = "%" + value + " = load " + fieldType + ", " + fieldType + "* %" + tmpPtr
    codegenEmit(cg, line)

    返回 value
}

/**
 * 生成结构体字段存储 IR
 */
函数 codegenStructFieldStore(cg: Codegen, structPtr: 文本, fieldIndex: 整数, value: 文本, fieldType: 文本): 无返回 {
    定义 可变 tmpPtr: 文本
    tmpPtr = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + tmpPtr + " = getelementptr " + fieldType + ", " + fieldType + "* %" + structPtr + ", i32 0, i32 " + 整数转文本(fieldIndex)
    codegenEmit(cg, line)

    line = "store " + fieldType + " %" + value + ", " + fieldType + "* %" + tmpPtr
    codegenEmit(cg, line)
}

/**
 * 生成空指针检查 IR
 */
函数 codegenNullCheck(cg: Codegen, tmpPtr: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = icmp ne i8* %" + tmpPtr + ", null"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成全局变量声明 IR
 */
函数 codegenGlobalString(cg: Codegen, strValue: 文本, name: 文本): 文本 {
    定义 可变 line: 文本
    line = "@" + name + " = private constant [0 x i8] c\"" + strValue + "\\00\""
    codegenEmit(cg, line)

    返回 name
}

/**
 * 生成全局变量声明 IR (整数)
 */
函数 codegenGlobalInt(cg: Codegen, value: 整数, name: 文本): 文本 {
    定义 可变 line: 文本
    line = "@" + name + " = global i64 " + 整数转文本(value)
    codegenEmit(cg, line)

    返回 name
}

/**
 * 生成选择性 IR (cond ? then : else)
 */
函数 codegenSelect(cg: Codegen, cond: 文本, thenValue: 文本, elseValue: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = select i1 %" + cond + ", i64 %" + thenValue + ", i64 %" + elseValue
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成位旋转 IR (左移后带符号扩展)
 */
函数 codegenShl(cg: Codegen, value: 文本, amount: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = shl i64 %" + value + ", %" + amount
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成算术右移 IR
 */
函数 codegenAShr(cg: Codegen, value: 文本, amount: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = ashr i64 %" + value + ", %" + amount
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成逻辑右移 IR
 */
函数 codegenLShr(cg: Codegen, value: 文本, amount: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = lshr i64 %" + value + ", %" + amount
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成按位与 IR
 */
函数 codegenAnd(cg: Codegen, left: 文本, right: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = and i64 %" + left + ", %" + right
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成按位或 IR
 */
函数 codegenOr(cg: Codegen, left: 文本, right: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = or i64 %" + left + ", %" + right
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成按位异或 IR
 */
函数 codegenXor(cg: Codegen, left: 文本, right: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = xor i64 %" + left + ", %" + right
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成按位取反 IR
 */
函数 codegenNot(cg: Codegen, value: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = xor i64 %" + value + ", -1"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成函数入口标注
 */
函数 codegenFunctionEntry(cg: Codegen, funcName: 文本): 无返回 {
    定义 可变 line: 文本
    line = "; 函数入口: " + funcName
    codegenEmit(cg, line)
}

/**
 * 生成代码块标注
 */
函数 codegenBlockLabel(cg: Codegen, blockName: 文本): 无返回 {
    定义 可变 line: 文本
    line = "; 代码块: " + blockName
    codegenEmit(cg, line)
}

/**
 * 生成注释
 */
函数 codegenComment(cg: Codegen, comment: 文本): 无返回 {
    定义 可变 line: 文本
    line = "; " + comment
    codegenEmit(cg, line)
}

/**
 * 生成 unreachable 指令 IR
 */
函数 codegenUnreachable(cg: Codegen): 无返回 {
    codegenEmit(cg, "unreachable")
}

/**
 * 生成 switch 指令 IR (用于 match 语句)
 */
函数 codegenSwitch(cg: Codegen, value: 文本, defaultLabel: 文本, numCases: 整数) {
    定义 可变 line: 文本
    line = "switch i64 %" + value + ", label %" + defaultLabel
    codegenEmit(cg, line)
}

/**
 * 生成 case 分支 IR
 */
函数 codegenCase(cg: Codegen, caseValue: 文本, caseLabel: 文本) {
    定义 可变 line: 文本
    line = "i64 " + caseValue + ", label %" + caseLabel
    codegenEmit(cg, line)
}

/**
 * 生成 match 语句 IR
 */
函数 codegenMatch(cg: Codegen, subjectValue: 文本, caseCount: 整数, hasDefault: 整数): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 endLabel: 文本
    endLabel = codegenNewLabel(cg)

    定义 可变 defaultLabel: 文本
    defaultLabel = codegenNewLabel(cg)

    定义 可变 line: 文本
    line = "switch i64 %" + subjectValue + ", label %" + defaultLabel
    codegenEmit(cg, line)

    定义 可变 i: 整数
    i = 0
    当 i < caseCount 则 {
        定义 可变 caseLabel: 文本
        caseLabel = codegenNewLabel(cg)
        line = "i64 " + 整数转文本(i) + ", label %" + caseLabel
        codegenEmit(cg, line)
        i = i + 1
    }

    /* 默认标签 */
    cg.indent = cg.indent - 1
    codegenEmit(cg, defaultLabel + ":")
    cg.indent = cg.indent + 1

    若 hasDefault == 0 则 {
        codegenEmit(cg, "unreachable")
    }

    /* 结束标签 */
    cg.indent = cg.indent - 1
    codegenEmit(cg, endLabel + ":")
    cg.indent = cg.indent + 1

    返回 result
}

/**
 * 生成 phi 节点 IR (用于 match 分支的值合并)
 */
函数 codegenPhi(cg: Codegen, numValues: 整数): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = phi i64"
    定义 可变 i: 整数
    i = 0
    当 i < numValues 则 {
        定义 可变 label: 文本
        label = codegenNewLabel(cg)
        line = line + " [%tmp" + 整数转文本(i) + ", %L" + 整数转文本(i) + "]"
        若 i < numValues - 1 则 {
            line = line + ","
        }
        i = i + 1
    }
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成 if 语句 IR
 */
函数 codegenIf(cg: Codegen, condVar: 文本, thenLabel: 文本, elseLabel: 文本, endLabel: 文本) {
    定义 可变 line: 文本
    line = "br i1 %" + condVar + ", label %" + thenLabel + ", label %" + elseLabel
    codegenEmit(cg, line)

    cg.indent = cg.indent - 1
    codegenEmit(cg, thenLabel + ":")
    cg.indent = cg.indent + 1
}

/**
 * 生成 while 循环 IR
 */
函数 codegenWhile(cg: Codegen, condVar: 文本, bodyLabel: 文本, endLabel: 文本) {
    定义 可变 line: 文本
    line = "br i1 %" + condVar + ", label %" + bodyLabel + ", label %" + endLabel
    codegenEmit(cg, line)

    cg.indent = cg.indent - 1
    codegenEmit(cg, bodyLabel + ":")
    cg.indent = cg.indent + 1
}

/**
 * 生成 for 循环 IR
 */
函数 codegenFor(cg: Codegen, varName: 文本, startVal: 整数, endVal: 整数, bodyLabel: 文本, condLabel: 文本, endLabel: 文本) {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = add i64 0, " + 整数转文本(startVal)
    codegenEmit(cg, line)

    定义 可变 alloca: 文本
    alloca = varName + "_alloca"
    codegenEmit(cg, "%" + alloca + " = alloca i64")
    codegenEmit(cg, "store i64 %" + result + ", i64* %" + alloca)

    cg.indent = cg.indent - 1
    codegenEmit(cg, condLabel + ":")
    cg.indent = cg.indent + 1

    定义 可变 cmpResult: 文本
    cmpResult = codegenNewTemp(cg)
    line = "%" + cmpResult + " = icmp sle i64 %" + result + ", " + 整数转文本(endVal)
    codegenEmit(cg, line)
    line = "br i1 %" + cmpResult + ", label %" + bodyLabel + ", label %" + endLabel
    codegenEmit(cg, line)

    cg.indent = cg.indent - 1
    codegenEmit(cg, bodyLabel + ":")
    cg.indent = cg.indent + 1
}

/**
 * 生成 break 跳转 IR
 */
函数 codegenBreak(cg: Codegen, endLabel: 文本) {
    定义 可变 line: 文本
    line = "br label %" + endLabel
    codegenEmit(cg, line)
}

/**
 * 生成 continue 跳转 IR
 */
函数 codegenContinue(cg: Codegen, condLabel: 文本) {
    定义 可变 line: 文本
    line = "br label %" + condLabel
    codegenEmit(cg, line)
}

/**
 * 生成赋值 IR
 */
函数 codegenAssign(cg: Codegen, varName: 文本, value: 文本, varType: 文本) {
    定义 可变 llType: 文本
    llType = getLLVMType(varType)

    定义 可变 alloca: 文本
    alloca = varName + "_slot"

    定义 可变 line: 文本
    line = "%" + alloca + " = alloca " + llType
    codegenEmit(cg, line)

    line = "store " + llType + " %" + value + ", " + llType + "* %" + alloca
    codegenEmit(cg, line)
}

/**
 * 生成复合赋值 IR (+=, -=, *=, /=, %=)
 */
函数 codegenCompoundAssign(cg: Codegen, varName: 文本, op: 文本, value: 文本, varType: 文本): 文本 {
    定义 可变 llType: 文本
    llType = getLLVMType(varType)

    定义 可变 alloca: 文本
    alloca = varName + "_slot"

    定义 可变 line: 文本
    line = "%" + alloca + " = alloca " + llType
    codegenEmit(cg, line)

    定义 可变 llOp: 文本
    llOp = "add"

    若 op == "+=" 则 { llOp = "add" }
    若 op == "-=" 则 { llOp = "sub" }
    若 op == "*=" 则 { llOp = "mul" }
    若 op == "/=" 则 { llOp = "sdiv" }
    若 op == "%=" 则 { llOp = "srem" }

    定义 可变 result: 文本
    result = codegenNewTemp(cg)
    line = "%" + result + " = " + llOp + " " + llType + " %" + value + ", %" + value
    codegenEmit(cg, line)

    line = "store " + llType + " %" + result + ", " + llType + "* %" + alloca
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成 return 语句 IR
 */
函数 codegenReturn(cg: Codegen, value: 文本) {
    定义 可变 line: 文本
    若 cg.currentReturnType == "void" 则 {
        line = "ret void"
    } 否则 {
        line = "ret i64 %" + value
    }
    codegenEmit(cg, line)
}

/**
 * 生成函数调用 IR
 */
函数 codegenCall(cg: Codegen, funcName: 文本, returnType: 文本): 文本 {
    定义 可变 result: 文本
    result = ""

    若 returnType != "void" 则 {
        定义 可变 tmp: 文本
        tmp = codegenNewTemp(cg)
        codegenEmit(cg, "%" + tmp + " = call " + returnType + " @" + funcName + "()")
        result = tmp
    } 否则 {
        codegenEmit(cg, "call " + returnType + " @" + funcName + "()")
    }

    返回 result
}

/**
 * 生成函数调用 IR（带参数）
 */
函数 codegenCallWithArgs(cg: Codegen, funcName: 文本, argCount: 整数, returnType: 文本): 文本 {
    定义 可变 result: 文本
    result = ""

    若 returnType != "void" 则 {
        定义 可变 tmp: 文本
        tmp = codegenNewTemp(cg)
        定义 可变 line: 文本
        line = "%" + tmp + " = call " + returnType + " @" + funcName + "("
        /* 简化：参数列表留空 */
        line = line + ")"
        codegenEmit(cg, line)
        result = tmp
    } 否则 {
        codegenEmit(cg, "call " + returnType + " @" + funcName + "()")
    }

    返回 result
}

/**
 * 生成字符串长度调用 IR
 */
函数 codegenStringLen(cg: Codegen, strPtr: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = call i64 @rt_string_len(i8* %" + strPtr + ")"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成字符串拼接调用 IR
 */
函数 codegenStringConcat(cg: Codegen, str1: 文本, str2: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = call i8* @rt_string_concat(i8* %" + str1 + ", i8* %" + str2 + ")"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成字符串切片调用 IR
 */
函数 codegenStringSlice(cg: Codegen, strPtr: 文本, start: 文本, end: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = call i8* @rt_string_slice(i8* %" + strPtr + ", i64 %" + start + ", i64 %" + end + ")"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成列表创建调用 IR
 */
函数 codegenListNew(cg: Codegen): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = call i64 @rt_list_new()"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成列表追加调用 IR
 */
函数 codegenListAppend(cg: Codegen, list: 文本, value: 文本): 无返回 {
    定义 可变 line: 文本
    line = "call void @rt_list_append(i8* %" + list + ", i8* %" + value + ")"
    codegenEmit(cg, line)
}

/**
 * 生成列表获取调用 IR
 */
函数 codegenListGet(cg: Codegen, list: 文本, index: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = call i8* @rt_list_get(i8* %" + list + ", i64 %" + index + ")"
    codegenEmit(cg, line)

    返回 result
}

/* ============ IR 生成函数 ============ */

/**
 * 生成模块头
 */
函数 emitModuleHeader(cg: Codegen, name: 文本) {
    打印("; ============================================")
    打印("; 玄语编译器 v0.2 - 自展版本")
    打印("; LLVM IR 生成")
    打印("; ============================================")
    打印("")
    codegenEmit(cg, "source_filename = \"" + name + "\"")
    打印("")
}

/**
 * 生成目标数据声明
 */
函数 emitTargetData(cg: Codegen) {
    codegenEmit(cg, "target datalayout = \"e-m:w-p64:64:64-i32:32-i64:64-i128:128-n32:64-S128\"")
    codegenEmit(cg, "target triple = \"x86_64-pc-windows-msvc\"")
    打印("")
}

/**
 * 生成函数头
 */
函数 emitFunctionHeader(cg: Codegen, name: 文本, paramCount: 整数, returnType: 文本): 文本 {
    定义 可变 llName: 文本
    llName = name

    定义 可变 line: 文本
    line = "define " + returnType + " @" + llName + "() {"

    codegenEmitLine(cg, line)

    cg.indent = cg.indent + 1
    返回 name
}

/**
 * 生成变量分配
 */
函数 emitAlloca(cg: Codegen, varName: 文本, typeName: 文本) {
    定义 可变 llType: 文本
    llType = getLLVMType(typeName)
    定义 可变 line: 文本
    line = "%" + varName + " = alloca " + llType
    codegenEmit(cg, line)
}

/**
 * 生成存储指令
 */
函数 emitStore(cg: Codegen, value: 文本, varName: 文本, typeName: 文本) {
    定义 可变 llType: 文本
    llType = getLLVMType(typeName)
    定义 可变 line: 文本
    line = "store " + llType + " %" + value + ", " + llType + "* %" + varName
    codegenEmit(cg, line)
}

/**
 * 生成加载指令
 */
函数 emitLoad(cg: Codegen, varName: 文本, typeName: 文本): 文本 {
    定义 可变 llType: 文本
    llType = getLLVMType(typeName)
    定义 可变 result: 文本
    result = codegenNewTemp(cg)
    定义 可变 line: 文本
    line = "%" + result + " = load " + llType + ", " + llType + "* %" + varName
    codegenEmit(cg, line)
    返回 result
}

/**
 * 生成整数常量
 */
函数 emitIntegerLiteral(cg: Codegen, value: 整数): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)
    定义 可变 line: 文本
    line = "%" + result + " = add i64 0, " + 整数转文本(value)
    codegenEmit(cg, line)
    返回 result
}

/**
 * 生成字符串常量
 */
函数 emitStringLiteral(cg: Codegen, strValue: 文本): 文本 {
    定义 可变 constName: 文本
    constName = "str"
    定义 可变 idxStr: 文本
    idxStr = 整数转文本(cg.stringConstCount)
    constName = constName + idxStr
    cg.stringConstCount = cg.stringConstCount + 1

    定义 可变 line: 文本
    line = "@" + constName + " = private constant [" + 整数转文本(文本长度(strValue)) + " x i8] c\"" + strValue + "\\00\""
    codegenEmit(cg, line)

    定义 可变 ptrResult: 文本
    ptrResult = codegenNewTemp(cg)
    line = "%" + ptrResult + " = getelementptr [" + 整数转文本(文本长度(strValue)) + " x i8], [" + 整数转文本(文本长度(strValue)) + " x i8]* @" + constName + ", i64 0, i64 0"
    codegenEmit(cg, line)

    返回 ptrResult
}

/**
 * 生成二元运算
 */
函数 emitBinaryOp(cg: Codegen, op: 文本, left: 文本, right: 文本, leftType: 文本, rightType: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 llOp: 文本
    llOp = "+"
    若 op == "-" 则 { llOp = "sub" }
    若 op == "*" 则 { llOp = "mul" }
    若 op == "/" 则 { llOp = "sdiv" }
    若 op == "%" 则 { llOp = "srem" }

    定义 可变 llType: 文本
    llType = getLLVMType(leftType)

    定义 可变 line: 文本
    line = "%" + result + " = " + llOp + " " + llType + " %" + left + ", %" + right
    codegenEmit(cg, line)
    返回 result
}

/**
 * 生成比较指令
 */
函数 emitCompare(cg: Codegen, op: 文本, left: 文本, right: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 llOp: 文本
    llOp = "eq"
    若 op == ">" 则 { llOp = "sgt" }
    若 op == "<" 则 { llOp = "slt" }
    若 op == ">=" 则 { llOp = "sge" }
    若 op == "<=" 则 { llOp = "sle" }
    若 op == "!=" 则 { llOp = "ne" }

    定义 可变 line: 文本
    line = "%" + result + " = icmp " + llOp + " i64 %" + left + ", %" + right
    codegenEmit(cg, line)
    返回 result
}

/**
 * 生成条件分支
 */
函数 emitBr(cg: Codegen, condVar: 文本, thenLabel: 文本, elseLabel: 文本) {
    定义 可变 line: 文本
    line = "br i1 %" + condVar + ", label %" + thenLabel + ", label %" + elseLabel
    codegenEmit(cg, line)
}

/**
 * 生成无条件跳转
 */
函数 emitJump(cg: Codegen, labelName: 文本) {
    定义 可变 line: 文本
    line = "br label %" + labelName
    codegenEmit(cg, line)
}

/**
 * 生成标签
 */
函数 emitLabel(cg: Codegen, labelName: 文本) {
    cg.indent = cg.indent - 1
    定义 可变 line: 文本
    line = labelName + ":"
    codegenEmitLine(cg, line)
    cg.indent = cg.indent + 1
}

/**
 * 生成返回指令
 */
函数 emitReturn(cg: Codegen, valueName: 文本, returnType: 文本) {
    定义 可变 line: 文本
    若 returnType == "void" 则 {
        line = "ret void"
    } 否则 {
        line = "ret i64 %" + valueName
    }
    codegenEmit(cg, line)
}

/**
 * 生成函数调用
 */
函数 emitCall(cg: Codegen, funcName: 文本, argCount: 整数, returnType: 文本): 文本 {
    定义 可变 result: 文本
    result = ""

    若 returnType != "void" 则 {
        result = codegenNewTemp(cg)
        定义 可变 line: 文本
        line = "%" + result + " = call " + returnType + " @" + funcName + "()"
        codegenEmit(cg, line)
    } 否则 {
        codegenEmit(cg, "call " + returnType + " @" + funcName + "()")
    }

    返回 result
}

/* ============ 内置函数声明 ============ */

函数 emitBuiltinDecls(cg: Codegen) {
    打印("; ==================== 内置函数声明 ====================")
    codegenEmit(cg, "declare void @print(i8*)")
    codegenEmit(cg, "declare i64 @print_int(i64)")
    codegenEmit(cg, "declare double @print_float(double)")
    codegenEmit(cg, "declare i8* @print_string(i8*)")
    codegenEmit(cg, "declare i64 @str_to_int(i8*)")
    codegenEmit(cg, "declare double @_u6574_u6570_u8f6c_u6587_u672c_u90e8(i64)")
    codegenEmit(cg, "declare i64 @rt_string_len(i8*)")
    codegenEmit(cg, "declare i8* @rt_string_concat(i8*, i8*)")
    codegenEmit(cg, "declare i8* @rt_string_slice(i8*, i64, i64)")
    codegenEmit(cg, "declare i64 @argc()")
    codegenEmit(cg, "declare i8* @argv(i64)")
    codegenEmit(cg, "declare i8* @rt_readline()")
    codegenEmit(cg, "declare i64 @rt_list_new()")
    codegenEmit(cg, "declare void @rt_list_append(i8*, i8*)")
    codegenEmit(cg, "declare void @rt_list_set(i8*, i64, i8*)")
    codegenEmit(cg, "declare i8* @rt_list_get(i8*, i64)")
    codegenEmit(cg, "declare i64 @rt_list_len(i8*)")
    
    /* 文件 I/O 函数 */
    codegenEmit(cg, "declare i8* @file_read(i8*)")
    codegenEmit(cg, "declare i32 @file_write(i8*, i8*)")
    codegenEmit(cg, "declare i32 @file_exists(i8*)")
    codegenEmit(cg, "declare i32 @file_delete(i8*)")
    
    /* 命令执行函数 */
    codegenEmit(cg, "declare i32 @exec_cmd(i8*)")
    codegenEmit(cg, "declare i8* @cmd_output(i8*)")
    
    /* 输入函数 */
    codegenEmit(cg, "declare i64 @input_int()")
    codegenEmit(cg, "declare i8* @input_text()")
    
    打印("")
}

/* ============ 模块和导入支持 ============ */

/**
 * 生成模块声明
 */
函数 emitModuleDecl(cg: Codegen, moduleName: 文本) {
    定义 可变 line: 文本
    line = "; 模块: " + moduleName
    codegenEmit(cg, line)
}

/**
 * 生成导入声明
 */
函数 emitImportDecl(cg: Codegen, path: 文本) {
    定义 可变 line: 文本
    line = "; 导入: " + path
    codegenEmit(cg, line)
}

/**
 * 生成模块函数前缀
 */
函数 getModuleFuncName(moduleName: 文本, funcName: 文本): 文本 {
    若 moduleName == "" 则 {
        返回 funcName
    }
    返回 moduleName + "_" + funcName
}

/**
 * 生成外部函数声明
 */
函数 emitExternalFuncDecl(cg: Codegen, funcName: 文本, returnType: 文本, paramTypes: 列表) {
    定义 可变 line: 文本
    line = "declare " + returnType + " @" + funcName + "()"
    codegenEmit(cg, line)
}

/**
 * 生成模块入口标注
 */
函数 emitModuleEntry(cg: Codegen, moduleName: 文本): 无返回 {
    定义 可变 line: 文本
