/**
 * 生成调试位置
 */
函数 emitDebugLocation(cg: Codegen, line: 整数, col: 整数): 无返回 {
    定义 可变 debugStr: 文本
    debugStr = "!DILocation(line: " + 整数转文本(line) + ", column: " + 整数转文本(col) + ")"
    codegenEmit(cg, debugStr)
}

/**
 * 生成调试变量
 */
函数 emitDebugVariable(cg: Codegen, name: 文本, type: 文本): 无返回 {
    定义 可变 line: 文本
    line = "!DILocalVariable(name: \"" + name + "\", type: !" + type + ")"
    codegenEmit(cg, line)
}

/**
 * 生成行号标注
 */
函数 emitLineNumber(cg: Codegen, line: 整数): 无返回 {
    定义 可变 lineStr: 文本
    lineStr = "; 行号: " + 整数转文本(line)
    codegenEmit(cg, lineStr)
}

/* ============ 主函数 ============ */

/**
 * 生成完整的函数 IR
 */
函数 emitFunction(cg: Codegen, funcName: 文本, returnType: 文本, nodeCount: 整数) {
    打印("")
    打印("define " + returnType + " @" + funcName + "() {")

    cg.indent = cg.indent + 1
    cg.currentFunc = funcName
    cg.currentReturnType = returnType

    /* 变量分配 */
    打印("  %result = alloca i64")

    /* 函数体 - 根据函数名生成不同 IR */

    若 funcName == "主" 则 {
        /* 主函数: 返回 0 */
        打印("  %tmp0 = add i64 0, 0")
        打印("  ret i64 %tmp0")
    } 否则 {
        /* 默认返回 0 */
        打印("  %tmp0 = add i64 0, 0")
        打印("  ret i64 %tmp0")
    }

    cg.indent = cg.indent - 1
    打印("}")
}

/**
 * 生成 main 函数包装
 */
函数 emitMainWrapper(cg: Codegen) {
    打印("")
    打印("define i32 @main() {")
    cg.indent = 1

    定义 可变 result: 文本
    result = codegenNewTemp(cg)
    打印("  %" + result + " = call i64 @主()")
    定义 可变 truncVal: 文本
    truncVal = codegenNewTemp(cg)
    打印("  %" + truncVal + " = trunc i64 %" + result + " to i32")

    打印("  ret i32 %" + truncVal)
    打印("}")
}

/* ============ AST 遍历和语句生成 ============ */

/**
 * 生成表达式 IR
 */
函数 codegen生成表达式(cg: Codegen, exprKind: 整数, value: 文本, left: 文本, right: 文本): 文本 {
    定义 可变 result: 文本
    result = ""

    若 exprKind == 10 则 {
        /* 二元表达式 */
        定义 可变 llOp: 文本
        llOp = "add"
        若 value == "-" 则 { llOp = "sub" }
        若 value == "*" 则 { llOp = "mul" }
        若 value == "/" 则 { llOp = "sdiv" }
        若 value == "%" 则 { llOp = "srem" }

        result = codegenNewTemp(cg)
        定义 可变 line: 文本
        line = "%" + result + " = " + llOp + " i64 %" + left + ", %" + right
        codegenEmit(cg, line)
    } 否则 {
        若 exprKind == 14 则 {
            /* 字面量 */
            result = codegenNewTemp(cg)
            定义 可变 line: 文本
            line = "%" + result + " = add i64 0, " + value
            codegenEmit(cg, line)
        } 否则 {
            若 exprKind == 13 则 {
                /* 标识符 - 加载变量 */
                result = codegenNewTemp(cg)
                定义 可变 line: 文本
                line = "%" + result + " = load i64, i64* %" + value
                codegenEmit(cg, line)
            }
        }
    }

    返回 result
}

/**
 * 生成变量分配
 */
函数 codegen生成变量(cg: Codegen, varName: 文本, typeName: 文本): 文本 {
    定义 可变 tmpPtr: 文本
    tmpPtr = varName + "_slot"

    定义 可变 line: 文本
    line = "%" + tmpPtr + " = alloca " + getLLVMType(typeName)
    codegenEmit(cg, line)

    返回 tmpPtr
}

/**
 * 生成赋值语句
 */
函数 codegen生成赋值(cg: Codegen, varName: 文本, value: 文本, varType: 文本): 无返回 {
    定义 可变 tmpPtr: 文本
    tmpPtr = varName + "_slot"

    定义 可变 line: 文本
    line = "store " + getLLVMType(varType) + " %" + value + ", " + getLLVMType(varType) + "* %" + tmpPtr
    codegenEmit(cg, line)
}

/**
 * 生成 if 语句
 */
函数 codegen生成If(cg: Codegen, condVar: 文本, thenLabel: 文本, elseLabel: 文本, endLabel: 文本): 无返回 {
    定义 可变 line: 文本
    line = "br i1 %" + condVar + ", label %" + thenLabel + ", label %" + elseLabel
    codegenEmit(cg, line)

    cg.indent = cg.indent - 1
    codegenEmit(cg, thenLabel + ":")
    cg.indent = cg.indent + 1
}

/**
 * 生成 while 循环
 */
函数 codegen生成While(cg: Codegen, condVar: 文本, bodyLabel: 文本, endLabel: 文本): 无返回 {
    定义 可变 line: 文本
    line = "br i1 %" + condVar + ", label %" + bodyLabel + ", label %" + endLabel
    codegenEmit(cg, line)

    cg.indent = cg.indent - 1
    codegenEmit(cg, bodyLabel + ":")
    cg.indent = cg.indent + 1
}

/**
 * 生成 for 循环
 */
函数 codegen生成For(cg: Codegen, varName: 文本, startVal: 整数, endVal: 整数): 无返回 {
    定义 可变 iterVar: 文本
    iterVar = codegen生成变量(cg, varName, "整数")

    定义 可变 startTmp: 文本
    startTmp = codegenNewTemp(cg)
    定义 可变 line: 文本
    line = "%" + startTmp + " = add i64 0, " + 整数转文本(startVal)
    codegenEmit(cg, line)
    line = "store i64 %" + startTmp + ", i64* %" + iterVar
    codegenEmit(cg, line)
}

/**
 * 生成返回语句
 */
函数 codegen生成返回(cg: Codegen, value: 文本, returnType: 文本): 无返回 {
    定义 可变 line: 文本
    若 returnType == "void" 则 {
        line = "ret void"
    } 否则 {
        line = "ret i64 %" + value
    }
    codegenEmit(cg, line)
}

/**
 * 生成函数调用（带参数）
 */
函数 codegen生成调用(cg: Codegen, funcName: 文本, argCount: 整数, returnType: 文本): 文本 {
    定义 可变 result: 文本
    result = ""

    若 returnType != "void" 则 {
        定义 可变 tmp: 文本
        tmp = codegenNewTemp(cg)
        定义 可变 line: 文本
        line = "%" + tmp + " = call " + returnType + " @" + funcName + "()"
        codegenEmit(cg, line)
        result = tmp
    } 否则 {
        codegenEmit(cg, "call " + returnType + " @" + funcName + "()")
    }

    返回 result
}

/**
 * 生成比较表达式并跳转
 */
函数 codegen生成条件跳转(cg: Codegen, op: 文本, left: 文本, right: 文本, trueLabel: 文本, falseLabel: 文本): 无返回 {
    定义 可变 cmpResult: 文本
    cmpResult = codegenNewTemp(cg)

    定义 可变 llOp: 文本
    llOp = "eq"
    若 op == ">" 则 { llOp = "sgt" }
    若 op == "<" 则 { llOp = "slt" }
    若 op == ">=" 则 { llOp = "sge" }
    若 op == "<=" 则 { llOp = "sle" }
    若 op == "!=" 则 { llOp = "ne" }

    定义 可变 line: 文本
    line = "%" + cmpResult + " = icmp " + llOp + " i64 %" + left + ", %" + right
    codegenEmit(cg, line)

    line = "br i1 %" + cmpResult + ", label %" + trueLabel + ", label %" + falseLabel
    codegenEmit(cg, line)
}

/**
 * 生成 break 语句
 */
函数 codegen生成Break(cg: Codegen, endLabel: 文本): 无返回 {
    定义 可变 line: 文本
    line = "br label %" + endLabel
    codegenEmit(cg, line)
}

/**
 * 生成 continue 语句
 */
函数 codegen生成Continue(cg: Codegen, condLabel: 文本): 无返回 {
    定义 可变 line: 文本
    line = "br label %" + condLabel
    codegenEmit(cg, line)
}

/**
 * 生成打印调用
 */
函数 codegen生成打印(cg: Codegen, value: 文本, valueType: 文本): 无返回 {
    定义 可变 line: 文本
    若 valueType == "i64" 则 {
        line = "call void @print_int(i64 %" + value + ")"
    } 否则 {
        若 valueType == "i8*" 则 {
            line = "call void @print(i8* %" + value + ")"
        }
    }
    codegenEmit(cg, line)
}

/**
 * 生成输入调用
 */
函数 codegen生成输入(cg: Codegen, inputType: 文本): 文本 {
    定义 可变 result: 文本
    result = ""

    定义 可变 tmp: 文本
    tmp = codegenNewTemp(cg)

    定义 可变 line: 文本
    若 inputType == "i64" 则 {
        line = "%" + tmp + " = call i64 @str_to_int(i8* @rt_readline())"
        codegenEmit(cg, line)
        result = tmp
    } 否则 {
        若 inputType == "i8*" 则 {
            line = "%" + tmp + " = call i8* @rt_readline()"
            codegenEmit(cg, line)
            result = tmp
        }
    }

    返回 result
}

/**
 * 生成列表创建
 */
函数 codegen生成列表创建(cg: Codegen): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = call i64 @rt_list_new()"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成列表追加
 */
函数 codegen生成列表追加(cg: Codegen, list: 文本, value: 文本): 无返回 {
    定义 可变 line: 文本
    line = "call void @rt_list_append(i8* %" + list + ", i8* %" + value + ")"
    codegenEmit(cg, line)
}

/**
 * 生成列表获取
 */
函数 codegen生成列表获取(cg: Codegen, list: 文本, index: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = call i8* @rt_list_get(i8* %" + list + ", i64 %" + index + ")"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成字符串长度
 */
函数 codegen生成字符串长度(cg: Codegen, strPtr: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = call i64 @rt_string_len(i8* %" + strPtr + ")"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成字符串拼接
 */
函数 codegen生成字符串拼接(cg: Codegen, str1: 文本, str2: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = call i8* @rt_string_concat(i8* %" + str1 + ", i8* %" + str2 + ")"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 执行代码生成
 */
函数 codegenRun(astNodeCount: 整数): 整数 {
    打印("=== 代码生成 ===")

    定义 可变 cg: Codegen
    cg = codegenInit()

    /* 生成模块头 */
    emitModuleHeader(cg, "xuanyu_source")

    /* 生成目标数据 */
    emitTargetData(cg)

    /* 生成内置函数声明 */
    emitBuiltinDecls(cg)

    /* 生成用户函数 */
    打印("; ==================== 用户函数 ====================")
    emitFunction(cg, "主", "i64", 10)

    /* 生成 main 包装 */
    emitMainWrapper(cg)

    打印("")
    打印("代码生成完成!")

    返回 1
}

/* ============ 高级 IR 生成函数 ============ */

/**
 * 生成结构体字面量 IR
 */
函数 codegenStructLiteral(cg: Codegen, structName: 文本, fieldCount: 整数): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = alloca %" + structName
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成空联合 IR
 */
函数 codegenZeroInit(cg: Codegen, typeName: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = bitcast " + typeName + " null to " + typeName
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成条件选择 IR (使用 select)
 */
函数 codegenSelectOp(cg: Codegen, cond: 文本, trueVal: 文本, falseVal: 文本, resultType: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = select i1 %" + cond + ", " + resultType + " %" + trueVal + ", " + resultType + " %" + falseVal
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成 freeze IR (固定值)
 */
函数 codegenFreeze(cg: Codegen, value: 文本, valueType: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = freeze " + valueType + " %" + value
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成 extractvalue IR (从聚合值提取)
 */
函数 codegenExtractValue(cg: Codegen, aggregate: 文本, index: 整数, aggregateType: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = extractvalue " + aggregateType + " %" + aggregate + ", " + 整数转文本(index)
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成 insertvalue IR (向聚合值插入)
 */
函数 codegenInsertValue(cg: Codegen, aggregate: 文本, value: 文本, index: 整数, aggregateType: 文本, valueType: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = insertvalue " + aggregateType + " %" + aggregate + ", " + valueType + " %" + value + ", " + 整数转文本(index)
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成 extractelement IR (从向量提取元素)
 */
函数 codegenExtractElement(cg: Codegen, vector: 文本, index: 文本, vectorWidth: 整数): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = extractelement <" + 整数转文本(vectorWidth) + " x i64> %" + vector + ", i64 %" + index
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成 insertelement IR (向向量插入元素)
 */
函数 codegenInsertElement(cg: Codegen, vector: 文本, value: 文本, index: 文本, vectorWidth: 整数): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = insertelement <" + 整数转文本(vectorWidth) + " x i64> %" + vector + ", i64 %" + value + ", i64 %" + index
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成 shufflevector IR (向量混洗)
 */
函数 codegenShuffleVector(cg: Codegen, v1: 文本, v2: 文本, mask: 文本, width: 整数): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = shufflevector <" + 整数转文本(width) + " x i64> %" + v1 + ", <" + 整数转文本(width) + " x i64> %" + v2 + ", <" + 整数转文本(width) + " x i32> %" + mask
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成 icmp 并转换为整数 IR
 */
函数 codegenIcmpToInt(cg: Codegen, op: 文本, left: 文本, right: 文本): 文本 {
    定义 可变 cmpResult: 文本
    cmpResult = codegenCompare(cg, op, left, right)

    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = zext i1 %" + cmpResult + " to i64"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成快速调用 IR (无返回值的调用)
 */
函数 codegenFastCall(cg: Codegen, funcName: 文本): 无返回 {
    codegenEmit(cg, "call void @" + funcName + "()")
}

/**
 * 生成 tail 调用提示 IR
 */
函数 codegenTailCallHint(cg: Codegen): 无返回 {
    codegenEmit(cg, "; tail call hint")
}

/**
 * 生成 musttail 调用提示 IR
 */
函数 codegenMustTailCall(cg: Codegen): 无返回 {
