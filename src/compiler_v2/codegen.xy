/* ============ AST 遍历核心入口 ============ */

/**
 * 遍历 AST 根节点生成完整 IR
 */
函数 codegen遍历AST(ast: AST节点): 文本 {
    定义 可变 cg: Codegen
    cg = codegenInit()

    打印("=== 开始 AST 遍历 ===")

    定义 可变 line: 文本
    line = "; Module: xuanyu_program"
    codegenEmit(cg, line)

    /* 生成模块头 */
    emitModuleHeader(cg, "xuanyu_program")

    /* 生成目标数据 */
    emitTargetData(cg)

    /* 生成内置函数声明 */
    emitBuiltinDecls(cg)

    /* 遍历顶层声明 */
    定义 可变 i: 整数
    i = 0
    当 i < 100 && i < 列表长度(ast.children) 则 {
        定义 可变 child: AST节点
        child = 列表获取(ast.children, i)

        若 child.kind == 1 则 {
            /* 函数定义 */
            codegen遍历函数定义(cg, child)
        } 否则 {
            若 child.kind == 21 则 {
                /* 结构体定义 */
                codegen遍历结构体定义(cg, child)
            } 否则 {
                若 child.kind == 22 则 {
                    /* 枚举定义 */
                    codegen遍历枚举定义(cg, child)
                } 否则 {
                    若 child.kind == 29 则 {
                        /* 模块定义 */
                        codegen遍历模块定义(cg, child)
                    } 否则 {
                        若 child.kind == 28 则 {
                            /* 导入语句 */
                            codegen遍历导入语句(cg, child)
                        } 否则 {
                            若 child.kind == 30 则 {
                                /* 外部声明 - 直接跳过，不生成代码 */
                            }
                        }
                    }
                }
            }
        }
        i = i + 1
    }

    /* 生成 main 包装 */
    emitMainWrapper(cg)

    打印("=== AST 遍历完成 ===")
    打印("共生成 ")
    打印(cg.funcCount)
    打印(" 个函数")

    /* 构建最终 IR 字符串 */
    定义 可变 result: 文本
    result = ""
    定义 可变 i: 整数
    i = 0
    当 i < 列表长度(cg.output) 则 {
        result = result + 列表获取(cg.output, i) + "\n"
        i = i + 1
    }
    返回 result
}

/**
 * 遍历结构体定义
 */
函数 codegen遍历结构体定义(cg: Codegen, structNode: AST节点): 无返回 {
    定义 可变 structName: 文本
    structName = structNode.name

    打印("生成结构体: ")
    打印(structName)

    定义 可变 line: 文本
    line = "; 结构体: " + structName
    codegenEmit(cg, line)

    定义 可变 i: 整数
    i = 0
    当 i < 列表长度(structNode.children) && i < 20 则 {
        定义 可变 field: AST节点
        field = structNode.children[i]
        打印("  字段: ")
        打印(field.name)
        i = i + 1
    }
}

/**
 * 遍历枚举定义
 */
函数 codegen遍历枚举定义(cg: Codegen, enumNode: AST节点): 无返回 {
    定义 可变 enumName: 文本
    enumName = enumNode.name

    打印("生成枚举: ")
