    codegenEmit(cg, line)
}

/**
 * 生成模块退出标注
 */
函数 emitModuleExit(cg: Codegen, moduleName: 文本): 无返回 {
    定义 可变 line: 文本
    line = "; 模块退出: " + moduleName
    codegenEmit(cg, line)
}

/* ============ 优化和提示 ============ */

/**
 * 生成优化级别标注
 */
函数 emitOptimizationHint(cg: Codegen, level: 整数): 无返回 {
    定义 可变 line: 文本
    line = "; llvm. opts: "
    若 level == 0 则 {
        line = line + "O0"
    } 否则 {
        若 level == 1 则 {
            line = line + "O1"
        } 否则 {
            若 level == 2 则 {
                line = line + "O2"
            } 否则 {
                若 level == 3 则 {
                    line = line + "O3"
                } 否则 {
                    line = line + "Os"
                }
            }
        }
    }
    codegenEmit(cg, line)
}

/**
 * 生成冷函数标注
 */
函数 emitColdFunctionHint(cg: Codegen): 无返回 {
    codegenEmit(cg, "; Function Attrs: cold")
    codegenEmit(cg, "; llvm.pure.const")
}

/**
 * 生成内联始终标注
 */
函数 emitAlwaysInlineHint(cg: Codegen): 无返回 {
    codegenEmit(cg, "; Function Attrs: alwaysinline")
}

/**
 * 生成无返回标注
 */
函数 emitNoReturnHint(cg: Codegen): 无返回 {
    codegenEmit(cg, "; Function Attrs: noreturn")
}

/**
 * 生成只读标注
 */
函数 emitReadOnlyHint(cg: Codegen): 无返回 {
    codegenEmit(cg, "; Function Attrs: readnone")
}

/**
 * 生成纯函数标注
 */
函数 emitPureFunctionHint(cg: Codegen): 无返回 {
    codegenEmit(cg, "; Function Attrs: readonly")
}

/**
 * 生成热点函数标注
 */
函数 emitHotFunctionHint(cg: Codegen): 无返回 {
    codegenEmit(cg, "; Function Attrs: hot")
}

/**
 * 生成内存访问模式标注
 */
函数 emitAlignmentHint(cg: Codegen, alignment: 整数): 无返回 {
    定义 可变 line: 文本
    line = "; Memory['"
    line = line + 整数转文本(alignment)
    line = line + "']"
    codegenEmit(cg, line)
}

/**
 * 生成向量宽度提示
 */
函数 emitVectorWidthHint(cg: Codegen, width: 整数): 无返回 {
    若 width > 1 则 {
        定义 可变 line: 文本
        line = "; Vector['"
        line = line + 整数转文本(width)
        line = line + "']"
        codegenEmit(cg, line)
    }
}

/**
 * 生成窥孔优化提示
 */
函数 emitPeepholeHint(cg: Codegen): 无返回 {
    codegenEmit(cg, "; Tails duplicated")
}

