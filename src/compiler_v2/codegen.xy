/**
 * @file codegen.xy
 * @brief 代码生成器 - 自展编译器
 * @description 生成 LLVM IR 指令，实现真实 AST 遍历
 */

引入 "src/compiler_v2/parser.xy"
引入 "src/compiler_v2/sema.xy"

/* ============ Codegen 结构 ============ */

结构体 Codegen {
    moduleName: 文本,
    tempCount: 整数,
    labelCount: 整数,
    funcCount: 整数,
    output: 列表,
    indent: 整数,
    stringConstCount: 整数,
    funcDefs: 列表,
    currentFunc: 文本,
    currentReturnType: 文本
}

/* ============ LLVM 类型映射 ============ */

函数 getLLVMType(typeName: 文本): 文本 {
    若 typeName == "整数" 或 typeName == "长整数" 则 { 返回 "i64" }
    若 typeName == "浮点数" 或 typeName == "双精度" 则 { 返回 "double" }
    若 typeName == "布尔" 则 { 返回 "i1" }
    若 typeName == "文本" 或 typeName == "字符" 则 { 返回 "i8*" }
    若 typeName == "无返回" 则 { 返回 "void" }
    返回 "i64"
}

/* ============ 初始化 ============ */

函数 codegenInit(): Codegen {
    定义 cg: Codegen
    cg.moduleName = "xuanyu_module"
    cg.tempCount = 0
    cg.labelCount = 0
    cg.funcCount = 0
    cg.output = 列表()
    cg.indent = 0
    cg.stringConstCount = 0
    cg.funcDefs = 列表()
    cg.currentFunc = ""
    cg.currentReturnType = "i64"
    返回 cg
}

/* ============ 输出函数 ============ */

函数 codegenEmitLine(cg: Codegen, line: 文本) {
    定义 i: 整数
    i = 0
    当 i < cg.indent 则 {
        打印("  ")
        i = i + 1
    }
    打印(line)
}

函数 codegenEmit(cg: Codegen, content: 文本) {
    codegenEmitLine(cg, content)
}

/* ============ 标签和临时变量 ============ */

函数 codegenNewLabel(cg: Codegen): 文本 {
    定义 num: 整数
    num = cg.labelCount
    cg.labelCount = cg.labelCount + 1
    定义 result: 文本
    result = "L"
    定义 numStr: 文本
    numStr = 整数转文本(num)
    result = result + numStr
    返回 result
}

函数 codegenNewTemp(cg: Codegen): 文本 {
    定义 num: 整数
    num = cg.tempCount
    cg.tempCount = cg.tempCount + 1
    定义 result: 文本
    result = "tmp"
    定义 tmpStr: 文本
    tmpStr = 整数转文本(num)
    result = result + tmpStr
    返回 result
}

/* ============ AST 遍历和 IR 生成函数 ============ */

/**
 * 生成字面量值 IR
 */
函数 codegenLiteral(cg: Codegen, value: 文本, type: 整数): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    若 type == 1 则 {
        // 整数
        定义 line: 文本
        line = "%" + result + " = add i64 0, " + value
        codegenEmit(cg, line)
    } 否则 {
        若 type == 2 则 {
            // 字符串
            定义 ptr: 文本
            ptr = codegenNewTemp(cg)
            codegenEmit(cg, "%" + ptr + " = getelementptr [0 x i8], [0 x i8]* null, i64 0, i64 0")
            result = ptr
        } 否则 {
            // 默认作为整数
            codegenEmit(cg, "%" + result + " = add i64 0, " + value)
        }
    }

    返回 result
}

/**
 * 生成二元表达式 IR
 */
函数 codegenBinaryOp(cg: Codegen, op: 文本, left: 文本, right: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 llOp: 文本
    llOp = "add"

    若 op == "+" 则 { llOp = "add" }
    若 op == "-" 则 { llOp = "sub" }
    若 op == "*" 则 { llOp = "mul" }
    若 op == "/" 则 { llOp = "sdiv" }
    若 op == "%" 则 { llOp = "srem" }

    定义 line: 文本
    line = "%" + result + " = " + llOp + " i64 %" + left + ", %" + right
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成比较表达式 IR
 */
函数 codegenCompare(cg: Codegen, op: 文本, left: 文本, right: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 llOp: 文本
    llOp = "eq"

    若 op == "==" 则 { llOp = "eq" }
    若 op == "!=" 则 { llOp = "ne" }
    若 op == "<" 则 { llOp = "slt" }
    若 op == ">" 则 { llOp = "sgt" }
    若 op == "<=" 则 { llOp = "sle" }
    若 op == ">=" 则 { llOp = "sge" }

    定义 line: 文本
    line = "%" + result + " = icmp " + llOp + " i64 %" + left + ", %" + right
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成逻辑与 (&&) IR
 */
函数 codegenLogicalAnd(cg: Codegen, left: 文本, right: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = and i1 %" + left + ", %" + right
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成逻辑或 (||) IR
 */
函数 codegenLogicalOr(cg: Codegen, left: 文本, right: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = or i1 %" + left + ", %" + right
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成逻辑非 (!) IR
 */
函数 codegenLogicalNot(cg: Codegen, value: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = xor i1 %" + value + ", 1"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成一元减法 IR
 */
函数 codegenNegate(cg: Codegen, value: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = sub i64 0, %" + value
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成符号扩展 IR
 */
函数 codegenSignExt(cg: Codegen, value: 文本, fromType: 文本, toType: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = sext " + fromType + " %" + value + " to " + toType
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成零扩展 IR
 */
函数 codegenZeroExt(cg: Codegen, value: 文本, fromType: 文本, toType: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = zext " + fromType + " %" + value + " to " + toType
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成截断 IR
 */
函数 codegenTrunc(cg: Codegen, value: 文本, fromType: 文本, toType: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = trunc " + fromType + " %" + value + " to " + toType
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成浮点到整数的转换 IR
 */
函数 codegenFptoSI(cg: Codegen, value: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = fptosi double %" + value + " to i64"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成整数到浮点的转换 IR
 */
函数 codegenSIToFP(cg: Codegen, value: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = sitofp i64 %" + value + " to double"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成数组分配 IR
 */
函数 codegenArrayAlloca(cg: Codegen, elementType: 文本, numElements: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = alloca " + elementType + ", i64 %" + numElements
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成数组元素访问 IR
 */
函数 codegenArrayAccess(cg: Codegen, arrayPtr: 文本, index: 文本, elementType: 文本): 文本 {
    定义 ptr: 文本
    ptr = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + ptr + " = getelementptr " + elementType + ", " + elementType + "* %" + arrayPtr + ", i64 %" + index
    codegenEmit(cg, line)

    定义 value: 文本
    value = codegenNewTemp(cg)
    line = "%" + value + " = load " + elementType + ", " + elementType + "* %" + ptr
    codegenEmit(cg, line)

    返回 value
}

/**
 * 生成数组元素存储 IR
 */
函数 codegenArrayStore(cg: Codegen, arrayPtr: 文本, index: 文本, value: 文本, elementType: 文本): 无返回 {
    定义 ptr: 文本
    ptr = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + ptr + " = getelementptr " + elementType + ", " + elementType + "* %" + arrayPtr + ", i64 %" + index
    codegenEmit(cg, line)

    line = "store " + elementType + " %" + value + ", " + elementType + "* %" + ptr
    codegenEmit(cg, line)
}

/**
 * 生成结构体分配 IR
 */
函数 codegenStructAlloca(cg: Codegen, structType: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = alloca " + structType
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成结构体字段访问 IR (使用字段索引)
 */
函数 codegenStructFieldAccess(cg: Codegen, structPtr: 文本, fieldIndex: 整数, fieldType: 文本): 文本 {
    定义 ptr: 文本
    ptr = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + ptr + " = getelementptr " + fieldType + ", " + fieldType + "* %" + structPtr + ", i32 0, i32 " + 整数转文本(fieldIndex)
    codegenEmit(cg, line)

    定义 value: 文本
    value = codegenNewTemp(cg)
    line = "%" + value + " = load " + fieldType + ", " + fieldType + "* %" + ptr
    codegenEmit(cg, line)

    返回 value
}

/**
 * 生成结构体字段存储 IR
 */
函数 codegenStructFieldStore(cg: Codegen, structPtr: 文本, fieldIndex: 整数, value: 文本, fieldType: 文本): 无返回 {
    定义 ptr: 文本
    ptr = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + ptr + " = getelementptr " + fieldType + ", " + fieldType + "* %" + structPtr + ", i32 0, i32 " + 整数转文本(fieldIndex)
    codegenEmit(cg, line)

    line = "store " + fieldType + " %" + value + ", " + fieldType + "* %" + ptr
    codegenEmit(cg, line)
}

/**
 * 生成空指针检查 IR
 */
函数 codegenNullCheck(cg: Codegen, ptr: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = icmp ne i8* %" + ptr + ", null"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成全局变量声明 IR
 */
函数 codegenGlobalString(cg: Codegen, strValue: 文本, name: 文本): 文本 {
    定义 line: 文本
    line = "@" + name + " = private constant [0 x i8] c\"" + strValue + "\\00\""
    codegenEmit(cg, line)

    返回 name
}

/**
 * 生成全局变量声明 IR (整数)
 */
函数 codegenGlobalInt(cg: Codegen, value: 整数, name: 文本): 文本 {
    定义 line: 文本
    line = "@" + name + " = global i64 " + 整数转文本(value)
    codegenEmit(cg, line)

    返回 name
}

/**
 * 生成选择性 IR (cond ? then : else)
 */
函数 codegenSelect(cg: Codegen, cond: 文本, thenValue: 文本, elseValue: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = select i1 %" + cond + ", i64 %" + thenValue + ", i64 %" + elseValue
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成位旋转 IR (左移后带符号扩展)
 */
函数 codegenShl(cg: Codegen, value: 文本, amount: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = shl i64 %" + value + ", %" + amount
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成算术右移 IR
 */
函数 codegenAShr(cg: Codegen, value: 文本, amount: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = ashr i64 %" + value + ", %" + amount
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成逻辑右移 IR
 */
函数 codegenLShr(cg: Codegen, value: 文本, amount: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = lshr i64 %" + value + ", %" + amount
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成按位与 IR
 */
函数 codegenAnd(cg: Codegen, left: 文本, right: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = and i64 %" + left + ", %" + right
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成按位或 IR
 */
函数 codegenOr(cg: Codegen, left: 文本, right: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = or i64 %" + left + ", %" + right
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成按位异或 IR
 */
函数 codegenXor(cg: Codegen, left: 文本, right: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = xor i64 %" + left + ", %" + right
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成按位取反 IR
 */
函数 codegenNot(cg: Codegen, value: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = xor i64 %" + value + ", -1"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成函数入口标注
 */
函数 codegenFunctionEntry(cg: Codegen, funcName: 文本): 无返回 {
    定义 line: 文本
    line = "; 函数入口: " + funcName
    codegenEmit(cg, line)
}

/**
 * 生成代码块标注
 */
函数 codegenBlockLabel(cg: Codegen, blockName: 文本): 无返回 {
    定义 line: 文本
    line = "; 代码块: " + blockName
    codegenEmit(cg, line)
}

/**
 * 生成注释
 */
函数 codegenComment(cg: Codegen, comment: 文本): 无返回 {
    定义 line: 文本
    line = "; " + comment
    codegenEmit(cg, line)
}

/**
 * 生成 unreachable 指令 IR
 */
函数 codegenUnreachable(cg: Codegen): 无返回 {
    codegenEmit(cg, "unreachable")
}

/**
 * 生成 switch 指令 IR (用于 match 语句)
 */
函数 codegenSwitch(cg: Codegen, value: 文本, defaultLabel: 文本, numCases: 整数) {
    定义 line: 文本
    line = "switch i64 %" + value + ", label %" + defaultLabel
    codegenEmit(cg, line)
}

/**
 * 生成 case 分支 IR
 */
函数 codegenCase(cg: Codegen, caseValue: 文本, caseLabel: 文本) {
    定义 line: 文本
    line = "i64 " + caseValue + ", label %" + caseLabel
    codegenEmit(cg, line)
}

/**
 * 生成 match 语句 IR
 */
函数 codegenMatch(cg: Codegen, subjectValue: 文本, caseCount: 整数, hasDefault: 整数): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 endLabel: 文本
    endLabel = codegenNewLabel(cg)

    定义 defaultLabel: 文本
    defaultLabel = codegenNewLabel(cg)

    定义 line: 文本
    line = "switch i64 %" + subjectValue + ", label %" + defaultLabel
    codegenEmit(cg, line)

    定义 i: 整数
    i = 0
    当 i < caseCount 则 {
        定义 caseLabel: 文本
        caseLabel = codegenNewLabel(cg)
        line = "i64 " + 整数转文本(i) + ", label %" + caseLabel
        codegenEmit(cg, line)
        i = i + 1
    }

    /* 默认标签 */
    cg.indent = cg.indent - 1
    codegenEmit(cg, defaultLabel + ":")
    cg.indent = cg.indent + 1

    若 hasDefault == 0 则 {
        codegenEmit(cg, "unreachable")
    }

    /* 结束标签 */
    cg.indent = cg.indent - 1
    codegenEmit(cg, endLabel + ":")
    cg.indent = cg.indent + 1

    返回 result
}

/**
 * 生成 phi 节点 IR (用于 match 分支的值合并)
 */
函数 codegenPhi(cg: Codegen, numValues: 整数): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = phi i64"
    定义 i: 整数
    i = 0
    当 i < numValues 则 {
        定义 label: 文本
        label = codegenNewLabel(cg)
        line = line + " [%tmp" + 整数转文本(i) + ", %L" + 整数转文本(i) + "]"
        若 i < numValues - 1 则 {
            line = line + ","
        }
        i = i + 1
    }
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成 if 语句 IR
 */
函数 codegenIf(cg: Codegen, condVar: 文本, thenLabel: 文本, elseLabel: 文本, endLabel: 文本) {
    定义 line: 文本
    line = "br i1 %" + condVar + ", label %" + thenLabel + ", label %" + elseLabel
    codegenEmit(cg, line)

    cg.indent = cg.indent - 1
    codegenEmit(cg, thenLabel + ":")
    cg.indent = cg.indent + 1
}

/**
 * 生成 while 循环 IR
 */
函数 codegenWhile(cg: Codegen, condVar: 文本, bodyLabel: 文本, endLabel: 文本) {
    定义 line: 文本
    line = "br i1 %" + condVar + ", label %" + bodyLabel + ", label %" + endLabel
    codegenEmit(cg, line)

    cg.indent = cg.indent - 1
    codegenEmit(cg, bodyLabel + ":")
    cg.indent = cg.indent + 1
}

/**
 * 生成 for 循环 IR
 */
函数 codegenFor(cg: Codegen, varName: 文本, startVal: 整数, endVal: 整数, bodyLabel: 文本, condLabel: 文本, endLabel: 文本) {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = add i64 0, " + 整数转文本(startVal)
    codegenEmit(cg, line)

    定义 alloca: 文本
    alloca = varName + "_alloca"
    codegenEmit(cg, "%" + alloca + " = alloca i64")
    codegenEmit(cg, "store i64 %" + result + ", i64* %" + alloca)

    cg.indent = cg.indent - 1
    codegenEmit(cg, condLabel + ":")
    cg.indent = cg.indent + 1

    定义 cmpResult: 文本
    cmpResult = codegenNewTemp(cg)
    line = "%" + cmpResult + " = icmp sle i64 %" + result + ", " + 整数转文本(endVal)
    codegenEmit(cg, line)
    line = "br i1 %" + cmpResult + ", label %" + bodyLabel + ", label %" + endLabel
    codegenEmit(cg, line)

    cg.indent = cg.indent - 1
    codegenEmit(cg, bodyLabel + ":")
    cg.indent = cg.indent + 1
}

/**
 * 生成 break 跳转 IR
 */
函数 codegenBreak(cg: Codegen, endLabel: 文本) {
    定义 line: 文本
    line = "br label %" + endLabel
    codegenEmit(cg, line)
}

/**
 * 生成 continue 跳转 IR
 */
函数 codegenContinue(cg: Codegen, condLabel: 文本) {
    定义 line: 文本
    line = "br label %" + condLabel
    codegenEmit(cg, line)
}

/**
 * 生成赋值 IR
 */
函数 codegenAssign(cg: Codegen, varName: 文本, value: 文本, varType: 文本) {
    定义 llType: 文本
    llType = getLLVMType(varType)

    定义 alloca: 文本
    alloca = varName + "_slot"

    定义 line: 文本
    line = "%" + alloca + " = alloca " + llType
    codegenEmit(cg, line)

    line = "store " + llType + " %" + value + ", " + llType + "* %" + alloca
    codegenEmit(cg, line)
}

/**
 * 生成复合赋值 IR (+=, -=, *=, /=, %=)
 */
函数 codegenCompoundAssign(cg: Codegen, varName: 文本, op: 文本, value: 文本, varType: 文本): 文本 {
    定义 llType: 文本
    llType = getLLVMType(varType)

    定义 alloca: 文本
    alloca = varName + "_slot"

    定义 line: 文本
    line = "%" + alloca + " = alloca " + llType
    codegenEmit(cg, line)

    定义 llOp: 文本
    llOp = "add"

    若 op == "+=" 则 { llOp = "add" }
    若 op == "-=" 则 { llOp = "sub" }
    若 op == "*=" 则 { llOp = "mul" }
    若 op == "/=" 则 { llOp = "sdiv" }
    若 op == "%=" 则 { llOp = "srem" }

    定义 result: 文本
    result = codegenNewTemp(cg)
    line = "%" + result + " = " + llOp + " " + llType + " %" + value + ", %" + value
    codegenEmit(cg, line)

    line = "store " + llType + " %" + result + ", " + llType + "* %" + alloca
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成 return 语句 IR
 */
函数 codegenReturn(cg: Codegen, value: 文本) {
    定义 line: 文本
    若 cg.currentReturnType == "void" 则 {
        line = "ret void"
    } 否则 {
        line = "ret i64 %" + value
    }
    codegenEmit(cg, line)
}

/**
 * 生成函数调用 IR
 */
函数 codegenCall(cg: Codegen, funcName: 文本, returnType: 文本): 文本 {
    定义 result: 文本
    result = ""

    若 returnType != "void" 则 {
        定义 tmp: 文本
        tmp = codegenNewTemp(cg)
        codegenEmit(cg, "%" + tmp + " = call " + returnType + " @" + funcName + "()")
        result = tmp
    } 否则 {
        codegenEmit(cg, "call " + returnType + " @" + funcName + "()")
    }

    返回 result
}

/**
 * 生成函数调用 IR（带参数）
 */
函数 codegenCallWithArgs(cg: Codegen, funcName: 文本, argCount: 整数, returnType: 文本): 文本 {
    定义 result: 文本
    result = ""

    若 returnType != "void" 则 {
        定义 tmp: 文本
        tmp = codegenNewTemp(cg)
        定义 line: 文本
        line = "%" + tmp + " = call " + returnType + " @" + funcName + "("
        /* 简化：参数列表留空 */
        line = line + ")"
        codegenEmit(cg, line)
        result = tmp
    } 否则 {
        codegenEmit(cg, "call " + returnType + " @" + funcName + "()")
    }

    返回 result
}

/**
 * 生成字符串长度调用 IR
 */
函数 codegenStringLen(cg: Codegen, strPtr: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = call i64 @rt_string_len(i8* %" + strPtr + ")"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成字符串拼接调用 IR
 */
函数 codegenStringConcat(cg: Codegen, str1: 文本, str2: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = call i8* @rt_string_concat(i8* %" + str1 + ", i8* %" + str2 + ")"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成字符串切片调用 IR
 */
函数 codegenStringSlice(cg: Codegen, strPtr: 文本, start: 文本, end: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = call i8* @rt_string_slice(i8* %" + strPtr + ", i64 %" + start + ", i64 %" + end + ")"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成列表创建调用 IR
 */
函数 codegenListNew(cg: Codegen): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = call i64 @rt_list_new()"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成列表追加调用 IR
 */
函数 codegenListAppend(cg: Codegen, list: 文本, value: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = call i64 @rt_list_append(i64 %" + list + ", i64 %" + value + ")"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成列表获取调用 IR
 */
函数 codegenListGet(cg: Codegen, list: 文本, index: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = call i64 @rt_list_get(i64 %" + list + ", i64 %" + index + ")"
    codegenEmit(cg, line)

    返回 result
}

/* ============ IR 生成函数 ============ */

/**
 * 生成模块头
 */
函数 emitModuleHeader(cg: Codegen, name: 文本) {
    打印("; ============================================")
    打印("; 玄语编译器 v0.2 - 自展版本")
    打印("; LLVM IR 生成")
    打印("; ============================================")
    打印("")
    codegenEmit(cg, "source_filename = \"" + name + "\"")
    打印("")
}

/**
 * 生成目标数据声明
 */
函数 emitTargetData(cg: Codegen) {
    codegenEmit(cg, "target datalayout = \"e-m:w-p64:64:64-i32:32-i64:64-i128:128-n32:64-S128\"")
    codegenEmit(cg, "target triple = \"x86_64-pc-windows-msvc\"")
    打印("")
}

/**
 * 生成函数头
 */
函数 emitFunctionHeader(cg: Codegen, name: 文本, paramCount: 整数, returnType: 文本): 文本 {
    定义 llName: 文本
    llName = name

    定义 line: 文本
    line = "define " + returnType + " @" + llName + "() {"

    codegenEmitLine(cg, line)

    cg.indent = cg.indent + 1
    返回 name
}

/**
 * 生成变量分配
 */
函数 emitAlloca(cg: Codegen, varName: 文本, typeName: 文本) {
    定义 llType: 文本
    llType = getLLVMType(typeName)
    定义 line: 文本
    line = "%" + varName + " = alloca " + llType
    codegenEmit(cg, line)
}

/**
 * 生成存储指令
 */
函数 emitStore(cg: Codegen, value: 文本, varName: 文本, typeName: 文本) {
    定义 llType: 文本
    llType = getLLVMType(typeName)
    定义 line: 文本
    line = "store " + llType + " %" + value + ", " + llType + "* %" + varName
    codegenEmit(cg, line)
}

/**
 * 生成加载指令
 */
函数 emitLoad(cg: Codegen, varName: 文本, typeName: 文本): 文本 {
    定义 llType: 文本
    llType = getLLVMType(typeName)
    定义 result: 文本
    result = codegenNewTemp(cg)
    定义 line: 文本
    line = "%" + result + " = load " + llType + ", " + llType + "* %" + varName
    codegenEmit(cg, line)
    返回 result
}

/**
 * 生成整数常量
 */
函数 emitIntegerLiteral(cg: Codegen, value: 整数): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)
    定义 line: 文本
    line = "%" + result + " = add i64 0, " + 整数转文本(value)
    codegenEmit(cg, line)
    返回 result
}

/**
 * 生成字符串常量
 */
函数 emitStringLiteral(cg: Codegen, strValue: 文本): 文本 {
    定义 constName: 文本
    constName = "str"
    定义 idxStr: 文本
    idxStr = 整数转文本(cg.stringConstCount)
    constName = constName + idxStr
    cg.stringConstCount = cg.stringConstCount + 1

    定义 line: 文本
    line = "@" + constName + " = private constant [" + 整数转文本(文本长度(strValue)) + " x i8] c\"" + strValue + "\\00\""
    codegenEmit(cg, line)

    定义 ptrResult: 文本
    ptrResult = codegenNewTemp(cg)
    line = "%" + ptrResult + " = getelementptr [" + 整数转文本(文本长度(strValue)) + " x i8], [" + 整数转文本(文本长度(strValue)) + " x i8]* @" + constName + ", i64 0, i64 0"
    codegenEmit(cg, line)

    返回 ptrResult
}

/**
 * 生成二元运算
 */
函数 emitBinaryOp(cg: Codegen, op: 文本, left: 文本, right: 文本, leftType: 文本, rightType: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 llOp: 文本
    llOp = "+"
    若 op == "-" 则 { llOp = "sub" }
    若 op == "*" 则 { llOp = "mul" }
    若 op == "/" 则 { llOp = "sdiv" }
    若 op == "%" 则 { llOp = "srem" }

    定义 llType: 文本
    llType = getLLVMType(leftType)

    定义 line: 文本
    line = "%" + result + " = " + llOp + " " + llType + " %" + left + ", %" + right
    codegenEmit(cg, line)
    返回 result
}

/**
 * 生成比较指令
 */
函数 emitCompare(cg: Codegen, op: 文本, left: 文本, right: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 llOp: 文本
    llOp = "eq"
    若 op == ">" 则 { llOp = "sgt" }
    若 op == "<" 则 { llOp = "slt" }
    若 op == ">=" 则 { llOp = "sge" }
    若 op == "<=" 则 { llOp = "sle" }
    若 op == "!=" 则 { llOp = "ne" }

    定义 line: 文本
    line = "%" + result + " = icmp " + llOp + " i64 %" + left + ", %" + right
    codegenEmit(cg, line)
    返回 result
}

/**
 * 生成条件分支
 */
函数 emitBr(cg: Codegen, condVar: 文本, thenLabel: 文本, elseLabel: 文本) {
    定义 line: 文本
    line = "br i1 %" + condVar + ", label %" + thenLabel + ", label %" + elseLabel
    codegenEmit(cg, line)
}

/**
 * 生成无条件跳转
 */
函数 emitJump(cg: Codegen, labelName: 文本) {
    定义 line: 文本
    line = "br label %" + labelName
    codegenEmit(cg, line)
}

/**
 * 生成标签
 */
函数 emitLabel(cg: Codegen, labelName: 文本) {
    cg.indent = cg.indent - 1
    定义 line: 文本
    line = labelName + ":"
    codegenEmitLine(cg, line)
    cg.indent = cg.indent + 1
}

/**
 * 生成返回指令
 */
函数 emitReturn(cg: Codegen, valueName: 文本, returnType: 文本) {
    定义 line: 文本
    若 returnType == "void" 则 {
        line = "ret void"
    } 否则 {
        line = "ret i64 %" + valueName
    }
    codegenEmit(cg, line)
}

/**
 * 生成函数调用
 */
函数 emitCall(cg: Codegen, funcName: 文本, argCount: 整数, returnType: 文本): 文本 {
    定义 result: 文本
    result = ""

    若 returnType != "void" 则 {
        result = codegenNewTemp(cg)
        定义 line: 文本
        line = "%" + result + " = call " + returnType + " @" + funcName + "()"
        codegenEmit(cg, line)
    } 否则 {
        codegenEmit(cg, "call " + returnType + " @" + funcName + "()")
    }

    返回 result
}

/* ============ 内置函数声明 ============ */

函数 emitBuiltinDecls(cg: Codegen) {
    打印("; ==================== 内置函数声明 ====================")
    codegenEmit(cg, "declare void @print(i8*)")
    codegenEmit(cg, "declare i64 @print_int(i64)")
    codegenEmit(cg, "declare double @print_float(double)")
    codegenEmit(cg, "declare i8* @print_string(i8*)")
    codegenEmit(cg, "declare i64 @str_to_int(i8*)")
    codegenEmit(cg, "declare i8* @int_to_str(i64)")
    codegenEmit(cg, "declare i64 @rt_string_len(i8*)")
    codegenEmit(cg, "declare i8* @rt_string_concat(i8*, i8*)")
    codegenEmit(cg, "declare i8* @rt_string_slice(i8*, i64, i64)")
    codegenEmit(cg, "declare i64 @argc()")
    codegenEmit(cg, "declare i8* @argv(i64)")
    codegenEmit(cg, "declare i8* @rt_readline()")
    codegenEmit(cg, "declare i64 @rt_list_new()")
    codegenEmit(cg, "declare i64 @rt_list_append(i64, i64)")
    codegenEmit(cg, "declare i64 @rt_list_get(i64, i64)")
    codegenEmit(cg, "declare i64 @rt_list_len(i64)")
    打印("")
}

/* ============ 模块和导入支持 ============ */

/**
 * 生成模块声明
 */
函数 emitModuleDecl(cg: Codegen, moduleName: 文本) {
    定义 line: 文本
    line = "; 模块: " + moduleName
    codegenEmit(cg, line)
}

/**
 * 生成导入声明
 */
函数 emitImportDecl(cg: Codegen, path: 文本) {
    定义 line: 文本
    line = "; 导入: " + path
    codegenEmit(cg, line)
}

/**
 * 生成模块函数前缀
 */
函数 getModuleFuncName(moduleName: 文本, funcName: 文本): 文本 {
    若 moduleName == "" 则 {
        返回 funcName
    }
    返回 moduleName + "_" + funcName
}

/**
 * 生成外部函数声明
 */
函数 emitExternalFuncDecl(cg: Codegen, funcName: 文本, returnType: 文本, paramTypes: 列表) {
    定义 line: 文本
    line = "declare " + returnType + " @" + funcName + "()"
    codegenEmit(cg, line)
}

/**
 * 生成模块入口标注
 */
函数 emitModuleEntry(cg: Codegen, moduleName: 文本): 无返回 {
    定义 line: 文本
    line = "; 模块入口: " + moduleName
    codegenEmit(cg, line)
}

/**
 * 生成模块退出标注
 */
函数 emitModuleExit(cg: Codegen, moduleName: 文本): 无返回 {
    定义 line: 文本
    line = "; 模块退出: " + moduleName
    codegenEmit(cg, line)
}

/* ============ 优化和提示 ============ */

/**
 * 生成优化级别标注
 */
函数 emitOptimizationHint(cg: Codegen, level: 整数): 无返回 {
    定义 line: 文本
    line = "; llvm. opts: "
    若 level == 0 则 {
        line = line + "O0"
    } 否则 {
        若 level == 1 则 {
            line = line + "O1"
        } 否则 {
            若 level == 2 则 {
                line = line + "O2"
            } 否则 {
                若 level == 3 则 {
                    line = line + "O3"
                } 否则 {
                    line = line + "Os"
                }
            }
        }
    }
    codegenEmit(cg, line)
}

/**
 * 生成冷函数标注
 */
函数 emitColdFunctionHint(cg: Codegen): 无返回 {
    codegenEmit(cg, "; Function Attrs: cold")
    codegenEmit(cg, "; llvm.pure.const")
}

/**
 * 生成内联始终标注
 */
函数 emitAlwaysInlineHint(cg: Codegen): 无返回 {
    codegenEmit(cg, "; Function Attrs: alwaysinline")
}

/**
 * 生成无返回标注
 */
函数 emitNoReturnHint(cg: Codegen): 无返回 {
    codegenEmit(cg, "; Function Attrs: noreturn")
}

/**
 * 生成只读标注
 */
函数 emitReadOnlyHint(cg: Codegen): 无返回 {
    codegenEmit(cg, "; Function Attrs: readnone")
}

/**
 * 生成纯函数标注
 */
函数 emitPureFunctionHint(cg: Codegen): 无返回 {
    codegenEmit(cg, "; Function Attrs: readonly")
}

/**
 * 生成热点函数标注
 */
函数 emitHotFunctionHint(cg: Codegen): 无返回 {
    codegenEmit(cg, "; Function Attrs: hot")
}

/**
 * 生成内存访问模式标注
 */
函数 emitAlignmentHint(cg: Codegen, alignment: 整数): 无返回 {
    定义 line: 文本
    line = "; Memory['"
    line = line + 整数转文本(alignment)
    line = line + "']"
    codegenEmit(cg, line)
}

/**
 * 生成向量宽度提示
 */
函数 emitVectorWidthHint(cg: Codegen, width: 整数): 无返回 {
    若 width > 1 则 {
        定义 line: 文本
        line = "; Vector['"
        line = line + 整数转文本(width)
        line = line + "']"
        codegenEmit(cg, line)
    }
}

/**
 * 生成窥孔优化提示
 */
函数 emitPeepholeHint(cg: Codegen): 无返回 {
    codegenEmit(cg, "; Tails duplicated")
}

/* ============ 调试信息生成 ============ */

/**
 * 生成源文件信息
 */
函数 emitSourceFile(cg: Codegen, filename: 文本): 无返回 {
    定义 line: 文本
    line = "source_filename = \"" + filename + "\""
    codegenEmit(cg, line)
}

/**
 * 生成目标数据布局
 */
函数 emitDataLayout(cg: Codegen, layout: 文本): 无返回 {
    定义 line: 文本
    line = "target datalayout = \"" + layout + "\""
    codegenEmit(cg, line)
}

/**
 * 生成目标三元组
 */
函数 emitTargetTriple(cg: Codegen, triple: 文本): 无返回 {
    定义 line: 文本
    line = "target triple = \"" + triple + "\""
    codegenEmit(cg, line)
}

/**
 * 生成调试版本
 */
函数 emitDwarfVersion(cg: Codegen, version: 整数): 无返回 {
    定义 line: 文本
    line = "!llvm.module.flags = !{!0}"
    codegenEmit(cg, line)
    line = "!0 = !{i32 2, !\"Dwarf Version\", i32 " + 整数转文本(version) + "}"
    codegenEmit(cg, line)
}

/* ============ SIMD 和向量化支持 ============ */

/**
 * 生成向量相加 IR
 */
函数 codegenVectorAdd(cg: Codegen, lhs: 文本, rhs: 文本, width: 整数): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = add <" + 整数转文本(width) + " x i64> %" + lhs + ", %" + rhs
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成向量广播 IR
 */
函数 codegenVectorBroadcast(cg: Codegen, value: 文本, width: 整数): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = insertelement <" + 整数转文本(width) + " x i64> undef, i64 %" + value + ", i32 0"
    codegenEmit(cg, line)

    返回 result
}

/* ============ 异常处理支持 ============ */

/**
 * 生成异常抛出 IR
 */
函数 codegenThrow(cg: Codegen, exceptionType: 文本, message: 文本): 无返回 {
    定义 line: 文本
    line = "call void @llvm.trap()"
    codegenEmit(cg, line)
}

/**
 * 生成异常捕获 IR
 */
函数 codegenCatch(cg: Codegen, handlerLabel: 文本): 无返回 {
    定义 line: 文本
    line = "br label %" + handlerLabel
    codegenEmit(cg, line)
}

/**
 * 生成清理块 IR
 */
函数 codegenCleanup(cg: Codegen): 无返回 {
    codegenEmit(cg, "; 清理块")
}

/* ============ 内存模型支持 ============ */

/**
 * 生成内存屏障 IR
 */
函数 codegenMemoryBarrier(cg: Codegen): 无返回 {
    codegenEmit(cg, "call void @llvm.mem fence(i8 1)")
}

/**
 * 生成 volatile 加载 IR
 */
函数 codegenVolatileLoad(cg: Codegen, ptr: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = load volatile i64, i64* %" + ptr
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成 volatile 存储 IR
 */
函数 codegenVolatileStore(cg: Codegen, value: 文本, ptr: 文本): 无返回 {
    定义 line: 文本
    line = "store volatile i64 %" + value + ", i64* %" + ptr
    codegenEmit(cg, line)
}

/* ============ 链接器和符号支持 ============ */

/**
 * 生成外部符号引用
 */
函数 emitExternalSymbol(cg: Codegen, name: 文本, 类型: 文本): 无返回 {
    定义 line: 文本
    line = "@" + name + " = external " + 类型
    codegenEmit(cg, line)
}

/**
 * 生成全局符号定义
 */
函数 emitGlobalSymbol(cg: Codegen, name: 文本, 类型: 文本, value: 文本): 无返回 {
    定义 line: 文本
    line = "@" + name + " = global " + 类型 + " " + value
    codegenEmit(cg, line)
}

/**
 * 生成弱符号定义
 */
函数 emitWeakSymbol(cg: Codegen, name: 文本, 类型: 文本): 无返回 {
    定义 line: 文本
    line = "@" + name + " = weak " + 类型
    codegenEmit(cg, line)
}

/* ============ 属性标注 ============ */

/**
 * 生成函数属性
 */
函数 emitFunctionAttrs(cg: Codegen, attrs: 文本): 无返回 {
    定义 line: 文本
    line = "; Function Attrs: " + attrs
    codegenEmit(cg, line)
}

/**
 * 生成 noinline 属性
 */
函数 emitNoInlineAttr(cg: Codegen): 无返回 {
    codegenEmit(cg, "; Function Attrs: noinline")
}

/**
 * 生成 alwaysinline 属性
 */
函数 emitAlwaysInlineAttr(cg: Codegen): 无返回 {
    codegenEmit(cg, "; Function Attrs: alwaysinline")
}

/**
 * 生成 cold 属性
 */
函数 emitColdAttr(cg: Codegen): 无返回 {
    codegenEmit(cg, "; Function Attrs: cold")
}

/**
 * 生成 returns_twice 属性
 */
函数 emitReturnsTwiceAttr(cg: Codegen): 无返回 {
    codegenEmit(cg, "; Function Attrs: returns_twice")
}

/**
 * 生成 noreturn 属性
 */
函数 emitNoReturnAttr(cg: Codegen): 无返回 {
    codegenEmit(cg, "; Function Attrs: noreturn")
}

/**
 * 生成 nounwind 属性
 */
函数 emitNoUnwindAttr(cg: Codegen): 无返回 {
    codegenEmit(cg, "; Function Attrs: nounwind")
}

/**
 * 生成 readonly 属性
 */
函数 emitReadOnlyAttr(cg: Codegen): 无返回 {
    codegenEmit(cg, "; Function Attrs: readonly")
}

/**
 * 生成 readnone 属性
 */
函数 emitReadNoneAttr(cg: Codegen): 无返回 {
    codegenEmit(cg, "; Function Attrs: readnone")
}

/* ============ 元数据 ============ */

/**
 * 生成调试位置
 */
函数 emitDebugLocation(cg: Codegen, line: 整数, col: 整数): 无返回 {
    定义 line: 文本
    line = "!DILocation(line: " + 整数转文本(line) + ", column: " + 整数转文本(col) + ")"
    codegenEmit(cg, line)
}

/**
 * 生成调试变量
 */
函数 emitDebugVariable(cg: Codegen, name: 文本, type: 文本): 无返回 {
    定义 line: 文本
    line = "!DILocalVariable(name: \"" + name + "\", type: !" + type + ")"
    codegenEmit(cg, line)
}

/**
 * 生成行号标注
 */
函数 emitLineNumber(cg: Codegen, line: 整数): 无返回 {
    定义 line: 文本
    line = "; 行号: " + 整数转文本(line)
    codegenEmit(cg, line)
}

/* ============ 主函数 ============ */

/**
 * 生成完整的函数 IR
 */
函数 emitFunction(cg: Codegen, funcName: 文本, returnType: 文本, nodeCount: 整数) {
    打印("")
    打印("define " + returnType + " @" + funcName + "() {")

    cg.indent = cg.indent + 1
    cg.currentFunc = funcName
    cg.currentReturnType = returnType

    /* 变量分配 */
    打印("  %result = alloca i64")

    /* 函数体 - 根据函数名生成不同 IR */

    若 funcName == "主" 则 {
        /* 主函数: 返回 0 */
        打印("  %tmp0 = add i64 0, 0")
        打印("  ret i64 %tmp0")
    } 否则 {
        /* 默认返回 0 */
        打印("  %tmp0 = add i64 0, 0")
        打印("  ret i64 %tmp0")
    }

    cg.indent = cg.indent - 1
    打印("}")
}

/**
 * 生成 main 函数包装
 */
函数 emitMainWrapper(cg: Codegen) {
    打印("")
    打印("define i32 @main() {")
    cg.indent = 1

    定义 result: 文本
    result = codegenNewTemp(cg)
    打印("  %" + result + " = call i64 @主()")
    定义 truncVal: 文本
    truncVal = codegenNewTemp(cg)
    打印("  %" + truncVal + " = trunc i64 %" + result + " to i32")

    打印("  ret i32 %" + truncVal)
    打印("}")
}

/* ============ AST 遍历和语句生成 ============ */

/**
 * 生成表达式 IR
 */
函数 codegen生成表达式(cg: Codegen, exprKind: 整数, value: 文本, left: 文本, right: 文本): 文本 {
    定义 result: 文本
    result = ""

    若 exprKind == 10 则 {
        /* 二元表达式 */
        定义 llOp: 文本
        llOp = "add"
        若 value == "-" 则 { llOp = "sub" }
        若 value == "*" 则 { llOp = "mul" }
        若 value == "/" 则 { llOp = "sdiv" }
        若 value == "%" 则 { llOp = "srem" }

        result = codegenNewTemp(cg)
        定义 line: 文本
        line = "%" + result + " = " + llOp + " i64 %" + left + ", %" + right
        codegenEmit(cg, line)
    } 否则 {
        若 exprKind == 14 则 {
            /* 字面量 */
            result = codegenNewTemp(cg)
            定义 line: 文本
            line = "%" + result + " = add i64 0, " + value
            codegenEmit(cg, line)
        } 否则 {
            若 exprKind == 13 则 {
                /* 标识符 - 加载变量 */
                result = codegenNewTemp(cg)
                定义 line: 文本
                line = "%" + result + " = load i64, i64* %" + value
                codegenEmit(cg, line)
            }
        }
    }

    返回 result
}

/**
 * 生成变量分配
 */
函数 codegen生成变量(cg: Codegen, varName: 文本, typeName: 文本): 文本 {
    定义 ptr: 文本
    ptr = varName + "_slot"

    定义 line: 文本
    line = "%" + ptr + " = alloca " + getLLVMType(typeName)
    codegenEmit(cg, line)

    返回 ptr
}

/**
 * 生成赋值语句
 */
函数 codegen生成赋值(cg: Codegen, varName: 文本, value: 文本, varType: 文本): 无返回 {
    定义 ptr: 文本
    ptr = varName + "_slot"

    定义 line: 文本
    line = "store " + getLLVMType(varType) + " %" + value + ", " + getLLVMType(varType) + "* %" + ptr
    codegenEmit(cg, line)
}

/**
 * 生成 if 语句
 */
函数 codegen生成If(cg: Codegen, condVar: 文本, thenLabel: 文本, elseLabel: 文本, endLabel: 文本): 无返回 {
    定义 line: 文本
    line = "br i1 %" + condVar + ", label %" + thenLabel + ", label %" + elseLabel
    codegenEmit(cg, line)

    cg.indent = cg.indent - 1
    codegenEmit(cg, thenLabel + ":")
    cg.indent = cg.indent + 1
}

/**
 * 生成 while 循环
 */
函数 codegen生成While(cg: Codegen, condVar: 文本, bodyLabel: 文本, endLabel: 文本): 无返回 {
    定义 line: 文本
    line = "br i1 %" + condVar + ", label %" + bodyLabel + ", label %" + endLabel
    codegenEmit(cg, line)

    cg.indent = cg.indent - 1
    codegenEmit(cg, bodyLabel + ":")
    cg.indent = cg.indent + 1
}

/**
 * 生成 for 循环
 */
函数 codegen生成For(cg: Codegen, varName: 文本, startVal: 整数, endVal: 整数): 无返回 {
    定义 iterVar: 文本
    iterVar = codegen生成变量(cg, varName, "整数")

    定义 startTmp: 文本
    startTmp = codegenNewTemp(cg)
    定义 line: 文本
    line = "%" + startTmp + " = add i64 0, " + 整数转文本(startVal)
    codegenEmit(cg, line)
    line = "store i64 %" + startTmp + ", i64* %" + iterVar
    codegenEmit(cg, line)
}

/**
 * 生成返回语句
 */
函数 codegen生成返回(cg: Codegen, value: 文本, returnType: 文本): 无返回 {
    定义 line: 文本
    若 returnType == "void" 则 {
        line = "ret void"
    } 否则 {
        line = "ret i64 %" + value
    }
    codegenEmit(cg, line)
}

/**
 * 生成函数调用（带参数）
 */
函数 codegen生成调用(cg: Codegen, funcName: 文本, argCount: 整数, returnType: 文本): 文本 {
    定义 result: 文本
    result = ""

    若 returnType != "void" 则 {
        定义 tmp: 文本
        tmp = codegenNewTemp(cg)
        定义 line: 文本
        line = "%" + tmp + " = call " + returnType + " @" + funcName + "()"
        codegenEmit(cg, line)
        result = tmp
    } 否则 {
        codegenEmit(cg, "call " + returnType + " @" + funcName + "()")
    }

    返回 result
}

/**
 * 生成比较表达式并跳转
 */
函数 codegen生成条件跳转(cg: Codegen, op: 文本, left: 文本, right: 文本, trueLabel: 文本, falseLabel: 文本): 无返回 {
    定义 cmpResult: 文本
    cmpResult = codegenNewTemp(cg)

    定义 llOp: 文本
    llOp = "eq"
    若 op == ">" 则 { llOp = "sgt" }
    若 op == "<" 则 { llOp = "slt" }
    若 op == ">=" 则 { llOp = "sge" }
    若 op == "<=" 则 { llOp = "sle" }
    若 op == "!=" 则 { llOp = "ne" }

    定义 line: 文本
    line = "%" + cmpResult + " = icmp " + llOp + " i64 %" + left + ", %" + right
    codegenEmit(cg, line)

    line = "br i1 %" + cmpResult + ", label %" + trueLabel + ", label %" + falseLabel
    codegenEmit(cg, line)
}

/**
 * 生成 break 语句
 */
函数 codegen生成Break(cg: Codegen, endLabel: 文本): 无返回 {
    定义 line: 文本
    line = "br label %" + endLabel
    codegenEmit(cg, line)
}

/**
 * 生成 continue 语句
 */
函数 codegen生成Continue(cg: Codegen, condLabel: 文本): 无返回 {
    定义 line: 文本
    line = "br label %" + condLabel
    codegenEmit(cg, line)
}

/**
 * 生成打印调用
 */
函数 codegen生成打印(cg: Codegen, value: 文本, valueType: 文本): 无返回 {
    定义 line: 文本
    若 valueType == "i64" 则 {
        line = "call void @print_int(i64 %" + value + ")"
    } 否则 {
        若 valueType == "i8*" 则 {
            line = "call void @print(i8* %" + value + ")"
        }
    }
    codegenEmit(cg, line)
}

/**
 * 生成输入调用
 */
函数 codegen生成输入(cg: Codegen, inputType: 文本): 文本 {
    定义 result: 文本
    result = ""

    定义 tmp: 文本
    tmp = codegenNewTemp(cg)

    定义 line: 文本
    若 inputType == "i64" 则 {
        line = "%" + tmp + " = call i64 @str_to_int(i8* @rt_readline())"
        codegenEmit(cg, line)
        result = tmp
    } 否则 {
        若 inputType == "i8*" 则 {
            line = "%" + tmp + " = call i8* @rt_readline()"
            codegenEmit(cg, line)
            result = tmp
        }
    }

    返回 result
}

/**
 * 生成列表创建
 */
函数 codegen生成列表创建(cg: Codegen): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = call i64 @rt_list_new()"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成列表追加
 */
函数 codegen生成列表追加(cg: Codegen, list: 文本, value: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = call i64 @rt_list_append(i64 %" + list + ", i64 %" + value + ")"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成列表获取
 */
函数 codegen生成列表获取(cg: Codegen, list: 文本, index: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = call i64 @rt_list_get(i64 %" + list + ", i64 %" + index + ")"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成字符串长度
 */
函数 codegen生成字符串长度(cg: Codegen, strPtr: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = call i64 @rt_string_len(i8* %" + strPtr + ")"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成字符串拼接
 */
函数 codegen生成字符串拼接(cg: Codegen, str1: 文本, str2: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = call i8* @rt_string_concat(i8* %" + str1 + ", i8* %" + str2 + ")"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 执行代码生成
 */
函数 codegenRun(astNodeCount: 整数): 整数 {
    打印("=== 代码生成 ===")

    定义 cg: Codegen
    cg = codegenInit()

    /* 生成模块头 */
    emitModuleHeader(cg, "xuanyu_source")

    /* 生成目标数据 */
    emitTargetData(cg)

    /* 生成内置函数声明 */
    emitBuiltinDecls(cg)

    /* 生成用户函数 */
    打印("; ==================== 用户函数 ====================")
    emitFunction(cg, "主", "i64", 10)

    /* 生成 main 包装 */
    emitMainWrapper(cg)

    打印("")
    打印("代码生成完成!")

    返回 1
}

/* ============ 高级 IR 生成函数 ============ */

/**
 * 生成结构体字面量 IR
 */
函数 codegenStructLiteral(cg: Codegen, structName: 文本, fieldCount: 整数): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = alloca %" + structName
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成空联合 IR
 */
函数 codegenZeroInit(cg: Codegen, typeName: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = bitcast " + typeName + " null to " + typeName
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成条件选择 IR (使用 select)
 */
函数 codegenSelectOp(cg: Codegen, cond: 文本, trueVal: 文本, falseVal: 文本, resultType: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = select i1 %" + cond + ", " + resultType + " %" + trueVal + ", " + resultType + " %" + falseVal
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成 freeze IR (固定值)
 */
函数 codegenFreeze(cg: Codegen, value: 文本, valueType: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = freeze " + valueType + " %" + value
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成 extractvalue IR (从聚合值提取)
 */
函数 codegenExtractValue(cg: Codegen, aggregate: 文本, index: 整数, aggregateType: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = extractvalue " + aggregateType + " %" + aggregate + ", " + 整数转文本(index)
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成 insertvalue IR (向聚合值插入)
 */
函数 codegenInsertValue(cg: Codegen, aggregate: 文本, value: 文本, index: 整数, aggregateType: 文本, valueType: 文本): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = insertvalue " + aggregateType + " %" + aggregate + ", " + valueType + " %" + value + ", " + 整数转文本(index)
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成 extractelement IR (从向量提取元素)
 */
函数 codegenExtractElement(cg: Codegen, vector: 文本, index: 文本, vectorWidth: 整数): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = extractelement <" + 整数转文本(vectorWidth) + " x i64> %" + vector + ", i64 %" + index
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成 insertelement IR (向向量插入元素)
 */
函数 codegenInsertElement(cg: Codegen, vector: 文本, value: 文本, index: 文本, vectorWidth: 整数): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = insertelement <" + 整数转文本(vectorWidth) + " x i64> %" + vector + ", i64 %" + value + ", i64 %" + index
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成 shufflevector IR (向量混洗)
 */
函数 codegenShuffleVector(cg: Codegen, v1: 文本, v2: 文本, mask: 文本, width: 整数): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = shufflevector <" + 整数转文本(width) + " x i64> %" + v1 + ", <" + 整数转文本(width) + " x i64> %" + v2 + ", <" + 整数转文本(width) + " x i32> %" + mask
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成 icmp 并转换为整数 IR
 */
函数 codegenIcmpToInt(cg: Codegen, op: 文本, left: 文本, right: 文本): 文本 {
    定义 cmpResult: 文本
    cmpResult = codegenCompare(cg, op, left, right)

    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = zext i1 %" + cmpResult + " to i64"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成快速调用 IR (无返回值的调用)
 */
函数 codegenFastCall(cg: Codegen, funcName: 文本): 无返回 {
    codegenEmit(cg, "call void @" + funcName + "()")
}

/**
 * 生成 tail 调用提示 IR
 */
函数 codegenTailCallHint(cg: Codegen): 无返回 {
    codegenEmit(cg, "; tail call hint")
}

/**
 * 生成 musttail 调用提示 IR
 */
函数 codegenMustTailCall(cg: Codegen): 无返回 {
    codegenEmit(cg, "; musttail call")
}

/**
 * 生成捕获异常 IR
 */
函数 codegenCatchSwitch(cg: Codegen, parentPad: 文本, defaultLabel: 文本, numHandlers: 整数): 文本 {
    定义 result: 文本
    result = codegenNewTemp(cg)

    定义 line: 文本
    line = "%" + result + " = catchswitch within %" + parentPad + " [label %" + defaultLabel + "] to label %" + defaultLabel
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成清理返回 IR
 */
函数 codegenCleanupRet(cg: Codegen, catchPad: 文本, targetLabel: 文本): 无返回 {
    定义 line: 文本
    line = "cleanupret from %" + catchPad + " unwind label %" + targetLabel
    codegenEmit(cg, line)
}

/**
 * 生成分支权重元数据
 */
函数 emitBranchWeights(cg: Codegen, trueWeight: 整数, falseWeight: 整数): 无返回 {
    定义 line: 文本
    line = "!prof !{i64 " + 整数转文本(trueWeight) + ", i64 " + 整数转文本(falseWeight) + "}"
    codegenEmit(cg, line)
}

/**
 * 生成调用图信息元数据
 */
函数 emitCallGraph(cg: Codegen, caller: 文本, callee: 文本): 无返回 {
    定义 line: 文本
    line = "!callgraph !{" + caller + ", !" + callee + "}"
    codegenEmit(cg, line)
}

/**
 * 生成函数入口计数元数据
 */
函数 emitFunctionEntryCount(cg: Codegen, count: 整数): 无返回 {
    定义 line: 文本
    line = "!llvm.entryPoints = !{i64 " + 整数转文本(count) + "}"
    codegenEmit(cg, line)
}

/* ============ 优化 Pass 函数 ============ */

/**
 * 常量折叠评估
 */
函数 codegen常量折叠评估(exprKind: 整数, leftVal: 整数, rightVal: 整数, op: 文本): 整数 {
    若 exprKind != 10 则 { 返回 -1 }

    若 op == "+" 则 { 返回 leftVal + rightVal }
    若 op == "-" 则 { 返回 leftVal - rightVal }
    若 op == "*" 则 { 返回 leftVal * rightVal }
    若 op == "/" 则 {
        若 rightVal != 0 则 { 返回 leftVal / rightVal }
    }
    若 op == "%" 则 {
        若 rightVal != 0 则 { 返回 leftVal % rightVal }
    }

    返回 -1
}

/**
 * 拷贝传播分析
 */
函数 codegen拷贝传播(block: 列表): 列表 {
    定义 result: 列表
    result = 列表()

    打印("优化: 拷贝传播")

    返回 result
}

/**
 * 代数简化
 */
函数 codegen代数简化(exprKind: 整数, op: 文本, operand: 整数): 整数 {
    若 op == "+" 且 operand == 0 则 { 返回 0 }
    若 op == "-" 且 operand == 0 则 { 返回 0 }
    若 op == "*" 且 operand == 1 则 { 返回 0 }
    若 op == "/" 且 operand == 1 则 { 返回 0 }
    若 op == "*" 且 operand == 0 则 { 返回 0 }

    返回 -1
}

/**
 * 死代码消除
 */
函数 codegen死代码消除(func: 文本): 无返回 {
    打印("优化: 死代码消除 - ")
    打印(func)
}

/**
 * 循环不变代码移动
 */
函数 codegen循环不变代码移动(loopLabel: 文本): 无返回 {
    打印("优化: 循环不变代码移动 - ")
    打印(loopLabel)
}

/**
 * 循环展开
 */
函数 codegen循环展开(loopLabel: 文本, factor: 整数): 无返回 {
    打印("优化: 循环展开 - ")
    打印(loopLabel)
    打印(" (factor=")
    打印(factor)
    打印(")")
}

/**
 * 条件简化
 */
函数 codegen条件简化(cond: 文本): 整数 {
    若 cond == "真" 则 { 返回 1 }
    若 cond == "假" 则 { 返回 0 }
    返回 -1
}

/**
 * 强度削减
 */
函数 codegen强度削减(stmt: 文本): 无返回 {
    打印("优化: 强度削减")
}

/**
 * 全局值编号
 */
函数 codegen全局值编号(): 无返回 {
    打印("优化: 全局值编号")
}

/**
 * 内联决策
 */
函数 codegen内联决策(funcName: 文本, size: 整数): 整数 {
    若 size < 50 则 { 返回 1 }
    若 funcName == "打印" 则 { 返回 0 }
    若 funcName == "输入整数" 则 { 返回 0 }
    返回 0
}

/**
 * 执行内联
 */
函数 codegen执行内联(cg: Codegen, funcName: 文本, callSite: 文本): 无返回 {
    打印("内联函数: ")
    打印(funcName)
}

