/**
 * 遍历模块定义
 */
函数 codegen遍历模块定义(cg: Codegen, moduleNode: AST节点): 无返回 {
    定义 可变 moduleName: 文本
    moduleName = moduleNode.name

    打印("遍历模块: ")
    打印(moduleName)

    定义 可变 line: 文本
    line = "; 模块: " + moduleName
    codegenEmit(cg, line)

    /* 遍历模块内容 */
    定义 可变 i: 整数
    i = 0
    当 i < 列表长度(moduleNode.children) && i < 50 则 {
        定义 可变 child: AST节点
        child = moduleNode.children[i]

        若 child.kind == 1 则 {
            codegen遍历函数定义(cg, child)
        }
        i = i + 1
    }
}

/**
 * 遍历函数定义
 */
函数 codegen遍历函数定义(cg: Codegen, funcNode: AST节点): 无返回 {
    定义 可变 funcName: 文本
    funcName = funcNode.name

    定义 可变 returnType: 文本
    returnType = "i64"

    打印("生成函数: ")
    打印(funcName)

    /* 保存当前状态 */
    cg.currentFunc = funcName
    cg.currentFunctionIndex = cg.functionIndexCounter
    cg.functionIndexCounter = cg.functionIndexCounter + 1
    
    /* 清空变量映射，进入新作用域 */
    codegen清空变量(cg)

    /* 生成函数头 */
    codegenEmit(cg, "")
    
    /* 处理参数列表 */
    定义 可变 bodyIdx: 整数
    bodyIdx = 0
    定义 可变 paramStr: 文本
    paramStr = ""
    
    若 列表长度(funcNode.children) > 1 则 {
        /* 可能有参数列表，先处理参数 */
        定义 可变 paramNode: AST节点
        paramNode = 列表获取(funcNode.children, 0)
        若 paramNode.kind == 2 则 {
            /* 参数列表 */
            bodyIdx = 1
            /* 生成参数声明 */
            定义 可变 i: 整数
            i = 0
            当 i < 列表长度(paramNode.children) 则 {
                定义 可变 param: AST节点
                param = paramNode.children[i]
                若 i > 0 则 {
                    paramStr = paramStr + ", "
                }
                paramStr = paramStr + "i64 %" + param.name
                i = i + 1
            }
        }
    }
    
    /* 生成函数定义 */
    codegenEmit(cg, "define " + returnType + " @" + funcName + "(" + paramStr + ") {")
    cg.indent = cg.indent + 1

    /* 生成函数体 */
    
    /* 处理函数体 */
    若 bodyIdx < 列表长度(funcNode.children) 则 {
        定义 可变 body: AST节点
        body = 列表获取(funcNode.children, bodyIdx)
        
        若 body.kind == 18 则 {
            /* 块语句 */
            codegen遍历块语句(cg, body)
            /* 确保块语句结束后有返回语句 */
            codegenEmit(cg, "  %tmp0 = add i64 0, 0")
            codegenEmit(cg, "  ret i64 %tmp0")
        } 否则 {
            /* 单表达式函数体 */
            定义 可变 result: 文本
            result = codegen遍历表达式(cg, body)
            codegenEmit(cg, "  ret i64 %" + result)
        }
    } 否则 {
        /* 空函数体，返回 0 */
        codegenEmit(cg, "  %tmp0 = add i64 0, 0")
        codegenEmit(cg, "  ret i64 %tmp0")
    }

    cg.indent = cg.indent - 1
    codegenEmit(cg, "}")
    cg.funcCount = cg.funcCount + 1
}

/**
 * 检查块语句是否有返回语句
 * @param cg 代码生成器
 * @param block 块语句节点
 * @return 如果有返回语句返回1，否则返回0
 */
函数 codegen块语句有返回语句(cg: Codegen, block: AST节点): 整数 {
    /* 检查是否是块语句，如果不是，直接检查 */
    若 block.kind != 18 则 {
        /* 不是块语句，直接检查是否是返回语句 */
        若 block.kind == 8 则 {
            返回 1
        } 否则 {
            返回 0
        }
    }

    定义 可变 i: 整数
    i = 0

    当 i < 列表长度(block.children) && i < 50 则 {
        定义 可变 stmt: AST节点
        stmt = block.children[i]

        /* 检查是否是返回语句 */
        若 stmt.kind == 8 则 {
            返回 1
        }

        i = i + 1
    }

    返回 0
}

/**
 * 遍历块语句
 */
函数 codegen遍历块语句(cg: Codegen, block: AST节点): 无返回 {
    /* 检查是否是块语句，如果不是，直接遍历 */
    若 block.kind != 18 则 {
        /* 不是块语句，直接遍历 */
        codegen遍历语句(cg, block)
        返回
    }

    定义 可变 i: 整数
    i = 0

    当 i < 列表长度(block.children) && i < 50 则 {
        定义 可变 stmt: AST节点
        stmt = block.children[i]

        codegen遍历语句(cg, stmt)

        /* 如果是返回语句，停止遍历，因为返回语句之后的代码是不可达的 */
        若 stmt.kind == 8 则 {
            跳出循环
        }

        i = i + 1
    }
}

/**
 * 遍历语句
 */
函数 codegen遍历语句(cg: Codegen, stmt: AST节点): 无返回 {
    若 stmt.kind == 3 则 {
        /* 变量定义 */
        codegen遍历变量定义(cg, stmt)
    } 否则 {
        若 stmt.kind == 4 则 {
            /* 赋值语句 */
            codegen遍历赋值语句(cg, stmt)
        } 否则 {
            若 stmt.kind == 5 则 {
                /* if 语句 */
                codegen遍历If语句(cg, stmt)
            } 否则 {
                若 stmt.kind == 6 则 {
                    /* while 语句 */
                    codegen遍历While语句(cg, stmt)
                } 否则 {
                    若 stmt.kind == 20 则 {
                        /* for 语句 */
                        codegen遍历For语句(cg, stmt)
                    } 否则 {
                        若 stmt.kind == 8 则 {
                            /* return 语句 */
                            codegen遍历返回语句(cg, stmt)
                        } 否则 {
                            若 stmt.kind == 16 则 {
                                /* break 语句 */
                                codegen遍历Break语句(cg, stmt)
                            } 否则 {
                                若 stmt.kind == 17 则 {
                                    /* continue 语句 */
                                    codegen遍历Continue语句(cg, stmt)
                                } 否则 {
                                    若 stmt.kind == 9 则 {
                                        /* 表达式语句 */
                                        定义 可变 result: 文本
                                        result = codegen遍历表达式(cg, stmt)
                                    } 否则 {
                                        若 stmt.kind == 18 则 {
                                            /* 块语句 */
                                            codegen遍历块语句(cg, stmt)
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

/**
 * 遍历变量定义
 */
函数 codegen遍历变量定义(cg: Codegen, varNode: AST节点): 无返回 {
    定义 可变 varName: 文本
    varName = varNode.name

    /* 分配空间 */
    定义 可变 tmpPtr: 文本
    tmpPtr = varName + "_slot"
    codegenEmit(cg, "  %" + tmpPtr + " = alloca i64")

    /* 添加到变量映射 */
    codegen添加变量(cg, varName, tmpPtr, "整数")

    /* 初始化 */
    若 列表长度(varNode.children) > 0 则 {
        定义 可变 initNode: AST节点
        initNode = 列表获取(varNode.children, 0)
        定义 可变 initVal: 文本
        initVal = codegen遍历表达式(cg, initNode)
        codegenEmit(cg, "  store i64 %" + initVal + ", i64* %" + tmpPtr)
    }
}

/**
 * 遍历赋值语句
 */
函数 codegen遍历赋值语句(cg: Codegen, assignNode: AST节点): 无返回 {
    定义 可变 varName: 文本
    varName = assignNode.name

    /* 查找变量 */
    定义 可变 tmpPtr: 文本
    tmpPtr = codegen查找变量(cg, varName)
    若 tmpPtr == "" 则 {
        /* 变量未找到，使用默认命名 */
        tmpPtr = varName + "_slot"
    }

    /* 生成右侧表达式 */
    若 列表长度(assignNode.children) > 0 则 {
        定义 可变 rightNode: AST节点
        rightNode = 列表获取(assignNode.children, 0)
        定义 可变 rightVal: 文本
        rightVal = codegen遍历表达式(cg, rightNode)
        codegenEmit(cg, "  store i64 %" + rightVal + ", i64* %" + tmpPtr)
    }
}

/**
 * 遍历 break 语句
 */
函数 codegen遍历Break语句(cg: Codegen, breakNode: AST节点): 无返回 {
    定义 可变 ctx: 循环上下文
    ctx = codegen获取当前循环上下文(cg)
    若 ctx.结束标签 != "" 则 {
        codegenEmit(cg, "  br label %" + ctx.结束标签)
    }
}

/**
 * 遍历 continue 语句
 */
函数 codegen遍历Continue语句(cg: Codegen, continueNode: AST节点): 无返回 {
    定义 可变 ctx: 循环上下文
    ctx = codegen获取当前循环上下文(cg)
    若 ctx.continue标签 != "" 则 {
        codegenEmit(cg, "  br label %" + ctx.continue标签)
    }
}

/**
 * 遍历 if 语句
 */
函数 codegen遍历If语句(cg: Codegen, ifNode: AST节点): 无返回 {
    定义 可变 thenLabel: 文本
    thenLabel = codegenNewLabel(cg)
    定义 可变 elseLabel: 文本
    elseLabel = codegenNewLabel(cg)
    定义 可变 endLabel: 文本
    endLabel = codegenNewLabel(cg)

    /* 条件表达式 */
    定义 可变 cond: AST节点
    cond = 列表获取(ifNode.children, 0)
    定义 可变 condVar: 文本
    condVar = codegen遍历表达式(cg, cond)

    /* 条件跳转 */
    codegenEmit(cg, "  br i1 %" + condVar + ", label %" + thenLabel + ", label %" + elseLabel)

    /* then 块 */
    codegenEmit(cg, thenLabel + ":")
    定义 可变 thenBlock: AST节点
    thenBlock = 列表获取(ifNode.children, 1)
    定义 可变 thenHasReturn: 整数
    thenHasReturn = codegen块语句有返回语句(cg, thenBlock)
    codegen遍历块语句(cg, thenBlock)
    若 thenHasReturn == 0 则 {
        codegenEmit(cg, "  br label %" + endLabel)
    }

    /* else 块 */
    codegenEmit(cg, elseLabel + ":")
    定义 可变 childrenLen: 整数
    childrenLen = 列表长度(ifNode.children)
    若 childrenLen >= 3 则 {
        定义 可变 elseBlock: AST节点
        elseBlock = 列表获取(ifNode.children, 2)
        定义 可变 elseHasReturn: 整数
        elseHasReturn = codegen块语句有返回语句(cg, elseBlock)
        codegen遍历块语句(cg, elseBlock)
        若 elseHasReturn == 0 则 {
            codegenEmit(cg, "  br label %" + endLabel)
        }
    } 否则 {
        codegenEmit(cg, "  br label %" + endLabel)
    }

    /* 结束 */
    codegenEmit(cg, endLabel + ":")
    /* 生成一个空操作，避免LLVM IR语法错误 */
    codegenEmit(cg, "  %tmp_end = add i64 0, 0")
}

/**
 * 遍历 while 语句
 */
函数 codegen遍历While语句(cg: Codegen, whileNode: AST节点): 无返回 {
    定义 可变 condLabel: 文本
    condLabel = codegenNewLabelWithPrefix(cg, "while_cond_")
    定义 可变 bodyLabel: 文本
    bodyLabel = codegenNewLabelWithPrefix(cg, "while_body_")
    定义 可变 endLabel: 文本
    endLabel = codegenNewLabelWithPrefix(cg, "while_end_")

    /* 创建循环上下文 */
    定义 可变 ctx: 循环上下文
    ctx.循环开始标签 = condLabel
    ctx.循环体标签 = bodyLabel
    ctx.continue标签 = condLabel
    ctx.结束标签 = endLabel
    codegen推入循环上下文(cg, ctx)

    /* 跳转到条件 */
    codegenEmit(cg, "  br label %" + condLabel)

    /* 条件 */
    cg.indent = cg.indent - 1
    codegenEmit(cg, condLabel + ":")
    cg.indent = cg.indent + 1
    
    定义 可变 cond: AST节点
    cond = 列表获取(whileNode.children, 0)
    定义 可变 condVar: 文本
    condVar = codegen遍历表达式(cg, cond)

    /* 条件跳转 */
    codegenEmit(cg, "  br i1 %" + condVar + ", label %" + bodyLabel + ", label %" + endLabel)

    /* 循环体 */
    cg.indent = cg.indent - 1
    codegenEmit(cg, bodyLabel + ":")
    cg.indent = cg.indent + 1
    
    定义 可变 body: AST节点
    body = 列表获取(whileNode.children, 1)
    codegen遍历块语句(cg, body)
    codegenEmit(cg, "  br label %" + condLabel)

    /* 结束 */
    cg.indent = cg.indent - 1
    codegenEmit(cg, endLabel + ":")
    cg.indent = cg.indent + 1
    /* 生成一个空操作，避免LLVM IR语法错误 */
    codegenEmit(cg, "  %tmp_end = add i64 0, 0")

    /* 弹出循环上下文 */
    codegen弹出循环上下文(cg)
}

/**
 * 遍历 for 语句
 */
函数 codegen遍历For语句(cg: Codegen, forNode: AST节点): 无返回 {
    定义 可变 initLabel: 文本
    initLabel = codegenNewLabel(cg)
    定义 可变 condLabel: 文本
    condLabel = codegenNewLabel(cg)
    定义 可变 bodyLabel: 文本
    bodyLabel = codegenNewLabel(cg)
    定义 可变 incLabel: 文本
    incLabel = codegenNewLabel(cg)
    定义 可变 endLabel: 文本
    endLabel = codegenNewLabel(cg)

    /* 初始化 */
    codegenEmit(cg, "  br label %" + initLabel)
    codegenEmit(cg, initLabel + ":")

    定义 可变 init: AST节点
    init = 列表获取(forNode.children, 0)
    codegen遍历表达式(cg, init)

    /* 跳转到条件 */
    codegenEmit(cg, "  br label %" + condLabel)

    /* 条件 */
    codegenEmit(cg, condLabel + ":")
    定义 可变 cond: AST节点
    cond = 列表获取(forNode.children, 1)
    定义 可变 condVar: 文本
    condVar = codegen遍历表达式(cg, cond)

    /* 条件跳转 */
    codegenEmit(cg, "  br i1 %" + condVar + ", label %" + bodyLabel + ", label %" + endLabel)

    /* 循环体 */
    codegenEmit(cg, bodyLabel + ":")
    定义 可变 body: AST节点
    body = 列表获取(forNode.children, 2)
    codegen遍历块语句(cg, body)
    codegenEmit(cg, "  br label %" + incLabel)

    /* 递增 */
    codegenEmit(cg, incLabel + ":")
    定义 可变 inc: AST节点
    inc = 列表获取(forNode.children, 1)
    codegen遍历表达式(cg, inc)
    codegenEmit(cg, "  br label %" + condLabel)

    /* 结束 */
    codegenEmit(cg, endLabel + ":")
}

/**
 * 遍历返回语句
 */
函数 codegen遍历返回语句(cg: Codegen, retNode: AST节点): 无返回 {
    若 列表长度(retNode.children) > 0 则 {
        定义 可变 result: 文本
        result = codegen遍历表达式(cg, retNode.children[0])
        codegenEmit(cg, "  ret i64 %" + result)
    } 否则 {
        codegenEmit(cg, "  ret void")
    }
}

/**
 * 遍历表达式
 */
函数 codegen遍历表达式(cg: Codegen, expr: AST节点): 文本 {
    定义 可变 result: 文本
    result = ""

    若 expr.kind == 13 则 {
        /* 标识符表达式 */
        result = codegen遍历标识符(cg, expr.name)
    } 否则 {
        若 expr.kind == 14 则 {
            /* 字面量表达式 */
            result = codegen遍历字面量(cg, expr.value)
        } 否则 {
            若 expr.kind == 10 则 {
                /* 二元表达式 - children[0] 是左操作数, children[1] 是右操作数 */
                若 列表长度(expr.children) >= 2 则 {
                    定义 可变 leftChild: AST节点
                    定义 可变 rightChild: AST节点
                    leftChild = 列表获取(expr.children, 0)
                    rightChild = 列表获取(expr.children, 1)
                    result = codegen遍历二元表达式(cg, expr.value, leftChild, rightChild)
                } 否则 {
                    /* 二元表达式子节点不足，返回默认值 */
                    result = codegenNewTemp(cg)
                    codegenEmit(cg, "  %" + result + " = add i64 0, 0")
                }
            } 否则 {
                若 expr.kind == 11 则 {
                    /* 一元表达式 - children[0] 是操作数 */
                    若 列表长度(expr.children) >= 1 则 {
                        定义 可变 operand: AST节点
                        operand = 列表获取(expr.children, 0)
                        result = codegen遍历一元表达式(cg, expr.value, operand)
                    } 否则 {
                        /* 一元表达式子节点不足，返回默认值 */
                        result = codegenNewTemp(cg)
                        codegenEmit(cg, "  %" + result + " = add i64 0, 0")
                    }
                } 否则 {
                    若 expr.kind == 12 则 {
                        /* 调用表达式 */
                        result = codegen遍历函数调用(cg, expr.name, expr.children)
                    } 否则 {
                        若 expr.kind == 19 则 {
                            /* 赋值表达式 - 处理为赋值语句 */
                            若 列表长度(expr.children) >= 2 则 {
                                定义 可变 leftChild: AST节点
                                定义 可变 rightChild: AST节点
                                leftChild = 列表获取(expr.children, 0)
                                rightChild = 列表获取(expr.children, 1)
                                /* 简单处理：先遍历右边，再赋值 */
                                result = codegen遍历表达式(cg, rightChild)
                            } 否则 {
                                result = codegenNewTemp(cg)
                                codegenEmit(cg, "  %" + result + " = add i64 0, 0")
                            }
                        } 否则 {
                            /* 默认: 返回临时变量 */
                            result = codegenNewTemp(cg)
                            codegenEmit(cg, "  %" + result + " = add i64 0, 0")
                        }
                    }
                }
            }
        }
    }

    返回 result
}

/**
 * 遍历标识符
 */
函数 codegen遍历标识符(cg: Codegen, name: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    codegenEmit(cg, "  %" + result + " = load i64, i64* %" + name + "_slot")

    返回 result
}

/**
 * 遍历字面量
 */
函数 codegen遍历字面量(cg: Codegen, value: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    codegenEmit(cg, "  %" + result + " = add i64 0, " + value)

    返回 result
}

/**
 * 遍历二元表达式
 */
函数 codegen遍历二元表达式(cg: Codegen, op: 文本, left: AST节点, right: AST节点): 文本 {
    定义 可变 leftVal: 文本
    leftVal = codegen遍历表达式(cg, left)

    定义 可变 rightVal: 文本
    rightVal = codegen遍历表达式(cg, right)

    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 llOp: 文本
    llOp = "add"

    若 op == "+" 则 { llOp = "add" }
    若 op == "-" 则 { llOp = "sub" }
    若 op == "*" 则 { llOp = "mul" }
    若 op == "/" 则 { llOp = "sdiv" }
    若 op == "%" 则 { llOp = "srem" }

    codegenEmit(cg, "  %" + result + " = " + llOp + " i64 %" + leftVal + ", %" + rightVal)

    返回 result
}

/**
 * 遍历一元表达式
 */
函数 codegen遍历一元表达式(cg: Codegen, op: 文本, operand: AST节点): 文本 {
    定义 可变 operandVal: 文本
    operandVal = codegen遍历表达式(cg, operand)

    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    若 op == "-" 则 {
        codegenEmit(cg, "  %" + result + " = sub i64 0, %" + operandVal)
    } 否则 {
        若 op == "!" 则 {
            codegenEmit(cg, "  %" + result + " = xor i1 %" + operandVal + ", true")
        }
    }

    返回 result
}

/**
 * 遍历函数调用
 */
函数 codegen遍历函数调用(cg: Codegen, funcName: 文本, args: AST节点): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    /* 内置函数返回类型映射表 */
    定义 可变 returnType: 文本
    returnType = "i64"

    若 funcName == "_u6574_u6570_u8f6c_u6587_u672c_u90e8" 则 {
        returnType = "double"
    } 否则 {
        若 funcName == "print_float" 则 {
            returnType = "double"
        }
    }

    /* 处理函数参数 */
    定义 可变 argStr: 文本
    argStr = ""

    若 args != 0 && 列表长度(args.children) > 0 则 {
        定义 可变 i: 整数
        i = 0
        当 i < 列表长度(args.children) 则 {
            定义 可变 argNode: AST节点
            argNode = 列表获取(args.children, i)

            /* 遍历参数表达式获取 SSA 值 */
            定义 可变 argValue: 文本
            argValue = codegen遍历表达式(cg, argNode)

            /* 将参数值添加到参数列表（使用 i64 作为默认类型） */
            若 i > 0 则 {
                argStr = argStr + ", "
            }
            argStr = argStr + "i64 %" + argValue

            i = i + 1
        }
    }

    /* 生成函数调用 IR */
    若 argStr != "" 则 {
        codegenEmit(cg, "  %" + result + " = call " + returnType + " @" + funcName + "(" + argStr + ")")
    } 否则 {
        codegenEmit(cg, "  %" + result + " = call " + returnType + " @" + funcName + "()")
    }

    返回 result
}



/**
 * 生成带前缀的新标签
 */
函数 codegenNewLabelWithPrefix(cg: Codegen, prefix: 文本): 文本 {
    定义 可变 num: 整数
    num = cg.labelCount
    cg.labelCount = cg.labelCount + 1
    定义 可变 result: 文本
    result = prefix
    定义 可变 numStr: 文本
    numStr = 整数转文本(num)
    result = result + numStr
    返回 result
}

/* ============ AST 遍历和 IR 生成 ============ */

/**
 * 遍历 AST 节点生成 IR
 */
函数 codegen遍历节点(cg: Codegen, nodeKind: 整数, nodeName: 文本): 文本 {
    打印("遍历节点: kind=")
    打印(nodeKind)
    打印(", name=")
    打印(nodeName)

    定义 可变 result: 文本
    result = ""

    若 nodeKind == 0 则 {
        result = codegen生成标识符(cg, nodeName)
    } 否则 {
        若 nodeKind == 2 则 {
            result = codegen生成变量声明(cg, nodeName)
        } 否则 {
            若 nodeKind == 5 则 {
                result = codegen生成函数调用(cg, nodeName, 0)
            } 否则 {
                若 nodeKind == 10 则 {
                    result = codegen生成二元表达式(cg, nodeName, "", "")
                } 否则 {
                    若 nodeKind == 14 则 {
                        result = codegen生成字面量(cg, nodeName)
                    }
                }
            }
        }
    }

    返回 result
}

/**
 * 生成标识符 IR
 */
函数 codegen生成标识符(cg: Codegen, name: 文本): 文本 {
    定义 可变 result: 文本
    result = name + "_val"

    定义 可变 line: 文本
    line = "%" + result + " = load i64, i64* %" + name + "_slot"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成变量声明 IR
 */
函数 codegen生成变量声明(cg: Codegen, name: 文本): 文本 {
    定义 可变 tmpPtr: 文本
    tmpPtr = name + "_slot"

    定义 可变 line: 文本
    line = "%" + tmpPtr + " = alloca i64"
    codegenEmit(cg, line)

    返回 tmpPtr
}

/**
 * 生成函数调用 IR
 */
函数 codegen生成函数调用(cg: Codegen, funcName: 文本, argCount: 整数): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    
    /* 特殊处理列表操作函数 */
    若 funcName == "_u5217_u8868_u8ffd_u52a0" 则 {
        /* 列表添加/追加 */
        line = "%" + result + " = call i64 @_u5217_u8868_u8ffd_u52a0(i8* %" + result + ", i64 %" + result + ")"
        codegenEmit(cg, line)
        返回 result
    } 否则 若 funcName == "_u5217_u8868_u8bbe_u7f6e" 则 {
        /* 列表设置 */
        line = "call void @_u5217_u8868_u8bbe_u7f6e(i8* %" + result + ", i64 0, i64 %" + result + ")"
        codegenEmit(cg, line)
        返回 result
    } 否则 若 funcName == "_u5217_u8868_u83b7_u53d6" 则 {
        /* 列表获取 */
        line = "%" + result + " = call i64 @_u5217_u8868_u83b7_u53d6(i8* %" + result + ", i64 0)"
        codegenEmit(cg, line)
        返回 result
    } 否则 若 funcName == "_u5217_u8868_u957f_u5ea6" 则 {
        /* 列表长度 */
        line = "%" + result + " = call i64 @_u5217_u8868_u957f_u5ea6(i8* %" + result + ")"
        codegenEmit(cg, line)
        返回 result
    } 否则 {
        /* 其他函数 */
        line = "%" + result + " = call i64 @" + funcName + "()"
        codegenEmit(cg, line)
        返回 result
    }
}

/**
 * 生成二元表达式 IR
 */
函数 codegen生成二元表达式(cg: Codegen, op: 文本, left: 文本, right: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 llOp: 文本
    llOp = "add"

    若 op == "+" 则 { llOp = "add" }
    若 op == "-" 则 { llOp = "sub" }
    若 op == "*" 则 { llOp = "mul" }
    若 op == "/" 则 { llOp = "sdiv" }
    若 op == "%" 则 { llOp = "srem" }

    定义 可变 line: 文本
    line = "%" + result + " = " + llOp + " i64 %" + left + ", %" + right
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成字面量 IR
 */
函数 codegen生成字面量(cg: Codegen, value: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = add i64 0, " + value
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成赋值 IR
 */
函数 codegen生成赋值IR(cg: Codegen, varName: 文本, value: 文本): 无返回 {
    定义 可变 tmpPtr: 文本
    tmpPtr = varName + "_slot"

    定义 可变 line: 文本
    line = "store i64 %" + value + ", i64* %" + tmpPtr
    codegenEmit(cg, line)
}

/**
 * 生成 if 语句 IR
 */
函数 codegen生成If语句(cg: Codegen, condVar: 文本, thenLabel: 文本, elseLabel: 文本, endLabel: 文本): 无返回 {
    定义 可变 line: 文本
    line = "br i1 %" + condVar + ", label %" + thenLabel + ", label %" + elseLabel
    codegenEmit(cg, line)
}

/**
 * 生成 while 循环 IR
 */
函数 codegen生成While循环(cg: Codegen, condVar: 文本, bodyLabel: 文本, endLabel: 文本): 无返回 {
    定义 可变 line: 文本
    line = "br i1 %" + condVar + ", label %" + bodyLabel + ", label %" + endLabel
    codegenEmit(cg, line)
}

/**
 * 生成 for 循环 IR
 */
函数 codegen生成For循环(cg: Codegen, varName: 文本, startVal: 整数, endVal: 整数, bodyLabel: 文本, incLabel: 文本, endLabel: 文本): 无返回 {
    定义 可变 tmpPtr: 文本
    tmpPtr = varName + "_slot"

    定义 可变 startTmp: 文本
    startTmp = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + startTmp + " = add i64 0, " + 整数转文本(startVal)
    codegenEmit(cg, line)

    line = "store i64 %" + startTmp + ", i64* %" + tmpPtr
    codegenEmit(cg, line)

    line = "br label %" + incLabel
    codegenEmit(cg, line)
}

/**
 * 生成 match 语句 IR
 */
函数 codegen生成Match语句(cg: Codegen, subjectVar: 文本, branchCount: 整数): 无返回 {
    打印("生成 match 语句 IR, subject=")
    打印(subjectVar)
    打印(", 分支数=")
    打印(branchCount)
}

/**
 * 生成返回语句 IR
 */
函数 codegen生成返回IR(cg: Codegen, value: 文本): 无返回 {
    定义 可变 line: 文本
    line = "ret i64 %" + value
    codegenEmit(cg, line)
}

/**
 * 生成 break 语句 IR
 */
函数 codegen生成BreakIR(cg: Codegen, endLabel: 文本): 无返回 {
    定义 可变 line: 文本
    line = "br label %" + endLabel
    codegenEmit(cg, line)
}

/**
 * 生成 continue 语句 IR
 */
函数 codegen生成ContinueIR(cg: Codegen, loopLabel: 文本): 无返回 {
    定义 可变 line: 文本
    line = "br label %" + loopLabel
    codegenEmit(cg, line)
}

/**
 * 生成比较表达式 IR
 */
函数 codegen生成比较IR(cg: Codegen, op: 文本, left: 文本, right: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 llOp: 文本
    llOp = "eq"

    若 op == "==" 则 { llOp = "eq" }
    若 op == "!=" 则 { llOp = "ne" }
    若 op == "<" 则 { llOp = "slt" }
    若 op == ">" 则 { llOp = "sgt" }
    若 op == "<=" 则 { llOp = "sle" }
    若 op == ">=" 则 { llOp = "sge" }

    定义 可变 line: 文本
    line = "%" + result + " = icmp " + llOp + " i64 %" + left + ", %" + right
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成逻辑与 IR
 */
函数 codegen生成逻辑与(cg: Codegen, left: 文本, right: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = and i1 %" + left + ", %" + right
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成逻辑或 IR
 */
函数 codegen生成逻辑或(cg: Codegen, left: 文本, right: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = or i1 %" + left + ", %" + right
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成逻辑非 IR
 */
函数 codegen生成逻辑非(cg: Codegen, operand: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = xor i1 %" + operand + ", true"
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成一元负 IR
 */
函数 codegen生成负值(cg: Codegen, operand: 文本): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = sub i64 0, %" + operand
    codegenEmit(cg, line)

    返回 result
}

/* ============ 代码生成统计 ============ */

/**
 * 代码生成统计信息
 */
结构体 CodegenStats {
    生成的指令数: 整数,
    生成的分支数: 整数,
    生成的函数数: 整数,
    生成的全局变量数: 整数,
    总内存分配: 整数
}

/**
 * 创建代码生成统计
 */
函数 codegen创建统计(): CodegenStats {
    定义 可变 stats: CodegenStats
    stats.生成的指令数 = 0
    stats.生成的分支数 = 0
    stats.生成的函数数 = 0
    stats.生成的全局变量数 = 0
    stats.总内存分配 = 0
    返回 stats
}

/**
 * 打印代码生成统计
 */
函数 codegen打印统计(stats: CodegenStats): 无返回 {
    打印("=== 代码生成统计 ===")
    打印("  生成的指令数: ")
    打印(stats.生成的指令数)
    打印("  生成的分支数: ")
    打印(stats.生成的分支数)
    打印("  生成的函数数: ")
    打印(stats.生成的函数数)
    打印("  生成的全局变量数: ")
    打印(stats.生成的全局变量数)
    打印("  总内存分配: ")
    打印(stats.总内存分配)
    打印("  bytes")
}

/* ============ 测试函数 ============ */

/**
 * 创建一个简单的测试 AST
 * 用于测试代码生成器
 */
函数 codegen创建测试AST(): AST节点 {
    定义 可变 root: AST节点
    root.kind = 0  // 程序节点
    root.name = "测试程序"
    root.children = 列表()
    
    /* 创建主函数 */
    定义 可变 mainFunc: AST节点
    mainFunc.kind = 1  // 函数定义
    mainFunc.name = "主"
    mainFunc.children = 列表()
    
    /* 创建函数体（块语句） */
    定义 可变 body: AST节点
    body.kind = 18  // 块语句
    body.children = 列表()
    
    /* 添加变量定义：x = 42 */
    定义 可变 varX: AST节点
    varX.kind = 3  // 变量定义
    varX.name = "x"
    varX.children = 列表()
    
    /* 添加字面量 42 */
    定义 可变 lit42: AST节点
    lit42.kind = 14  // 字面量表达式
    lit42.value = "42"
    列表追加(varX.children, lit42)
    列表追加(body.children, varX)
    
    /* 添加返回语句 */
    定义 可变 retStmt: AST节点
    retStmt.kind = 8  // 返回语句
    retStmt.children = 列表()
    
    /* 添加标识符 x */
    定义 可变 idX: AST节点
    idX.kind = 13  // 标识符表达式
    idX.name = "x"
    列表追加(retStmt.children, idX)
    列表追加(body.children, retStmt)
    
    /* 把函数体添加到函数 */
    列表追加(mainFunc.children, body)
    
    /* 把主函数添加到根节点 */
    列表追加(root.children, mainFunc)
    
    返回 root
}

/**
 * 测试代码生成器
 */
函数 codegen测试(): 整数 {
    打印("=== 代码生成器测试 ===")
    
    /* 创建测试 AST */
    定义 可变 testAST: AST节点
    testAST = codegen创建测试AST()
    
    /* 遍历 AST 生成 IR */
    打印("正在生成 LLVM IR...")
    定义 可变 moduleName: 文本
    moduleName = codegen遍历AST(testAST)
    
    打印("=== 测试完成 ===")
    打印("生成的模块: ")
    打印(moduleName)
    
    返回 1
}

/**
 * 测试字符串常量管理
 */
函数 codegen测试字符串常量(): 整数 {
    打印("=== 字符串常量测试 ===")
    
    定义 可变 cg: Codegen
    cg = codegenInit()
    
    /* 添加一些字符串常量 */
    定义 可变 str1: 文本
    str1 = codegen添加字符串常量(cg, "Hello, World!")
    定义 可变 str2: 文本
    str2 = codegen添加字符串常量(cg, "测试字符串")
    定义 可变 str3: 文本
    str3 = codegen添加字符串常量(cg, "Hello, World!")  // 重复的字符串
    
    打印("字符串1: ")
    打印(str1)
    打印("字符串2: ")
    打印(str2)
    打印("字符串3 (重复): ")
    打印(str3)
    
    /* 查找字符串 */
    定义 可变 found1: 文本
    found1 = codegen查找字符串常量(cg, "Hello, World!")
    定义 可变 found2: 文本
    found2 = codegen查找字符串常量(cg, "不存在的字符串")
    
    打印("查找 'Hello, World!': ")
    打印(found1)
    打印("查找 '不存在的字符串': ")
    打印(found2)
    
    打印("=== 字符串常量测试完成 ===")
    返回 1
}

/**
 * 测试变量映射管理
 */
函数 codegen测试变量映射(): 整数 {
    打印("=== 变量映射测试 ===")
    
    定义 可变 cg: Codegen
    cg = codegenInit()
    
    /* 添加变量 */
    codegen添加变量(cg, "x", "x_slot", "整数")
    codegen添加变量(cg, "y", "y_slot", "浮点数")
    codegen添加变量(cg, "name", "name_slot", "文本")
    
    /* 查找变量 */
    定义 可变 ssaX: 文本
    ssaX = codegen查找变量(cg, "x")
    定义 可变 typeX: 文本
    typeX = codegen查找变量类型(cg, "x")
    定义 可变 ssaY: 文本
    ssaY = codegen查找变量(cg, "y")
    定义 可变 typeY: 文本
    typeY = codegen查找变量类型(cg, "y")
    定义 可变 ssaNotFound: 文本
    ssaNotFound = codegen查找变量(cg, "不存在的变量")
    
    打印("变量 x - SSA: ")
    打印(ssaX)
    打印(", 类型: ")
    打印(typeX)
    打印("变量 y - SSA: ")
    打印(ssaY)
    打印(", 类型: ")
    打印(typeY)
    打印("变量 '不存在的变量': ")
    打印(ssaNotFound)
    
    /* 清空变量映射 */
    codegen清空变量(cg)
    打印("清空后变量映射大小: ")
    打印(列表长度(cg.variableMap))
    
    打印("=== 变量映射测试完成 ===")
    返回 1
}

/**
 * 主测试函数
 */
函数 codegen运行所有测试(): 整数 {
    打印("")
    打印("========================================")
    打印("   玄语 L2 编译器 - 代码生成器测试")
    打印("========================================")
    打印("")
    
    定义 可变 success: 整数
    success = 1
    
    /* 测试变量映射 */
    若 codegen测试变量映射() != 1 则 { success = 0 }
    打印("")
    
    /* 测试字符串常量 */
    若 codegen测试字符串常量() != 1 则 { success = 0 }
    打印("")
    
    /* 测试完整代码生成 */
    若 codegen测试() != 1 则 { success = 0 }
    打印("")
    
    打印("========================================")
    若 success == 1 则 {
        打印("   所有测试通过 ✓")
    } 否则 {
        打印("   部分测试失败 ✗")
    }
    打印("========================================")
    打印("")
    
    返回 success
}