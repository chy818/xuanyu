    定义 可变 line: 文本
    line = "; 枚举: " + enumName
    codegenEmit(cg, line)

    定义 可变 i: 整数
    i = 0
    当 i < 列表长度(enumNode.children) && i < 20 则 {
        定义 可变 member: AST节点
        member = enumNode.children[i]
        打印("  成员: ")
        打印(member.name)
        打印(" = ")
        打印(member.intValue)
        i = i + 1
    }
}

/**
 * 遍历导入语句
 */
函数 codegen遍历导入语句(cg: Codegen, importNode: AST节点): 无返回 {
