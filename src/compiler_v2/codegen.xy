}

/**
 * 生成捕获异常 IR
 */
函数 codegenCatchSwitch(cg: Codegen, parentPad: 文本, defaultLabel: 文本, numHandlers: 整数): 文本 {
    定义 可变 result: 文本
    result = codegenNewTemp(cg)

    定义 可变 line: 文本
    line = "%" + result + " = catchswitch within %" + parentPad + " [label %" + defaultLabel + "] to label %" + defaultLabel
    codegenEmit(cg, line)

    返回 result
}

/**
 * 生成清理返回 IR
 */
函数 codegenCleanupRet(cg: Codegen, catchPad: 文本, targetLabel: 文本): 无返回 {
    定义 可变 line: 文本
