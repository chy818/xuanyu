/**
 * 目标平台定义
 */
结构体 TargetPlatform {
    名称: 文本,
    架构: 文本,
    操作系统: 文本,
    厂商: 文本
}

/**
 * 获取默认目标平台
 */
函数 获取默认目标平台(): TargetPlatform {
    定义 可变 platform: TargetPlatform
    platform.名称 = "x86_64-pc-windows-msvc"
    platform.架构 = "x86_64"
    platform.操作系统 = "windows"
    platform.厂商 = "pc"
    返回 platform
}

/**
 * 获取支持的目标平台列表
 */
函数 获取支持的目标平台(): 列表 {
    定义 可变 platforms: 列表
    platforms = 列表()
    返回 platforms
}

/**
 * 验证目标平台
 */
函数 验证目标平台(platform: 文本): 整数 {
    若 platform == "x86_64-pc-windows-msvc" 则 { 返回 1 }
    若 platform == "x86_64-pc-linux-gnu" 则 { 返回 1 }
    若 platform == "aarch64-pc-windows-msvc" 则 { 返回 1 }
    若 platform == "aarch64-pc-linux-gnu" 则 { 返回 1 }
    返回 0
}

