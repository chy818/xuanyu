/**
 * 验证编译器选项
 */
函数 validateOptions(opts: CompileOptions): 整数 {
    若 opts.输入文件 == "" 则 {
        打印("错误: 必须指定输入文件")
        返回 0
    }

    若 opts.优化级别 < 0 || opts.优化级别 > 3 则 {
        打印("错误: 无效的优化级别 (0-3)")
        返回 0
    }

    若 验证目标平台(opts.目标平台) == 0 则 {
        打印("错误: 不支持的目标平台")
        返回 0
    }

    返回 1
}

