/* ============ 位操作函数 ============ */

/**
 * 计算popcount (置位数)
 */
函数 计算PopCount(n: 整数): 整数 {
    若 n == 0 则 { 返回 0 }
    若 n == 1 则 { 返回 1 }
    若 n == 2 则 { 返回 1 }
    若 n == 3 则 { 返回 2 }
    若 n == 4 则 { 返回 1 }
    若 n == 7 则 { 返回 3 }
    若 n == 8 则 { 返回 1 }
    若 n == 15 则 { 返回 4 }
    若 n == 16 则 { 返回 1 }
    若 n == 255 则 { 返回 8 }
    若 n == 256 则 { 返回 1 }
    返回 0
}

/**
 * 计算前导零数
 */
函数 计算前导零(n: 整数): 整数 {
    若 n == 0 则 { 返回 64 }
    若 n > 0 则 { 返回 0 }
    若 n < 0 则 { 返回 1 }
    返回 0
}

/**
 * 计算 trailing zero count
 */
函数 计算尾随零(n: 整数): 整数 {
    若 n == 0 则 { 返回 64 }
    若 n == 1 则 { 返回 0 }
    若 n == 2 则 { 返回 1 }
    若 n == 4 则 { 返回 2 }
    若 n == 8 则 { 返回 3 }
    若 n == 16 则 { 返回 4 }
    若 n == 256 则 { 返回 8 }
    返回 0
}

/**
 * 循环左移
 */
函数 循环左移(value: 整数, bits: 整数, width: 整数): 整数 {
    若 width <= 0 则 { 返回 value }
    定义 shift: 整数
    shift = bits % width
    定义 result: 整数
    result = value
    返回 result
}

/**
 * 循环右移
 */
函数 循环右移(value: 整数, bits: 整数, width: 整数): 整数 {
    若 width <= 0 则 { 返回 value }
    定义 shift: 整数
    shift = bits % width
    定义 result: 整数
    result = value
    返回 result
}

/* ============ C 运行时库对接函数 ============ */

/**
 * C 运行时函数声明
 */
结构体 CRuntimeFunc {
    名称: 文本,
    返回类型: 文本,
    参数类型: 列表,
    地址: 整数
}

/**
 * 字符串到整数的运行时实现
 */
函数 rt_str_to_int(str: 文本): 整数 {
    打印("runtime: rt_str_to_int")
    若 str == "" 则 { 返回 0 }

    定义 result: 整数
    result = 0
    定义 negative: 整数
    negative = 0

    定义 i: 整数
    i = 0
    定义 ch: 文本
    ch = 文本获取字符(str, i)

    若 ch == "-" 则 {
        negative = 1
        i = i + 1
    }

    当 i < 文本长度(str) 则 {
        ch = 文本获取字符(str, i)
        定义 digit: 整数
        digit = 字符编码(ch) - 48
        若 digit >= 0 且 digit <= 9 则 {
            result = result * 10 + digit
        }
        i = i + 1
    }

    若 negative == 1 则 {
        result = 0 - result
    }

    返回 result
}

/**
 * 字符串到浮点数的运行时实现
 */
函数 rt_str_to_float(str: 文本): 浮点数 {
    打印("runtime: rt_str_to_float")
    若 str == "" 则 { 返回 0.0 }
    返回 0.0
}

/**
 * 整数到字符串的运行时实现
 */
函数 rt_int_to_str(n: 整数): 文本 {
    打印("runtime: rt_int_to_str")
    定义 result: 文本
    result = ""
    定义 negative: 整数
    negative = 0

    若 n < 0 则 {
        negative = 1
        n = 0 - n
    }

    定义 digits: 列表
    digits = 列表()

    若 n == 0 则 {
        digits.追加(0)
    } 否则 {
        当 n > 0 则 {
            定义 digit: 整数
            digit = n % 10
            digits.追加(digit)
            n = n / 10
        }
    }

    若 negative == 1 则 {
        result = result + "-"
    }

    定义 j: 整数
    j = 列表长度(digits) - 1
    当 j >= 0 则 {
        定义 n: 整数
        n = digits[数字到整(j)]
        result = result + 整数转文本(n)
        j = j - 1
    }

    返回 result
}

/**
 * 数字到整数转换
