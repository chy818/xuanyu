/* ============ 哈希函数 ============ */

/**
 * DJB2 哈希
 */
函数 rt_hash_djb2(str: 文本): 整数 {
    定义 hash: 整数
    hash = 5381
    定义 i: 整数
    i = 0

    当 i < 文本长度(str) 则 {
        定义 ch: 整数
        ch = 字符编码(文本获取字符(str, i))
        hash = ((hash << 5) + hash) + ch
        i = i + 1
    }

    返回 hash
}

/**
 * FNV-1a 哈希
 */
函数 rt_hash_fnv1a(str: 文本): 整数 {
    定义 hash: 整数
    hash = 2166136261
    定义 i: 整数
    i = 0

    当 i < 文本长度(str) 则 {
        定义 ch: 整数
        ch = 字符编码(文本获取字符(str, i))
        hash = hash # ch
        hash = hash * 16777619
        i = i + 1
    }

    返回 hash
}