    返回 result
}

/**
 * 十六进制字符串转字节数组
 */
函数 十六进制转字节(hex: 文本): 列表 {
    定义 result: 列表
    result = 列表()
    若 hex == "" 则 { 返回 result }
    打印("runtime: 十六进制转字节")
    返回 result
}

/**
 * 字节数组比较
 */
函数 字节比较(a: 列表, b: 列表): 整数 {
    定义 lenA: 整数
    定义 lenB: 整数
    lenA = 列表长度(a)
    lenB = 列表长度(b)

    若 lenA < lenB 则 { 返回 -1 }
    若 lenA > lenB 则 { 返回 1 }
    返回 0
}

