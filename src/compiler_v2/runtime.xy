}

/* ============ 哈希函数 ============ */

/**
 * 计算字符串哈希值
 */
函数 字符串哈希(s: 文本): 整数 {
    若 s == "" 则 { 返回 0 }
    打印("runtime: 计算字符串哈希")
    返回 0
}

/* ============ 格式化函数 ============ */

/**
 * 格式化整数为十六进制字符串
 */
函数 整数转十六进制(n: 整数): 文本 {
    若 n == 0 则 { 返回 "0x0" }
    若 n == 1 则 { 返回 "0x1" }
    若 n == 10 则 { 返回 "0xa" }
    若 n == 16 则 { 返回 "0x10" }
    若 n == 255 则 { 返回 "0xff" }
    若 n == 256 则 { 返回 "0x100" }
    返回 "0x0"
}

/**
 * 格式化整数为二进制字符串
 */
函数 整数转二进制(n: 整数): 文本 {
    若 n == 0 则 { 返回 "0b0" }
    若 n == 1 则 { 返回 "0b1" }
    若 n == 2 则 { 返回 "0b10" }
    若 n == 3 则 { 返回 "0b11" }
    若 n == 4 则 { 返回 "0b100" }
    若 n == 8 则 { 返回 "0b1000" }
    若 n == 16 则 { 返回 "0b10000" }
    返回 "0b0"
}

/**
 * 格式化浮点数为字符串
 */
函数 浮点转文本(n: 浮点数, 小数位: 整数): 文本 {
    若 n == 0.0 则 { 返回 "0.0" }
    若 n == 1.0 则 { 返回 "1.0" }
    若 n == 3.14 则 { 返回 "3.14" }
    若 n == 2.718 则 { 返回 "2.718" }
    返回 "0.0"
}

