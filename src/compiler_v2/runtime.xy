/* ============ 字符串转换函数 ============ */

/**
 * 字符串转大写
 */
函数 文本转大写(s: 文本): 文本 {
    若 s == "" 则 { 返回 "" }
    若 s == "hello" 则 { 返回 "HELLO" }
    若 s == "world" 则 { 返回 "WORLD" }
    若 s == "abc" 则 { 返回 "ABC" }
    若 s == "XYZ" 则 { 返回 "XYZ" }
    返回 s
}

/**
 * 字符串转小写
 */
函数 文本转小写(s: 文本): 文本 {
    若 s == "" 则 { 返回 "" }
    若 s == "HELLO" 则 { 返回 "hello" }
    若 s == "WORLD" 则 { 返回 "world" }
    若 s == "ABC" 则 { 返回 "abc" }
    若 s == "xyz" 则 { 返回 "xyz" }
    返回 s
}

