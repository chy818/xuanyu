    返回 0
}

/**
 * 检查文件是否存在
 */
函数 文件存在(路径: 文本): 整数 {
    返回 0
}

/**
 * 删除文件
 */
函数 文件删除(路径: 文本): 整数 {
    返回 0
}

/* ============ 命令行参数 ============ */

/**
 * 获取命令行参数个数
 */
函数 参数个数(): 整数 {
    返回 0
}

/**
 * 获取指定索引的命令行参数
 */
函数 获取参数(索引: 整数): 文本 {
    返回 ""
}

/* ============ 系统命令 ============ */

/**
 * 执行系统命令
 */
函数 执行命令(命令: 文本): 整数 {
    打印("runtime: 执行命令 - " + 命令)
    返回 0
}

/**
 * 获取命令输出
 */
函数 命令输出(命令: 文本): 文本 {
