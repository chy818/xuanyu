    若 条件 == 假 则 {
        打印("ASSERTION FAILED: " + 消息)
    }
}

/**
 * 验证条件为假
 */
函数 断言假(条件: 布尔, 消息: 文本) {
    若 条件 == 真 则 {
        打印("ASSERTION FAILED: " + 消息)
    }
}

/**
 * 验证对象不为空
 */
函数 断言非空(obj: 整数, 消息: 文本) {
    若 obj == 0 则 {
        打印("ASSERTION FAILED: " + 消息)
    }
}

/**
 * 验证字符串不为空
 */
函数 断言非空文本(s: 文本, 消息: 文本) {
    若 s == "" 则 {
        打印("ASSERTION FAILED: " + 消息)
    }
}

