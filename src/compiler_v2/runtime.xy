    若 c == 'P' 则 { 返回 'p' }
    若 c == 'Q' 则 { 返回 'q' }
    若 c == 'R' 则 { 返回 'r' }
    若 c == 'S' 则 { 返回 's' }
    若 c == 'T' 则 { 返回 't' }
