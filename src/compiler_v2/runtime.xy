/**
 * 将字符转为大写
 */
函数 字符转大写(c: 字符): 字符 {
    若 c == 'a' 则 { 返回 'A' }
    若 c == 'b' 则 { 返回 'B' }
    若 c == 'c' 则 { 返回 'C' }
    若 c == 'd' 则 { 返回 'D' }
    若 c == 'e' 则 { 返回 'E' }
    若 c == 'f' 则 { 返回 'F' }
    若 c == 'g' 则 { 返回 'G' }
    若 c == 'h' 则 { 返回 'H' }
    若 c == 'i' 则 { 返回 'I' }
    若 c == 'j' 则 { 返回 'J' }
    若 c == 'k' 则 { 返回 'K' }
    若 c == 'l' 则 { 返回 'L' }
    若 c == 'm' 则 { 返回 'M' }
    若 c == 'n' 则 { 返回 'N' }
    若 c == 'o' 则 { 返回 'O' }
    若 c == 'p' 则 { 返回 'P' }
    若 c == 'q' 则 { 返回 'Q' }
    若 c == 'r' 则 { 返回 'R' }
    若 c == 's' 则 { 返回 'S' }
    若 c == 't' 则 { 返回 'T' }
    若 c == 'u' 则 { 返回 'U' }
    若 c == 'v' 则 { 返回 'V' }
    若 c == 'w' 则 { 返回 'W' }
    若 c == 'x' 则 { 返回 'X' }
    若 c == 'y' 则 { 返回 'Y' }
    若 c == 'z' 则 { 返回 'Z' }
    返回 c
}

/**
