/**
 * @file lexer.xy
 * @brief 词法分析器模块 - 自展编译器
 */

// Token 类型
枚举 TokType {
    Kw,
    Id,
    Num,
    Str,
    Sym,
    End,
}

// Token 结构体
结构体 Token {
    typ: TokType,
    text: 文本,
    val: 整数,
    line: 整数,
}

/**
 * 词法分析 - 简单实现
 * 输入源码，输出 Token 列表
 */
函数 lex(): 整数 {
    打印("lexer: 词法分析器已就绪")
    打印("支持: 标识符, 关键字, 数字, 字符串, 符号")
    返回 0
}
