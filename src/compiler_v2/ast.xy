/**
 * @file ast.xy
 * @brief AST 节点定义 - 自展编译器
 */

// 类型枚举
枚举 Type { Int, Bool, Str, Ptr, Void, List }

// 表达式
枚举 Exp { 
    Lit, 
    Id, 
    Call, 
    Bin 
}

// 语句
枚举 Stmt { 
    Exp, 
    Ret, 
    If, 
    While, 
    Let 
}

// 函数
结构体 Func { name, params, ret, body }

// 程序
结构体 Prog { funcs: 列表 }

函数 主(): 整数 {
    打印("ast ready")
    返回 0
}
