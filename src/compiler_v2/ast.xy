/**
 * @file ast.xy
 * @brief AST 节点定义模块
 */

枚举 Token型 {
    标识符K,
    关键字K,
    数字K,
    文本K,
    符号K,
    结束K,
    错误K,
}

结构体 Token {
    种类: Token型,
    内容: 文本,
    行: 整数,
    列: 整数,
}

枚举 表达式 {
    数字字面量,
    文本字面量,
    布尔字面量,
    标识符,
    二元运算,
    一元运算,
    函数调用,
}

枚举 语句 {
    表达式语句,
    变量声明,
    赋值,
    返回语句,
    如果语句,
    当语句,
    块语句,
}

枚举 声明 {
    函数定义,
    结构体定义,
    枚举定义,
    常量定义,
    外部函数,
}

打印("AST 模块已加载")
