/**
 * 分析 break 语句
 */
函数 分析Break语句(sema: Sema): 整数 {
    打印("分析 break 语句")

    定义 可变 idx: 整数
    idx = 查找符号(sema, "__in_loop")

    若 idx < 0 则 {
        报告错误(sema, "break 语句只能在循环中使用", 0)
        返回 -1
    }

    返回 0
}

/**
 * 分析 continue 语句
 */
函数 分析Continue语句(sema: Sema): 整数 {
    打印("分析 continue 语句")

    定义 可变 idx: 整数
    idx = 查找符号(sema, "__in_loop")

    若 idx < 0 则 {
        报告错误(sema, "continue 语句只能在循环中使用", 0)
        返回 -1
    }

    返回 0
}

/**
 * 进入循环作用域
 * 更新循环状态，用于 break/continue 语句检查
 */
函数 sema进入循环(sema: Sema): 无返回 {
    /* 更新循环状态 */
    sema.循环状态.激活 = 1
    sema.循环状态.循环层级 = sema.循环状态.循环层级 + 1
    
    打印("进入循环作用域，层级: ")
    打印(sema.循环状态.循环层级)
}

/**
 * 退出循环作用域
 * 更新循环状态
 */
函数 sema退出循环(sema: Sema): 无返回 {
    /* 更新循环状态 */
    sema.循环状态.循环层级 = sema.循环状态.循环层级 - 1
    若 sema.循环状态.循环层级 <= 0 则 {
        sema.循环状态.激活 = 0
        sema.循环状态.循环层级 = 0
    }
    
    打印("退出循环作用域，剩余层级: ")
    打印(sema.循环状态.循环层级)
}

/**
 * 进入函数作用域
 */
函数 sema进入函数(sema: Sema, funcName: 文本): 无返回 {
    打印("进入函数作用域: ")
    打印(funcName)
}

/**
 * 退出函数作用域
 */
函数 sema退出函数(sema: Sema): 无返回 {
    打印("退出函数作用域")
}

/* ============ AST 遍历语义分析核心 ============ */

/**
 * 遍历 AST 根节点进行语义分析
 */
函数 sema遍历AST(sema: Sema, ast: AST节点): 整数 {
    打印("=== 开始语义分析 ===")

    sema.错误计数 = 0
    sema.警告计数 = 0

    /* 注意：全局作用域已经在 semaInit 中创建 */

    定义 可变 errorCount: 整数
    errorCount = 0

    /* 遍历顶层声明 */
    定义 可变 i: 整数
    i = 0
    当 i < 列表长度(ast.children) && i < 100 则 {
        定义 可变 child: AST节点
        child = 列表获取(ast.children, i)

        若 child.kind == 1 则 {  /* 函数定义 */
            定义 可变 result: 整数
            result = sema遍历函数定义(sema, child)
            若 result < 0 则 {
                errorCount = errorCount + 1
            }
        } 否则 若 child.kind == 3 则 {  /* 变量定义 */
            定义 可变 result: 整数
            result = sema遍历变量定义(sema, child)
            若 result < 0 则 {
                errorCount = errorCount + 1
            }
        } 否则 若 child.kind == 21 则 {  /* 结构体定义 */
            定义 可变 result: 整数
            result = sema遍历结构体定义(sema, child)
            若 result < 0 则 {
                errorCount = errorCount + 1
            }
        } 否则 若 child.kind == 22 则 {  /* 枚举定义 */
            定义 可变 result: 整数
            result = sema遍历枚举定义(sema, child)
            若 result < 0 则 {
                errorCount = errorCount + 1
            }
        } 否则 若 child.kind == 30 则 {  /* 外部声明 - 直接跳过，语义分析不报错 */
            打印("跳过外部声明")
        } 否则 {
            打印("未知顶层声明类型: ")
            打印(child.kind)
        }
        i = i + 1
    }

    打印("=== 语义分析完成 ===")
    打印("错误数: ")
    打印(sema.错误计数)
    打印("警告数: ")
    打印(sema.警告计数)

    返回 errorCount
}

/**
 * 遍历结构体定义
 */
函数 sema遍历结构体定义(sema: Sema, structNode: AST节点): 整数 {
    定义 可变 structName: 文本
    structName = structNode.name

    打印("分析结构体定义: ")
    打印(structName)

    /* 创建结构体作用域 */
    定义 可变 scopeIdx: 整数
    scopeIdx = 创建作用域(sema, structName)

    /* 添加结构体类型符号 */
    定义 可变 result: 整数
    result = 添加符号(sema, structName, 10, 0)

    打印("结构体字段数量: ")
    打印(列表长度(structNode.children))

    退出作用域(sema)

    返回 result
}

/**
 * 遍历枚举定义
 */
函数 sema遍历枚举定义(sema: Sema, enumNode: AST节点): 整数 {
    定义 可变 enumName: 文本
    enumName = enumNode.name

    打印("分析枚举定义: ")
    打印(enumName)

    /* 添加枚举类型符号 */
    定义 可变 result: 整数
    result = 添加符号(sema, enumName, 11, 0)

    打印("枚举成员数量: ")
    打印(列表长度(enumNode.children))

    返回 result
}

/**
 * 遍历函数定义
 * 完整的函数定义分析，包括：
 * 1. 解析函数名和返回类型
 * 2. 分析参数列表并添加到作用域
 * 3. 将函数添加到符号表
 * 4. 分析函数体
 * 5. 检查返回值
 */
函数 sema遍历函数定义(sema: Sema, funcNode: AST节点): 整数 {
    定义 可变 funcName: 文本
    funcName = funcNode.name
    
    /* 设置当前函数信息 */
    sema.当前函数名 = funcName
    sema.当前函数返回类型 = 0  /* 默认整数类型 */

    打印("分析函数定义: ")
    打印(funcName)

    /* 首先将函数添加到当前作用域 */
    定义 可变 result: 整数
    result = 添加符号(sema, funcName, sema.当前函数返回类型, 0)
    若 result < 0 则 {
        返回 -1
    }

    /* 进入函数作用域 */
    定义 可变 functionScopeIdx: 整数
    functionScopeIdx = 创建作用域(sema, funcName + "_作用域")
    sema进入函数(sema, funcName)

    /* 分析参数列表 */
    若 列表长度(funcNode.children) > 1 则 {
        定义 可变 paramListNode: AST节点
        paramListNode = 列表获取(funcNode.children, 0)
        若 paramListNode.kind == 2 则 {  /* 参数列表节点 */
            result = sema分析参数列表(sema, paramListNode)
            若 result < 0 则 {
                退出作用域(sema)
                返回 -1
            }
        }
    }

    /* 分析函数体 */
    定义 可变 bodyIdx: 整数
    bodyIdx = 1  /* 默认 body 在索引 1 */
    若 列表长度(funcNode.children) == 1 则 {
        bodyIdx = 0  /* 如果只有一个子节点，就是 body */
    }
    
    定义 可变 body: AST节点
    body = 列表获取(funcNode.children, bodyIdx)

    打印("函数体 kind=")
    打印(body.kind)

    result = 0
    若 body.kind == 18 则 {  /* 块语句 */
        打印("遍历块语句")
        result = sema遍历块语句(sema, body)
    } 否则 {
        /* 单表达式函数体 */
        打印("遍历表达式")
        定义 可变 exprType: 整数
        exprType = sema遍历表达式(sema, body)
        
        /* 检查返回类型 */
        若 exprType >= 0 && sema.当前函数返回类型 >= 0 则 {
            若 类型兼容(exprType, sema.当前函数返回类型) == 0 则 {
                报告错误(sema, "函数返回类型不匹配: 期望 " + 类型转文本(sema.当前函数返回类型) + 
                     ", 实际 " + 类型转文本(exprType), funcNode.line)
            }
        }
    }

    /* 退出函数作用域 */
    sema退出函数(sema)
    退出作用域(sema)
    
    /* 清除当前函数信息 */
    sema.当前函数名 = ""
    sema.当前函数返回类型 = -1

    返回 result
}

/**
 * 分析参数列表
 * 解析函数参数并添加到作用域
 */
函数 sema分析参数列表(sema: Sema, paramListNode: AST节点): 整数 {
    打印("分析参数列表，参数个数: ")
    打印(列表长度(paramListNode.children))
    
    定义 可变 i: 整数
    i = 0
    当 i < 列表长度(paramListNode.children) 则 {
        定义 可变 paramNode: AST节点
        paramNode = 列表获取(paramListNode.children, i)
        
        /* 参数节点应该是标识符或变量定义 */
        定义 可变 paramName: 文本
        paramName = paramNode.name
        
        /* 默认参数类型为整数 */
        定义 可变 paramType: 整数
        paramType = 0
        
        打印("  参数: ")
        打印(paramName)
        打印(" 类型: ")
        打印(类型转文本(paramType))
        
        /* 添加参数到作用域 */
        定义 可变 result: 整数
        result = 添加符号(sema, paramName, paramType, 1)  /* 参数是可变的 */
        若 result < 0 则 {
            返回 -1
        }
        
        i = i + 1
    }
    
    返回 0
}

/**
 * 遍历块语句
 */
函数 sema遍历块语句(sema: Sema, block: AST节点): 整数 {
    定义 可变 i: 整数
    i = 0
    定义 可变 errorCount: 整数
    errorCount = 0

    打印("分析块语句, children=")
    打印(列表长度(block.children))

    当 i < 列表长度(block.children) && i < 50 则 {
        定义 可变 stmt: AST节点
        stmt = block.children[i]

        定义 可变 result: 整数
        result = sema遍历语句(sema, stmt)
        若 result < 0 则 {
            errorCount = errorCount + 1
        }

        i = i + 1
    }

    返回 errorCount
}

/**
 * 遍历语句
 */
函数 sema遍历语句(sema: Sema, stmt: AST节点): 整数 {
    定义 可变 result: 整数
    result = 0

    若 stmt.kind == 3 则 {  /* 变量定义 */
        result = sema遍历变量定义(sema, stmt)
    } 否则 若 stmt.kind == 12 则 {  /* 函数调用表达式 */
        result = sema遍历函数调用(sema, stmt.name, stmt.children)
    } 否则 若 stmt.kind == 5 则 {  /* if 语句 */
        result = sema遍历If语句(sema, stmt)
    } 否则 若 stmt.kind == 6 则 {  /* while 语句 */
        result = sema遍历While语句(sema, stmt)
    } 否则 若 stmt.kind == 20 则 {  /* for 语句 */
        result = sema遍历For语句(sema, stmt)
    } 否则 若 stmt.kind == 8 则 {  /* return 语句 */
        result = sema遍历返回语句(sema, stmt)
    } 否则 若 stmt.kind == 10 则 {  /* 二元表达式语句 */
        若 列表长度(stmt.children) >= 2 则 {
            定义 可变 leftChild: AST节点
            定义 可变 rightChild: AST节点
            leftChild = 列表获取(stmt.children, 0)
            rightChild = 列表获取(stmt.children, 1)
            result = sema遍历二元表达式(sema, stmt.name, leftChild, rightChild)
        }
    } 否则 若 stmt.kind == 16 则 {  /* break 语句 */
        result = sema遍历Break语句(sema, stmt)
    } 否则 若 stmt.kind == 17 则 {  /* continue 语句 */
        result = sema遍历Continue语句(sema, stmt)
    } 否则 若 stmt.kind == 25 则 {  /* match 语句 */
        若 列表长度(stmt.children) >= 1 则 {
            定义 可变 matchSubject: AST节点
            matchSubject = 列表获取(stmt.children, 0)
            定义 可变 subjectType: 整数
            subjectType = sema遍历表达式(sema, matchSubject)

            定义 可变 branchCount: 整数
            branchCount = 列表长度(stmt.children) - 1
            result = 分析Match语句(sema, subjectType, branchCount)
        }
    }

    返回 result
}

/**
 * 遍历变量定义
 * 完整的变量定义分析，包括：
 * 1. 解析变量名和类型注解
 * 2. 检查变量是否重定义
 * 3. 添加变量到符号表
 * 4. 分析初始化表达式
 * 5. 检查类型兼容性
 */
函数 sema遍历变量定义(sema: Sema, varNode: AST节点): 整数 {
    定义 可变 varName: 文本
    varName = varNode.name

    打印("分析变量定义: ")
    打印(varName)

    /* 检查是否已在当前作用域定义 */
    定义 可变 existing: 整数
    existing = 在当前作用域查找符号(sema, varName)

    若 existing >= 0 则 {
        报告错误(sema, "变量 '" + varName + "' 已在当前作用域定义", varNode.line)
        返回 -1
    }

    /* 解析变量类型（从 intValue 或 name 推断） */
    定义 可变 varType: 整数
    varType = varNode.intValue
    若 varType < 0 || varType > 8 则 {
        varType = 0  /* 默认整数类型 */
    }

    /* 检查是否是可变变量 */
    定义 可变 isMutable: 整数
    isMutable = 0  /* 默认不可变 */
    /* 可以从 varNode.value 或其他字段获取可变信息 */
    若 varNode.value == "可变" 则 {
        isMutable = 1
    }

    /* 添加变量到符号表 */
    定义 可变 result: 整数
    result = 添加符号(sema, varName, varType, isMutable)
    若 result < 0 则 {
        返回 -1
    }

    /* 分析初始化表达式 */
    若 列表长度(varNode.children) > 0 则 {
        定义 可变 initExpr: AST节点
        initExpr = 列表获取(varNode.children, 0)
        
        定义 可变 initType: 整数
        initType = sema遍历表达式(sema, initExpr)
        
        /* 检查初始化类型兼容性 */
        若 initType >= 0 则 {
            若 类型兼容(varType, initType) == 0 则 {
                报告警告(sema, "变量 '" + varName + "' 初始化类型不兼容: 期望 " + 
                          类型转文本(varType) + ", 实际 " + 类型转文本(initType), varNode.line)
            }
        }
    }

    返回 result
}

/**
 * 遍历 if 语句
 */
函数 sema遍历If语句(sema: Sema, ifNode: AST节点): 整数 {
    打印("分析 if 语句")

    定义 可变 cond: AST节点
    cond = 列表获取(ifNode.children, 0)

    定义 可变 condType: 整数
    condType = sema遍历表达式(sema, cond)

    /* 条件必须是布尔类型 */
    若 condType != 2 则 {
        报告警告(sema, "if 条件应为布尔类型", 0)
    }

    /* 分析 then 块 */
    定义 可变 thenBlock: AST节点
    thenBlock = 列表获取(ifNode.children, 1)
    定义 可变 result: 整数
    result = sema遍历块语句(sema, thenBlock)

    /* 分析 else 块 */
    定义 可变 childrenLen: 整数
    childrenLen = 列表长度(ifNode.children)
    若 childrenLen >= 3 则 {
        定义 可变 elseBlock: AST节点
        elseBlock = 列表获取(ifNode.children, 2)
        定义 可变 elseResult: 整数
        elseResult = sema遍历块语句(sema, elseBlock)
        若 elseResult < 0 则 {
            result = elseResult
        }
    }

    返回 result
}

/**
 * 遍历 while 语句
 */
函数 sema遍历While语句(sema: Sema, whileNode: AST节点): 整数 {
    打印("分析 while 语句")

    /* 进入循环作用域 */
    sema进入循环(sema)

    /* 分析条件表达式 */
    若 列表长度(whileNode.children) >= 1 则 {
        定义 可变 cond: AST节点
        cond = 列表获取(whileNode.children, 0)

        定义 可变 condType: 整数
        condType = sema遍历表达式(sema, cond)

        /* 条件应该是布尔类型 */
        若 condType != 2 && condType != 8 则 {
            报告警告(sema, "while 条件应为布尔类型", whileNode.line)
        }
    }

    /* 分析循环体 */
    定义 可变 result: 整数
    result = 0
    若 列表长度(whileNode.children) >= 2 则 {
        定义 可变 body: AST节点
        body = 列表获取(whileNode.children, 1)

        若 body.kind == 18 则 {
            result = sema遍历块语句(sema, body)
        } 否则 {
            result = sema遍历表达式(sema, body)
        }
    }

    /* 退出循环作用域 */
    sema退出循环(sema)

    返回 result
}

/**
 * 遍历 break 语句
 * 检查 break 语句是否在循环中
 */
函数 sema遍历Break语句(sema: Sema, breakNode: AST节点): 整数 {
    打印("分析 break 语句")

    /* 检查是否在循环中 */
    若 sema.循环状态.激活 == 0 则 {
        报告错误(sema, "break 语句只能在循环中使用", breakNode.line)
        返回 -1
    }

    返回 0
}

/**
 * 遍历 continue 语句
 * 检查 continue 语句是否在循环中
 */
函数 sema遍历Continue语句(sema: Sema, continueNode: AST节点): 整数 {
    打印("分析 continue 语句")

    /* 检查是否在循环中 */
    若 sema.循环状态.激活 == 0 则 {
        报告错误(sema, "continue 语句只能在循环中使用", continueNode.line)
        返回 -1
    }

    返回 0
}

/**
 * 遍历 for 语句
 */
函数 sema遍历For语句(sema: Sema, forNode: AST节点): 整数 {
    打印("分析 for 语句")

    /* 进入循环作用域 */
    sema进入循环(sema)

    /* 分析初始化 */
    定义 可变 init: AST节点
    init = 列表获取(forNode.children, 0)
    定义 可变 initResult: 整数
    initResult = sema遍历表达式(sema, init)

    /* 分析条件 */
    定义 可变 cond: AST节点
    cond = 列表获取(forNode.children, 1)
    定义 可变 condType: 整数
    condType = sema遍历表达式(sema, cond)

    /* 分析循环体 */
    定义 可变 body: AST节点
    body = 列表获取(forNode.children, 2)
    定义 可变 result: 整数
    result = sema遍历块语句(sema, body)

    /* 退出循环作用域 */
    sema退出循环(sema)

    返回 result
}

/**
 * 遍历返回语句
 */
函数 sema遍历返回语句(sema: Sema, retNode: AST节点): 整数 {
    打印("分析 return 语句")

    若 retNode.children.kind != 0 则 {
        定义 可变 exprType: 整数
        exprType = sema遍历表达式(sema, retNode.children)
    }

    返回 0
}

/**
 * 遍历表达式
 * 完整的表达式分析，包括：
 * 1. 标识符查找和类型获取
 * 2. 字面量类型推断
 * 3. 二元表达式类型检查
 * 4. 一元表达式类型检查
 * 5. 函数调用类型检查
 */
函数 sema遍历表达式(sema: Sema, expr: AST节点): 整数 {
    定义 可变 exprType: 整数
    exprType = 8  /* 默认为未知类型 */

    /* 更新当前行号 */
    sema.当前行号 = expr.line

    若 expr.kind == 13 则 {  /* 标识符表达式 */
        exprType = sema遍历标识符(sema, expr.name)
    } 否则 若 expr.kind == 14 则 {  /* 字面量表达式 */
        /* 根据字面量值推断类型 */
        定义 可变 val: 文本
        val = expr.value
        若 val == "真" || val == "假" 则 {
            exprType = 2  /* 布尔类型 */
        } 否则 若 val == "\"" || (文本长度(val) > 0 && val[0] == "\"") 则 {
            exprType = 3  /* 文本类型 */
        } 否则 若 val == "'" || (文本长度(val) > 0 && val[0] == "'") 则 {
            exprType = 4  /* 字符类型 */
        } 否则 若 文本包含(val, ".") == 1 则 {
            exprType = 1  /* 浮点类型 */
        } 否则 {
            exprType = 0  /* 整数类型 */
        }
    } 否则 若 expr.kind == 10 则 {  /* 二元表达式 */
        若 列表长度(expr.children) >= 2 则 {
            定义 可变 leftChild: AST节点
            定义 可变 rightChild: AST节点
            leftChild = 列表获取(expr.children, 0)
            rightChild = 列表获取(expr.children, 1)
            exprType = sema遍历二元表达式(sema, expr.name, leftChild, rightChild)
        }
    } 否则 若 expr.kind == 11 则 {  /* 一元表达式 */
        若 列表长度(expr.children) >= 1 则 {
            定义 可变 operand: AST节点
            operand = 列表获取(expr.children, 0)
            exprType = sema遍历一元表达式(sema, expr.name, operand)
        }
    } 否则 若 expr.kind == 12 则 {  /* 调用表达式 */
        exprType = sema遍历函数调用(sema, expr.name, expr.children)
    } 否则 若 expr.kind == 19 则 {  /* 赋值表达式 */
        若 列表长度(expr.children) >= 2 则 {
            定义 可变 targetNode: AST节点
            定义 可变 valueNode: AST节点
            targetNode = 列表获取(expr.children, 0)
            valueNode = 列表获取(expr.children, 1)
            exprType = sema遍历赋值表达式(sema, targetNode, valueNode)
        }
    } 否则 {
        /* 其他类型默认未知，后续可以扩展 */
        exprType = 0
    }

    返回 exprType
}

/**
 * 遍历赋值表达式
 * 检查赋值目标和值的类型兼容性
 */
函数 sema遍历赋值表达式(sema: Sema, target: AST节点, value: AST节点): 整数 {
    /* 分析目标表达式 */
    定义 可变 targetType: 整数
    targetType = sema遍历表达式(sema, target)
    
    /* 分析值表达式 */
    定义 可变 valueType: 整数
    valueType = sema遍历表达式(sema, value)
    
    /* 检查类型兼容性 */
    若 targetType >= 0 && valueType >= 0 则 {
        若 检查赋值兼容性(targetType, valueType) == 0 则 {
            报告错误(sema, "赋值类型不兼容: 目标类型 " + 类型转文本(targetType) + 
                     ", 值类型 " + 类型转文本(valueType), sema.当前行号)
        }
    }
    
    /* 赋值表达式返回目标类型 */
    返回 targetType
}

/**
 * 遍历标识符
 */
函数 sema遍历标识符(sema: Sema, name: 文本): 整数 {
    定义 可变 idx: 整数
    idx = 查找符号(sema, name)

    若 idx < 0 则 {
        报告错误(sema, "未定义的标识符: " + name, 0)
        返回 -1
    }

    定义 可变 symType: 整数
    symType = 获取符号类型(sema, name)
    返回 symType
}

/**
 * 遍历二元表达式
 */
函数 sema遍历二元表达式(sema: Sema, op: 文本, left: AST节点, right: AST节点): 整数 {
    定义 可变 leftType: 整数
    leftType = sema遍历表达式(sema, left)

    定义 可变 rightType: 整数
    rightType = sema遍历表达式(sema, right)

    /* 检查类型兼容性 */
    若 类型兼容(leftType, rightType) == 0 则 {
        报告错误(sema, "二元运算操作数类型不匹配", 0)
    }

    /* 比较运算需要整数或浮点类型，不支持指针/文本类型直接比较 */
    若 op == "==" || op == "!=" || op == "<" || op == ">" || op == "<=" || op == ">=" 则 {
        若 leftType < 0 || leftType == 3 || leftType == 6 则 {
            报告错误(sema, "文本类型不支持直接比较，请使用运行时字符串比较函数", 0)
        }
    }

    /* 返回结果类型 */
    若 op == "+" || op == "-" || op == "*" || op == "/" || op == "%" 则 {
        返回 leftType  /* 算术运算返回左操作数类型 */
    }

    /* 如果左操作数是文本类型，比较结果应该通过运行时函数返回，这里返回整数表示错误 */
    若 leftType < 0 || leftType == 3 || leftType == 6 则 {
        返回 0  /* 返回整数表示类型错误 */
    }

    返回 2  /* 比较和逻辑运算返回布尔类型 */
}

/**
 * 遍历一元表达式
 */
函数 sema遍历一元表达式(sema: Sema, op: 文本, operand: AST节点): 整数 {
    定义 可变 operandType: 整数
    operandType = sema遍历表达式(sema, operand)

    若 op == "!" 则 {
        返回 2  /* 逻辑非返回布尔类型 */
    }

    返回 operandType  /* 其他一元运算保持原类型 */
}

/**
 * 遍历函数调用
 */
函数 sema遍历函数调用(sema: Sema, funcName: 文本, args: AST节点): 整数 {
    打印("分析函数调用: ")
    打印(funcName)

    定义 可变 funcIdx: 整数
    funcIdx = 查找符号(sema, funcName)

    若 funcIdx < 0 则 {
        报告错误(sema, "调用未定义的函数: " + funcName, 0)
        返回 -1
    }

    /* 分析参数 */
    定义 可变 i: 整数
    i = 0
    当 i < 列表长度(args.children) && i < 10 则 {
        定义 可变 arg: AST节点
        arg = args.children[i]
        定义 可变 argType: 整数
        argType = sema遍历表达式(sema, arg)
        i = i + 1
    }

    /* 推断返回类型 */
    定义 可变 returnType: 整数
    returnType = 推断函数返回类型(funcName, args.children)

    返回 returnType
}

/**
 * 注册内置函数
 */
函数 注册内置函数(sema: Sema): 无返回 {
    打印("注册内置函数...")

    定义 可变 result: 整数
    result = 添加符号(sema, "打印", 5, 0)
    result = 添加符号(sema, "打印整数", 5, 0)
    result = 添加符号(sema, "输入整数", 0, 0)
    result = 添加符号(sema, "输入文本", 3, 0)
    result = 添加符号(sema, "文本长度", 0, 0)
    result = 添加符号(sema, "列表长度", 0, 0)
    result = 添加符号(sema, "整数转文本", 3, 0)
    result = 添加符号(sema, "文本转整数", 0, 0)
}

/* ============ 语义分析函数 ============ */

/**
 * 分析变量定义
 */
函数 分析变量定义(sema: Sema, 名称: 文本, 类型: 整数): 整数 {
    打印("分析变量定义: ")
    打印(名称)

    // 检查是否已定义
    定义 可变 existing: 整数
    existing = 查找符号(sema, 名称)

    若 existing >= 0 则 {
        打印("错误: 变量 ")
        打印(名称)
        打印(" 已定义")
        返回 -1
    }

    // 添加符号
    定义 可变 result: 整数
    result = 添加符号(sema, 名称, 类型, 0)

    返回 result
}

/**
 * 分析函数调用
 */
函数 分析函数调用(sema: Sema, 函数名: 文本, 参数个数: 整数): 整数 {
    打印("分析函数调用: ")
    打印(函数名)
    打印(" (参数个数=")
    打印(参数个数)
    打印(")")

    // 检查函数是否定义
    定义 可变 funcIdx: 整数
    funcIdx = 查找符号(sema, 函数名)

    若 funcIdx < 0 则 {
        报告错误(sema, "函数未定义: " + 函数名, 0)
        返回 -1
    }

    返回 0
}

/**
 * 分析二元表达式
 */
函数 分析二元表达式(sema: Sema, 左类型: 整数, 右类型: 整数, 运算符: 文本): 整数 {
    打印("分析二元表达式: ")
    打印(运算符)

    // 检查类型兼容
    若 类型兼容(左类型, 右类型) == 0 则 {
        打印("警告: 类型不匹配")
    }

    // 算术运算返回整数
    若 运算符 == "+" || 运算符 == "-" || 运算符 == "*" || 运算符 == "/" || 运算符 == "%" 则 {
        若 左类型 == 1 || 右类型 == 1 则 {
            返回 1 // 浮点运算返回浮点
        }
        返回 0 // 整数运算返回整数
    }

    // 比较运算返回布尔
    若 运算符 == "==" || 运算符 == "!=" || 运算符 == "<" || 运算符 == ">" || 运算符 == "<=" || 运算符 == ">=" 则 {
        返回 2 // 布尔类型
    }

    // 逻辑运算返回布尔
    若 运算符 == "&&" || 运算符 == "||" 则 {
        若 左类型 != 2 || 右类型 != 2 则 {
            报告警告(sema, "逻辑运算需要布尔操作数", 0)
        }
        返回 2
    }

    返回 0
}

/**
 * 分析一元表达式
 */
函数 分析一元表达式(sema: Sema, 操作数类型: 整数, 运算符: 文本): 整数 {
    打印("分析一元表达式: ")
    打印(运算符)

    // 负号运算符
    若 运算符 == "-" 则 {
        若 操作数类型 == 2 则 {
            报告警告(sema, "布尔类型取负无意义", 0)
        }
        返回 操作数类型
    }

    // 逻辑非
    若 运算符 == "!" 则 {
        若 操作数类型 != 2 则 {
            报告警告(sema, "逻辑非需要布尔操作数", 0)
        }
        返回 2
    }

    返回 操作数类型
}

/**
 * 分析 if 语句
 */
函数 分析If语句(sema: Sema, 条件类型: 整数): 整数 {
    打印("分析 if 语句")

    // 条件必须是布尔类型
    若 条件类型 != 2 则 {
        打印("警告: if 条件应为布尔类型")
    }

    返回 0
}

/**
 * 分析 while 语句
 */
函数 分析While语句(sema: Sema, 条件类型: 整数): 整数 {
    打印("分析 while 语句")

    // 条件必须是布尔类型
    若 条件类型 != 2 则 {
        打印("警告: while 条件应为布尔类型")
    }

    返回 0
}

/**
 * 分析 for 语句
 */
函数 分析For语句(sema: Sema, 起始类型: 整数, 结束类型: 整数): 整数 {
    打印("分析 for 语句")

    若 起始类型 != 0 && 起始类型 != 1 则 {
        报告警告(sema, "for 循环起始值应为数值类型", 0)
    }

    若 结束类型 != 0 && 结束类型 != 1 则 {
        报告警告(sema, "for 循环结束值应为数值类型", 0)
    }

    返回 0
}

/**
 * 分析赋值表达式
 */
函数 分析赋值表达式(sema: Sema, 目标类型: 整数, 源类型: 整数): 整数 {
    打印("分析赋值表达式")

    // 检查类型兼容性
    若 检查赋值兼容性(目标类型, 源类型) == 0 则 {
        报告错误(sema, "赋值类型不匹配", 0)
        返回 -1
    }

    返回 0
}

/**
 * 分析 return 语句
 */
函数 分析返回语句(sema: Sema, 返回类型: 整数, 表达式类型: 整数): 整数 {
    打印("分析 return 语句")

    若 返回类型 == 5 则 {
        // void 函数
        若 表达式类型 != 5 && 表达式类型 >= 0 则 {
            报告警告(sema, "void 函数不应有返回值", 0)
        }
        返回 0
    }

    若 表达式类型 < 0 则 {
        报告错误(sema, "return 语句缺少表达式", 0)
        返回 -1
    }

    若 检查赋值兼容性(返回类型, 表达式类型) == 0 则 {
        报告错误(sema, "返回值类型不匹配", 0)
        返回 -1
    }

    返回 0
}

/**
 * 分析 break 语句上下文
 */
函数 分析Break语句(sema: Sema, 在循环中: 整数): 整数 {
    若 在循环中 == 0 则 {
        报告错误(sema, "break 语句只能在循环中使用", 0)
        返回 -1
    }
    返回 0
}

/**
 * 分析 continue 语句上下文
 */
函数 分析Continue语句(sema: Sema, 在循环中: 整数): 整数 {
    若 在循环中 == 0 则 {
        报告错误(sema, "continue 语句只能在循环中使用", 0)
        返回 -1
    }
    返回 0
}

/**
 * 分析函数定义
 */
函数 分析函数定义(sema: Sema, 函数名: 文本, 返回类型: 整数, 参数个数: 整数): 整数 {
    打印("分析函数定义: ")
