    existing = 查找符号(sema, 函数名)

    若 existing >= 0 则 {
        报告错误(sema, "函数已定义: " + 函数名, 0)
        返回 -1
    }

    // 添加函数符号
    定义 可变 result: 整数
    result = 添加符号(sema, 函数名, 返回类型, 0)

    返回 result
}

