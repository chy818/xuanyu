 */
函数 是递归函数(funcName: 文本, callGraph: 列表): 整数 {
    若 funcName == "" 则 { 返回 0 }
    打印("检查递归: " + funcName)
    返回 0
}

/**
 * 检查函数是否为尾递归
 */
函数 是尾递归(funcName: 文本): 整数 {
    若 funcName == "" 则 { 返回 0 }
    打印("检查尾递归: " + funcName)
    返回 0
}

/**
 * 分析函数调用图
 */
函数 分析调用图(funcList: 列表): 列表 {
    定义 可变 callGraph: 列表
    callGraph = 列表()
    打印("分析调用图...")
    返回 callGraph
}

/**
 * 检查变量初始化状态
 */
函数 检查变量初始化(sema: Sema, varName: 文本): 整数 {
    定义 可变 idx: 整数
    idx = 查找符号(sema, varName)

    若 idx < 0 则 {
        报告警告(sema, "变量未定义: " + varName, 0)
        返回 0
    }

    打印("变量已初始化: " + varName)
    返回 1
}

/**
 * 检查类型是否为基础类型
 */
函数 是基础类型(typeName: 文本): 整数 {
    若 typeName == "整数" 则 { 返回 1 }
    若 typeName == "浮点数" 则 { 返回 1 }
    若 typeName == "布尔" 则 { 返回 1 }
    若 typeName == "文本" 则 { 返回 1 }
    若 typeName == "字符" 则 { 返回 1 }
    若 typeName == "无返回" 则 { 返回 1 }
    返回 0
}

/**
 * 检查类型是否为聚合类型
 */
函数 是聚合类型(typeName: 文本): 整数 {
    若 typeName == "列表" 则 { 返回 1 }
    若 typeName == "结构体" 则 { 返回 1 }
    若 typeName == "枚举" 则 { 返回 1 }
    若 typeName == "字典" 则 { 返回 1 }
    返回 0
}

/**
 * 检查函数参数数量
 */
函数 检查参数数量(funcName: 文本, expected: 整数, actual: 整数): 整数 {
    若 expected != actual 则 {
        打印("警告: 函数 " + funcName + " 参数数量不匹配，期望 " + 整数转文本(expected) + "，实际 " + 整数转文本(actual))
        返回 0
    }
    返回 1
}

/**
 * 检查函数返回值
 */
函数 检查函数返回值(funcName: 文本, returnType: 整数, hasReturn: 整数): 整数 {
    若 returnType != 5 && hasReturn == 0 则 {
        打印("警告: 函数 " + funcName + " 应该有返回值")
        返回 0
    }
    返回 1
}

/**
 * 检查 break 语句是否在循环中
 */
函数 检查Break语句上下文(sema: Sema): 整数 {
    打印("检查 break 语句上下文...")
    返回 1
}

/**
 * 检查 continue 语句是否在循环中
 */
函数 检查Continue语句上下文(sema: Sema): 整数 {
    打印("检查 continue 语句上下文...")
    返回 1
}

/**
 * 分析循环复杂度
 */
函数 分析循环复杂度(nodeCount: 整数): 整数 {
    若 nodeCount > 500 则 {
        打印("警告: 循环复杂度较高")
        返回 2
    }
    若 nodeCount > 200 则 {
        返回 1
    }
    返回 0
}

/**
 * 分析分支预测提示
 */
函数 分析分支预测(condFreq: 浮点数): 文本 {
    若 condFreq > 0.9 则 { 返回 "likely_taken" }
    若 condFreq < 0.1 则 { 返回 "unlikely_taken" }
    返回 "unpredictable"
}

/**
 * 检查内存分配大小
 */
函数 检查内存分配大小(size: 整数): 整数 {
    若 size <= 0 则 {
        打印("错误: 内存分配大小必须为正数")
        返回 -1
    }
    若 size > 1073741824 则 {
        打印("警告: 内存分配大小超过 1GB")
        返回 1
    }
    返回 0
}

/**
 * 检查指针运算有效性
 */
函数 检查指针运算(ptrType: 整数, offset: 整数): 整数 {
    若 ptrType != 6 && ptrType != 3 则 {
        打印("错误: 非指针类型不能进行指针运算")
        返回 0
    }
    返回 1
}

/**
 * 检查函数类型兼容性
 */
函数 检查函数类型兼容性(signature1: 文本, signature2: 文本): 整数 {
    若 signature1 == signature2 则 { 返回 1 }
    打印("警告: 函数类型签名不匹配")
    返回 0
}

/**
 * 检查结构体字段访问
 */
函数 检查结构体字段访问(structName: 文本, fieldName: 文本): 整数 {
    若 structName == "" || fieldName == "" 则 {
        返回 0
    }
    打印("检查结构体字段: " + structName + "." + fieldName)
    返回 1
}

/**
 * 获取默认类型值
 */
函数 获取默认值(typeName: 整数): 文本 {
    若 typeName == 0 则 { 返回 "0" }
    若 typeName == 1 则 { 返回 "0.0" }
    若 typeName == 2 则 { 返回 "假" }
    若 typeName == 3 则 { 返回 "\"\"" }
    若 typeName == 4 则 { 返回 "'\\0'" }
    返回 "null"
}

/**
 * 检查整数溢出
 */
函数 检查整数溢出(op: 文本, left: 整数, right: 整数): 整数 {
    若 op == "+" 则 {
        若 left > 0 && right > 0 && left > 9223372036854775807 - right 则 {
            打印("警告: 整数加法可能溢出")
            返回 1
        }
    }
    若 op == "*" 则 {
        若 left != 0 && right > 9223372036854775807 / left 则 {
            打印("警告: 整数乘法可能溢出")
            返回 1
        }
    }
    返回 0
}

/**
 * 初始化语义分析器
 */
函数 semaInit(源码: 文本): Sema {
    定义 可变 sema: Sema
    sema.源码 = 源码
    sema.当前作用域 = -1
    sema.作用域栈 = 列表()
    sema.错误列表 = 列表()
    sema.警告列表 = 列表()
    sema.当前行号 = 1
    sema.错误计数 = 0
    sema.警告计数 = 0
    sema.全局作用域 = -1
    sema.当前函数名 = ""
    sema.当前函数返回类型 = -1
    
    /* 初始化循环状态 */
    sema.循环状态.激活 = 0
    sema.循环状态.循环层级 = 0
    
    /* 创建全局作用域 */
    定义 可变 globalScopeIdx: 整数
    globalScopeIdx = 创建作用域(sema, "全局")
    sema.全局作用域 = globalScopeIdx
    
    /* 注册内置函数 */
    注册内置函数(sema)
    
    返回 sema
}

/**
 * 运行语义分析（完整版本，接受 AST 根节点）
 */
函数 sema分析AST(sema: Sema, ast: AST节点): 整数 {
    打印("=== 开始语义分析 ===")
    
    sema.错误计数 = 0
    sema.警告计数 = 0
    
    定义 可变 errorCount: 整数
    errorCount = sema遍历AST(sema, ast)
    
    打印("=== 语义分析完成 ===")
    打印("错误数: ")
    打印(sema.错误计数)
    打印("警告数: ")
    打印(sema.警告计数)
    
    返回 errorCount
}

/**
 * 打印符号表（调试用）
 */
函数 打印符号表(sema: Sema): 无返回 {
    打印("=== 符号表 ===")
    
    定义 可变 i: 整数
    i = 0
    当 i < 列表长度(sema.作用域栈) 则 {
        定义 可变 scope: 作用域
        scope = 列表获取(sema.作用域栈, i)
        
        打印("作用域 ")
        打印(i)
        打印(": ")
        打印(scope.名称)
        打印(" (层级=")
        打印(scope.层级)
        打印(")")
        
        定义 可变 j: 整数
        j = 0
        当 j < 列表长度(scope.符号表) 则 {
            定义 可变 sym: 符号
            sym = 列表获取(scope.符号表, j)
            打印("  符号: ")
            打印(sym.名称)
            打印(" 类型: ")
            打印(类型转文本(sym.类型))
            打印(" 可变: ")
            若 sym.可变 == 1 则 { 打印("是") } 否则 { 打印("否") }
            j = j + 1
        }
        i = i + 1
    }
    打印("=== 符号表结束 ===")
}

/* ============ 测试函数 ============ */

/**
 * 创建简单的测试 AST 用于验证语义分析器
 */
函数 创建测试AST(): AST节点 {
    定义 可变 root: AST节点
    root.kind = 0  /* 程序 */
    root.name = "测试程序"
    root.children = 列表()
    
    /* 创建变量定义 */
    定义 可变 varNode: AST节点
    varNode.kind = 3  /* 变量定义 */
    varNode.name = "x"
    varNode.intValue = 0  /* 整数类型 */
    varNode.line = 1
    varNode.children = 列表()
    
    /* 添加到根节点 */
    列表追加(root.children, varNode)
    
    /* 创建函数定义 */
    定义 可变 funcNode: AST节点
    funcNode.kind = 1  /* 函数定义 */
    funcNode.name = "测试函数"
    funcNode.line = 3
    funcNode.children = 列表()
    
    /* 创建函数体块语句 */
    定义 可变 blockNode: AST节点
    blockNode.kind = 18  /* 块语句 */
    blockNode.line = 4
    blockNode.children = 列表()
    
    /* 添加函数参数和体到函数 */
    列表追加(funcNode.children, blockNode)
    
    /* 添加函数到根节点 */
    列表追加(root.children, funcNode)
    
    返回 root
}

/**
 * 运行语义分析器测试
 */
函数 测试语义分析(): 整数 {
    打印("=== 开始语义分析器测试 ===")
    
    /* 初始化语义分析器 */
    定义 可变 sema: Sema
    sema = semaInit("测试源码")
    
    /* 创建测试 AST */
    定义 可变 testAST: AST节点
    testAST = 创建测试AST()
    
    /* 运行语义分析 */
    定义 可变 errorCount: 整数
    errorCount = sema分析AST(sema, testAST)
    
    /* 打印符号表 */
    打印符号表(sema)
    
    打印("=== 测试完成 ===")
    打印("错误数: ")
    打印(errorCount)
    
    返回 errorCount
}
