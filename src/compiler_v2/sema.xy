/**
 * @file sema.xy
 * @brief 语义分析器 - 自展编译器
 * @description 作用域管理、类型检查、标识符解析、错误报告
 */



/* ============ AST 节点类型 (与 parser.xy 一致) ============ */

枚举 AST节点类型 {
    程序 = 0,
    函数定义 = 1,
    参数列表 = 2,
    变量定义 = 3,
    赋值语句 = 4,
    if语句 = 5,
    while语句 = 6,
    循环语句 = 7,
    返回语句 = 8,
    表达式语句 = 9,
    二元表达式 = 10,
    一元表达式 = 11,
    调用表达式 = 12,
    标识符表达式 = 13,
    字面量表达式 = 14,
    类型转换 = 15,
    break语句 = 16,
    continue语句 = 17,
    块语句 = 18,
    赋值表达式 = 19,
    for循环 = 20,
    结构体定义 = 21,
    枚举定义 = 22,
    结构体字段 = 23,
    枚举成员 = 24,
    match语句 = 25,
    match分支 = 26,
    match默认分支 = 27,
    导入语句 = 28,
    模块定义 = 29,
    外部声明 = 30
}

/* ============ AST 节点结构体 ============ */

结构体 AST节点 {
    id: 整数,
    kind: 整数,
    name: 文本,
    value: 文本,
    intValue: 整数,
    line: 整数,
    children: 列表
}

/* ============ 类型定义 ============ */

/**
 * 基本类型枚举
 */
枚举 类型别名 {
    整数类型 = 0,     // i64
    浮点类型 = 1,     // double
    布尔类型 = 2,     // i1
    文本类型 = 3,     // i8*
    字符类型 = 4,     // i8
    无返回类型 = 5,   // void
    指针类型 = 6,     // i8*
    列表类型 = 7,     // 列表
    未知类型 = 8      // 未解析
}

/* ============ 循环状态管理 ============ */

/**
 * 循环状态 - 用于管理 break/continue 语句的上下文
 */
结构体 循环状态 {
    激活: 整数,          // 是否在循环中
    循环层级: 整数       // 嵌套循环层级
}

/* ============ 符号表条目 ============ */

结构体 符号 {
    名称: 文本,
    类型: 整数,
    可变: 整数,
    行号: 整数,
    作用域层级: 整数,
    已初始化: 整数
}

/* ============ 作用域结构 ============ */

结构体 作用域 {
    名称: 文本,
    符号表: 列表,    // 符号列表
    父作用域: 整数,  // 父作用域索引（-1 表示无父作用域）
    层级: 整数       // 作用域层级
}

/* ============ Sema 状态 ============ */

结构体 Sema {
    源码: 文本,
    当前作用域: 整数,    // 当前作用域索引
    作用域栈: 列表,      // 作用域列表
    错误列表: 列表,       // 错误消息列表
    警告列表: 列表,       // 警告消息列表
    当前行号: 整数,
    错误计数: 整数,
    警告计数: 整数,
    全局作用域: 整数,     // 全局作用域索引
    循环状态: 循环状态,   // 循环状态管理
    当前函数名: 文本,     // 当前正在分析的函数名
    当前函数返回类型: 整数 // 当前函数的返回类型
}

/* ============ 作用域操作 ============ */

/**
 * 创建新的作用域
 */
函数 创建作用域(sema: Sema, 名称: 文本): 整数 {
    定义 可变 scope: 作用域
    scope.名称 = 名称
    scope.符号表 = 列表()
    scope.层级 = 列表长度(sema.作用域栈)
    
    若 列表长度(sema.作用域栈) > 0 则 {
        scope.父作用域 = sema.当前作用域
    } 否则 {
        scope.父作用域 = -1
    }

    定义 可变 idx: 整数
    idx = 列表长度(sema.作用域栈)
    
    /* 将新作用域添加到作用域栈 */
    列表追加(sema.作用域栈, scope)

    sema.当前作用域 = idx

    返回 idx
}

/**
 * 退出当前作用域
 */
函数 退出作用域(sema: Sema): 整数 {
    定义 可变 prevScope: 整数
    prevScope = -1

    若 列表长度(sema.作用域栈) > 0 则 {
        定义 可变 currentScope: 作用域
        currentScope = sema.作用域栈[sema.当前作用域]
        prevScope = currentScope.父作用域
    }

    若 prevScope >= 0 则 {
        sema.当前作用域 = prevScope
    }

    返回 prevScope
}

/* ============ 符号操作 ============ */

/**
 * 查找符号（从当前作用域向上查找）
 */
函数 查找符号(sema: Sema, 名称: 文本): 整数 {
    定义 可变 scopeIdx: 整数
    scopeIdx = sema.当前作用域

    定义 可变 result: 整数
    result = -1  // 未找到

    当 scopeIdx >= 0 && scopeIdx < 列表长度(sema.作用域栈) 则 {
        定义 可变 scope: 作用域
        scope = sema.作用域栈[scopeIdx]

        定义 可变 i: 整数
        i = 0
        当 i < 列表长度(scope.符号表) 则 {
            定义 可变 sym: 符号
            sym = scope.符号表[i]
            若 sym.名称 == 名称 则 {
                result = scopeIdx
                返回 result
            }
            i = i + 1
        }

        若 scope.父作用域 < 0 则 {
            返回 -1
        }
        scopeIdx = scope.父作用域
    }

    返回 result
}

/**
 * 获取符号类型
 */
函数 获取符号类型(sema: Sema, 名称: 文本): 整数 {
    定义 可变 scopeIdx: 整数
    scopeIdx = sema.当前作用域

    当 scopeIdx >= 0 && scopeIdx < 列表长度(sema.作用域栈) 则 {
        定义 可变 scope: 作用域
        scope = sema.作用域栈[scopeIdx]

        定义 可变 i: 整数
        i = 0
        当 i < 列表长度(scope.符号表) 则 {
            定义 可变 sym: 符号
            sym = scope.符号表[i]
            若 sym.名称 == 名称 则 {
                返回 sym.类型
            }
            i = i + 1
        }

        若 scope.父作用域 < 0 则 {
            返回 -1
        }
        scopeIdx = scope.父作用域
    }

    返回 -1
}

/**
 * 在当前作用域查找符号（不向上查找父作用域）
 */
函数 在当前作用域查找符号(sema: Sema, 名称: 文本): 整数 {
    若 sema.当前作用域 < 0 || sema.当前作用域 >= 列表长度(sema.作用域栈) 则 {
        返回 -1
    }

    定义 可变 scope: 作用域
    scope = sema.作用域栈[sema.当前作用域]

    定义 可变 i: 整数
    i = 0
    当 i < 列表长度(scope.符号表) 则 {
        定义 可变 sym: 符号
        sym = scope.符号表[i]
        若 sym.名称 == 名称 则 {
            返回 i
        }
        i = i + 1
    }

    返回 -1
}

/**
 * 添加符号到当前作用域
 */
函数 添加符号(sema: Sema, 名称: 文本, 类型: 整数, 可变: 整数): 整数 {
    // 检查是否已在当前作用域定义
    定义 可变 existingIdx: 整数
    existingIdx = 在当前作用域查找符号(sema, 名称)

    若 existingIdx >= 0 则 {
        报告错误(sema, "符号 '" + 名称 + "' 已在当前作用域定义", sema.当前行号)
        返回 -1
    }

    定义 可变 sym: 符号
    sym.名称 = 名称
    sym.类型 = 类型
    sym.可变 = 可变
    sym.行号 = sema.当前行号
    sym.作用域层级 = sema.当前作用域
    sym.已初始化 = 0

    // 确保当前作用域有效
    若 sema.当前作用域 < 0 || sema.当前作用域 >= 列表长度(sema.作用域栈) 则 {
        创建作用域(sema, "全局")
    }

    // 添加符号到当前作用域
    定义 可变 scope: 作用域
    scope = 列表获取(sema.作用域栈, sema.当前作用域)
    列表追加(scope.符号表, sym)
    
    // 更新作用域栈中的作用域
    // 注意：玄语语言中列表元素是值类型，需要重新赋值
    列表设置(sema.作用域栈, sema.当前作用域, scope)

    返回 0
}

/* ============ 类型检查 ============ */

/**
 * 检查类型是否兼容
 */
函数 类型兼容(type1: 整数, type2: 整数): 整数 {
    // 相同类型兼容
    若 type1 == type2 则 {
        返回 1
    }

    // 整数和浮点可以转换
    若 type1 == 0 && type2 == 1 则 {
        返回 1
    }
    若 type1 == 1 && type2 == 0 则 {
        返回 1
    }

    // 指针和文本类型兼容
    若 type1 == 3 && type2 == 6 则 { 返回 1 }
    若 type1 == 6 && type2 == 3 则 { 返回 1 }

    返回 0
}

/**
 * 获取类型的字符串表示
 */
函数 类型转文本(type: 整数): 文本 {
    若 type == 0 则 { 返回 "整数" }
    若 type == 1 则 { 返回 "浮点数" }
    若 type == 2 则 { 返回 "布尔" }
    若 type == 3 则 { 返回 "文本" }
    若 type == 4 则 { 返回 "字符" }
    若 type == 5 则 { 返回 "无返回" }
    若 type == 6 则 { 返回 "指针" }
    若 type == 7 则 { 返回 "列表" }
    返回 "未知"
}

/**
 * 获取二元运算的结果类型
 */
函数 二元运算结果类型(leftType: 整数, op: 文本, rightType: 整数): 整数 {
    // 算术运算
    若 op == "+" || op == "-" || op == "*" || op == "/" || op == "%" 则 {
        若 leftType == 1 || rightType == 1 则 {
            返回 1  // 浮点运算返回浮点
        }
        返回 0  // 整数运算返回整数
    }

    // 比较运算返回布尔
    若 op == "==" || op == "!=" || op == "<" || op == ">" || op == "<=" || op == ">=" 则 {
        返回 2  // 布尔类型
    }

    // 逻辑运算返回布尔
    若 op == "&&" || op == "||" 则 {
        返回 2  // 布尔类型
    }

    // 位运算返回整数
    若 op == "&" || op == "|" || op == "^" || op == "<<" || op == ">>" 则 {
        返回 0
    }

    返回 0
}

/**
 * 检查类型是否有效
 */
函数 是有效类型(type: 整数): 整数 {
    若 type >= 0 && type <= 8 则 {
        返回 1
    }
    返回 0
}

/* ============ 错误报告 ============ */

/**
 * 报告错误
 */
函数 报告错误(sema: Sema, 消息: 文本, 行号: 整数): 整数 {
    sema.错误计数 = sema.错误计数 + 1
    
    打印("[错误]")
    若 行号 > 0 则 {
        打印(" (行")
        打印(行号)
        打印(")")
    }
    打印(": ")
    打印(消息)
    
    返回 -1
}

/**
 * 报告警告
 */
函数 报告警告(sema: Sema, 消息: 文本, 行号: 整数): 整数 {
    sema.警告计数 = sema.警告计数 + 1
    
    打印("[警告]")
    若 行号 > 0 则 {
        打印(" (行")
        打印(行号)
        打印(")")
    }
    打印(": ")
    打印(消息)
    
    返回 0
}

/**
 * 报告详细错误（包含更多信息）
 */
函数 报告详细错误(sema: Sema, 消息: 文本, 行号: 整数, 列号: 整数, 建议: 文本): 整数 {
    sema.错误计数 = sema.错误计数 + 1
    
    打印("━━━━━━━━━━━━━━━━━━━━━━━━")
    打印("[错误]")
    若 行号 > 0 则 {
        打印(" 位置: 第")
        打印(行号)
        打印("行")
        若 列号 > 0 则 {
            打印(", 第")
            打印(列号)
            打印("列")
        }
    }
    打印("")
    打印("  信息: " + 消息)
    若 建议 != "" 则 {
        打印("  建议: " + 建议)
    }
    打印("━━━━━━━━━━━━━━━━━━━━━━━━")
    
    返回 -1
}

/**
 * 获取错误统计信息
 */
函数 获取错误统计(sema: Sema): 文本 {
    定义 可变 result: 文本
    result = "错误: "
    result = result + 整数转文本(sema.错误计数)
    result = result + ", 警告: "
    result = result + 整数转文本(sema.警告计数)
    返回 result
}

/* ============ 类型推导 ============ */

/**
 * 推断表达式的类型
 */
函数 推断表达式类型(exprKind: 整数): 整数 {
    // 字面量表达式
    若 exprKind == 14 则 {
        返回 0  // 整数
    }

    // 标识符表达式
    若 exprKind == 13 则 {
        返回 0  // 整数（简化）
    }

    // 调用表达式
    若 exprKind == 12 则 {
        返回 0  // 整数（简化）
    }

    // 二元表达式
    若 exprKind == 10 则 {
        返回 0  // 整数（简化）
    }

    // 一元表达式
    若 exprKind == 11 则 {
        返回 0  // 整数（简化）
    }

    // 赋值表达式
    若 exprKind == 19 则 {
        返回 0  // 整数（简化）
    }

    // 下标访问
    若 exprKind == 20 则 {
        返回 0  // 返回元素类型
    }

    // 字段访问
    若 exprKind == 21 则 {
        返回 0  // 返回字段类型
    }

    返回 0
}

/**
 * 推断二元运算的结果类型
 */
函数 推断二元类型(左: 整数, op: 文本, 右: 整数): 整数 {
    // 算术运算
    若 op == "+" || op == "-" || op == "*" || op == "/" || op == "%" 则 {
        若 左 == 1 || 右 == 1 则 {
            返回 1  // 浮点
        }
        若 左 == 3 || 右 == 3 则 {
            返回 3  // 文本（字符串连接）
        }
        返回 0  // 整数
    }

    // 比较和逻辑运算
    若 op == "==" || op == "!=" || op == "<" || op == ">" || op == "<=" || op == ">=" 则 {
        返回 2  // 布尔
    }

    // 逻辑运算
    若 op == "&&" || op == "||" 则 {
        返回 2  // 布尔
    }

    // 位运算
    若 op == "&" || op == "|" || op == "^" || op == "<<" || op == ">>" 则 {
        返回 0  // 整数
    }

    返回 0
}

/**
 * 检查赋值类型是否兼容
 */
函数 检查赋值兼容性(目标类型: 整数, 源类型: 整数): 整数 {
    // 相同类型
    若 目标类型 == 源类型 则 {
        返回 1
    }

    // 整数和浮点可以互相赋值
    若 (目标类型 == 0 && 源类型 == 1) || (目标类型 == 1 && 源类型 == 0) 则 {
        返回 1
    }

    // 文本和指针可以兼容
    若 (目标类型 == 3 && 源类型 == 6) || (目标类型 == 6 && 源类型 == 3) 则 {
        返回 1
    }

    返回 0
}

/**
 * 推断函数返回类型
 */
函数 推断函数返回类型(funcName: 文本, paramTypes: 列表): 整数 {
    打印("推断函数返回类型: ")
    打印(funcName)

    // 内置函数映射
    若 funcName == "打印" || funcName == "打印整数" 则 {
        返回 5  // void
    }
    若 funcName == "输入整数" 则 {
        返回 0  // 整数
    }
    若 funcName == "输入浮点数" 则 {
        返回 1  // 浮点数
    }
    若 funcName == "输入文本" 则 {
        返回 3  // 文本
    }
    若 funcName == "输入字符" 则 {
        返回 4  // 字符
    }
    若 funcName == "文本长度" || funcName == "列表长度" 则 {
        返回 0  // 整数
    }

    // 默认返回整数
    返回 0
}

/**
 * 推断列表字面量类型
 */
函数 推断列表类型(elementTypes: 列表): 整数 {
    若 列表长度(elementTypes) == 0 则 {
        返回 7  // 空列表
    }

    定义 可变 firstType: 整数
    firstType = elementTypes[0]

    // 检查所有元素类型是否一致
    定义 可变 i: 整数
    i = 1
    当 i < 列表长度(elementTypes) 则 {
        若 elementTypes[i] != firstType 则 {
            返回 0  // 类型不一致，返回基础类型
        }
        i = i + 1
    }

    返回 firstType
}

/**
 * 推断一元运算结果类型
 */
函数 推断一元类型(op: 文本, operandType: 整数): 整数 {
    // 负号
    若 op == "-" 则 {
        若 operandType == 2 则 {
            返回 2  // 布尔取负无意义但返回布尔
        }
        返回 operandType  // 保持原类型
    }

    // 逻辑非
    若 op == "!" 则 {
        返回 2  // 始终返回布尔
    }

    // 位非
    若 op == "~" 则 {
        返回 0  // 始终返回整数
    }

    返回 operandType
}

/**
 * 类型提升规则
 */
函数 类型提升(a: 整数, b: 整数): 整数 {
    // 若任一操作数是浮点，则提升为浮点
    若 a == 1 || b == 1 则 {
        返回 1
    }

    // 否则返回整数
    返回 0
}

/**
 * 推断三目运算类型
 */
函数 推断三目类型(condType: 整数, thenType: 整数, elseType: 整数): 整数 {
    // 条件必须是布尔
    若 condType != 2 则 {
        打印("警告: 三目运算条件应为布尔类型")
    }

    // 两个分支必须兼容
    若 thenType == elseType 则 {
        返回 thenType
    }

    // 应用类型提升规则
    返回 类型提升(thenType, elseType)
}

/**
 * 检查类型是否可转换
 */
函数 是可转换的(fromType: 整数, toType: 整数): 整数 {
    // 相同类型
    若 fromType == toType 则 {
        返回 1
    }

    // 整数和浮点之间可转换
    若 (fromType == 0 || fromType == 1) && (toType == 0 || toType == 1) 则 {
        返回 1
    }

    // 整数可转换为布尔
    若 (fromType == 0 || fromType == 1) && toType == 2 则 {
        返回 1
    }

    // 布尔可转换为整数
    若 fromType == 2 && toType == 0 则 {
        返回 1
    }

    返回 0
}

/**
 * 获取类型的默认宽度（LLVM）
 */
函数 获取类型宽度(typeName: 文本): 整数 {
    若 typeName == "i1" 则 { 返回 1 }
    若 typeName == "i8" 则 { 返回 8 }
    若 typeName == "i16" 则 { 返回 16 }
    若 typeName == "i32" 则 { 返回 32 }
    若 typeName == "i64" 则 { 返回 64 }
    若 typeName == "float" 则 { 返回 32 }
    若 typeName == "double" 则 { 返回 64 }
    返回 64  // 默认64位
}

/**
 * 检查是否为空类型
 */
函数 是空类型(typeIdx: 整数): 整数 {
    若 typeIdx == 5 则 { 返回 1 }  // void
    若 typeIdx == 7 则 { 返回 1 }  // 空列表
    若 typeIdx == 8 则 { 返回 1 }  // 空指针
    返回 0
}

/**
 * 推断下标访问类型
 */
函数 推断下标类型(baseType: 整数, indexType: 整数): 整数 {
    // 下标必须是整数
    若 indexType != 0 则 {
        打印("警告: 下标应为整数类型")
    }

    // 列表返回元素类型
    若 baseType == 7 则 {
        返回 0  // 空列表返回整数
    }

    // 字典返回值类型
    若 baseType == 9 则 {
        返回 0  // 字典返回值类型
    }

    // 字符串返回字符
    若 baseType == 3 则 {
        返回 4  // 字符
    }

    返回 0
}

/**
 * 推断函数调用类型
 */
函数 推断调用类型(funcName: 文本, argTypes: 列表): 整数 {
    定义 可变 argCount: 整数
    argCount = 列表长度(argTypes)

    打印("推断调用类型: ")
    打印(funcName)
    打印(" (参数个数=")
    打印(argCount)
    打印(")")

    // 内置函数映射
    若 funcName == "整数" 则 {
        若 argCount == 1 则 {
            返回 0  // 转整数
        }
    }
    若 funcName == "浮点数" 则 {
        若 argCount == 1 则 {
            返回 1  // 转浮点
        }
    }
    若 funcName == "文本" 则 {
        若 argCount == 1 则 {
            返回 3  // 转文本
        }
    }

    // 默认返回整数
    返回 0
}

/**
 * 检查函数参数类型
 */
函数 检查参数类型(funcName: 文本, paramIdx: 整数, expectedType: 整数, actualType: 整数): 整数 {
    若 expectedType == actualType 则 {
        返回 1
    }

    // 尝试类型转换
    若 是可转换的(actualType, expectedType) == 1 则 {
        返回 1
    }

    打印("警告: 函数 ")
    打印(funcName)
    打印(" 第 ")
    打印(paramIdx)
    打印(" 个参数类型不匹配")
    返回 0
}

/**
 * 推断结构体字段类型
 */
函数 推断字段类型(structName: 文本, fieldName: 文本): 整数 {
    打印("推断字段类型: ")
    打印(structName)
    打印(".")
    打印(fieldName)

    // 默认返回整数
    返回 0
}

/**
 * 类型大小计算
 */
函数 计算类型大小(typeIdx: 整数): 整数 {
    若 typeIdx == 0 则 { 返回 8 }  // 整数 64位
    若 typeIdx == 1 则 { 返回 8 }  // 浮点数 64位
    若 typeIdx == 2 则 { 返回 1 }  // 布尔 8位
    若 typeIdx == 3 则 { 返回 8 }  // 文本指针 64位
    若 typeIdx == 4 则 { 返回 4 }  // 字符 32位
    若 typeIdx == 5 则 { 返回 0 }  // void
    若 typeIdx == 6 则 { 返回 8 }  // 指针 64位
    若 typeIdx == 7 则 { 返回 24 }  // 列表头
    返回 8  // 默认
}

/* ============ 泛型支持框架 ============ */

/**
 * 泛型实例化检查
 */
函数 检查泛型实例化(typeName: 文本, params: 列表): 整数 {
    // 列表类型
    若 typeName == "列表" 则 {
        若 列表长度(params) >= 1 则 {
            返回 1
        }
    }

    // 可选类型
    若 typeName == "可选" 则 {
        若 列表长度(params) >= 1 则 {
            返回 1
        }
    }

    // 结果类型
    若 typeName == "结果" 则 {
        若 列表长度(params) >= 2 则 {
            返回 1
        }
    }

    返回 0
}

/**
 * 获取泛型参数数量
 */
函数 获取泛型参数数量(typeName: 文本): 整数 {
    若 typeName == "列表" 则 { 返回 1 }
    若 typeName == "可选" 则 { 返回 1 }
    若 typeName == "结果" 则 { 返回 2 }
    若 typeName == "字典" 则 { 返回 2 }
    若 typeName == "集合" 则 { 返回 1 }
    返回 0
}

