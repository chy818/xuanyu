    若 nodeKind == 0 则 { 返回 分析标识符(sema, nodeName) }
    若 nodeKind == 2 则 { 返回 分析变量定义(sema, nodeName, 0) }
    若 nodeKind == 3 则 { 返回 分析函数调用(sema, nodeName, 0) }
    若 nodeKind == 5 则 { 返回 分析函数定义(sema, nodeName, 5, 0) }
    若 nodeKind == 10 则 { 返回 分析二元表达式(sema, 0, 0, nodeName) }

    返回 0
}

