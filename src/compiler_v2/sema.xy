/* ============ 主函数 ============ */

/**
 * 执行语义分析
 */
函数 semaRun(astNodeCount: 整数): 整数 {
    打印("=== 语义分析 ===")

    定义 可变 sema: Sema
    sema.源码 = ""
    sema.当前作用域 = 0
    sema.作用域栈 = 列表()
    sema.错误列表 = 列表()
    sema.警告列表 = 列表()
    sema.当前行号 = 1

    // 创建全局作用域
    定义 可变 globalScope: 整数
    globalScope = 创建作用域(sema, "全局")

    // 注册内置函数
    定义 可变 result: 整数
    result = 添加符号(sema, "打印", 5, 0)
    result = 添加符号(sema, "打印整数", 5, 0)
    result = 添加符号(sema, "输入整数", 0, 0)

    打印("语义分析完成，无错误")

    返回 0
}

