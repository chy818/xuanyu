/**
 * @file tests/integration/control_flow_test.xy
 * @brief 控制流集成测试
 */
函数 主() : 整数 {
    打印("=== 控制流测试 ===")
    定义 分数: 整数 = 85
    若 分数 >= 90 则 {
        打印("优秀")
    } 否则若 分数 >= 80 则 {
        打印("良好")
    } 否则 {
        打印("其他")
    }
    定义 sum: 整数 = 0
    定义 i: 整数 = 1
    当 i <= 5 则 {
        sum = sum + i
        i = i + 1
    }
    打印整数(sum)
    返回 0
}
