// 测试嵌套的 若-否则 结构
函数 test(): 整数 {
    定义 x: 整数
    x = 1

    若 x == 1 则 {
        若 x == 2 则 {
            x = 3
        } 否则 {
            若 x == 3 则 {
                x = 4
            } 否则 {
                若 x == 4 则 {
                    x = 5
                } 否则 {
                    若 x == 5 则 {
                        x = 6
                    } 否则 {
                        若 x == 6 则 {
                            x = 7
                        } 否则 {
                            若 x == 7 则 {
                                x = 8
                            } 否则 {
                                x = 9
                            }
                        }
                    }
                }
            }
        }
    }

    返回 x
}

函数 main(): 整数 {
    返回 test()
}
