// 测试程序：创建列表并添加元素
函数 主(): 整数 {
    定义 a = rt_list_new()
    rt_list_append(a, "Hello")
    rt_list_append(a, "Xuan Yu")
    rt_list_append(a, "Compiler")
    
    打印("列表创建成功！")
    打印("列表长度:")
    打印(rt_list_len(a))
    
    // 测试条件判断
    定义 i = 0
    若 i < 5 则 {
        打印("i 小于 5")
    } 否则 {
        打印("i 大于等于 5")
    }
    
    // 测试字符串操作
    打印("测试完成！")
    打印("请按回车键退出...")
    读取行()
    
    返回 0
}
