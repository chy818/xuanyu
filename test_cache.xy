// 测试 CacheOptions 结构体
结构体 CacheOptions {
    启用缓存: 整数,
    缓存目录: 文本,
    最大缓存大小: 整数
}

函数 createCacheOptions(): CacheOptions {
    定义 opts: CacheOptions
    opts.启用缓存 = 0
    opts.缓存目录 = ""
    opts.最大缓存大小 = 1073741824
    返回 opts
}

函数 main(): 整数 {
    定义 opts: CacheOptions
    opts = createCacheOptions()
    返回 0
}
