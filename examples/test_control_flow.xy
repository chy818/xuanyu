/**
 * @file test_control_flow.xy
 * @brief 测试控制流语句
 */

函数 测试若(): 整数 {
    定义 x: 整数 = 10
    定义 结果: 整数 = 0

    若 x > 5 则 {
        结果 = 1
    } 否则 {
        结果 = 0
    }

    返回 结果
}

函数 主(): 整数 {
    定义 total: 整数 = 0

    total = total + 测试若()

    打印("控制流测试完成: ")
    打印整数(total)
    打印("\n")

    返回 0
}
