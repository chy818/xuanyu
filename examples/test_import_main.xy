/**
 * @file test_import_main.xy
 * @brief 测试导入功能的主程序
 */

// 导入测试库
引入 "examples/test_import_lib.xy"

函数 主(): 整数 {
    // 测试加法
    定义 x: 整数 = 10
    定义 y: 整数 = 20
    定义 和: 整数 = 加法(x, y)
    
    打印("x + y = ")
    打印整数(和)
    打印("")
    
    // 测试乘法
    定义 积: 整数 = 乘法(x, y)
    打印("x * y = ")
    打印整数(积)
    打印("")
    
    // 测试字符串函数
    定义 消息: 文本 = 获取问候("世界")
    打印(消息)
    
    返回 0
}
