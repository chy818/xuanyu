/**
 * @file simple_test.xy
 * @brief 简单测试程序 - 验证编译流程
 */

函数 add(a: 整数, b: 整数): 整数 {
    返回 a + b
}

函数 main(): 整数 {
    打印("=== 玄语编译器 v0.2 测试 ===")
    
    定义 x: 整数
    x = 10
    
    定义 y: 整数
    y = 20
    
    定义 result: 整数
    result = add(x, y)
    
    打印("计算结果: 10 + 20 = 30")
    打印("编译流程测试成功!")
    
    返回 0
}
