/**
 * 徐语编译器自举测试程序
 * 测试编译器是否能正确处理所有语言特性
 */

// 测试基本类型
函数 测试_基本类型() : 整数 {
    定义 a: 整数 = 42
    定义 b: 浮点数 = 3.14
    定义 c: 布尔 = 真
    定义 d: 文本 = "你好"
    
    打印("=== 测试基本类型 ===")
    打印("整数: ")
    打印整数(a)
    打印("\n")
    
    打印("浮点数: ")
    打印浮点数(b)
    打印("\n")
    
    打印("布尔: ")
    若 c == 真 则 {
        打印("真")
    } 否则 {
        打印("假")
    }
    打印("\n")
    
    打印("文本: ")
    打印(d)
    打印("\n")
    
    返回 0
}

// 测试运算符
函数 测试_运算符() : 整数 {
    定义 x: 整数 = 10
    定义 y: 整数 = 3
    
    打印("=== 测试运算符 ===")
    
    定义 加: 整数 = x + y
    定义 减: 整数 = x - y
    定义 乘: 整数 = x * y
    定义 除: 整数 = x / y
    定义 余: 整数 = x % y
    
    打印("10 + 3 = ")
    打印整数(加)
    打印("\n")
    
    打印("10 - 3 = ")
    打印整数(减)
    打印("\n")
    
    打印("10 * 3 = ")
    打印整数(乘)
    打印("\n")
    
    打印("10 / 3 = ")
    打印整数(除)
    打印("\n")
    
    打印("10 % 3 = ")
    打印整数(余)
    打印("\n")
    
    返回 0
}

// 测试条件判断
函数 测试_条件判断() : 整数 {
    定义 分数: 整数 = 85
    
    打印("=== 测试条件判断 ===")
    
    若 分数 >= 90 则 {
        打印("优秀")
    } 否则若 分数 >= 80 则 {
        打印("良好")
    } 否则若 分数 >= 60 则 {
        打印("及格")
    } 否则 {
        打印("不及格")
    }
    打印("\n")
    
    返回 0
}

// 测试循环
函数 测试_循环() : 整数 {
    定义 总和: 整数 = 0
    定义 i: 整数 = 1
    
    打印("=== 测试循环 ===")
    
    当 i <= 10 则 {
        总和 = 总和 + i
        i = i + 1
    }
    
    打印("1到10的和: ")
    打印整数(总和)
    打印("\n")
    
    返回 0
}

// 测试函数调用
函数 计算平方(n: 整数) : 整数 {
    返回 n * n
}

函数 测试_函数调用() : 整数 {
    打印("=== 测试函数调用 ===")
    
    定义 结果: 整数 = 计算平方(5)
    打印("5的平方: ")
    打印整数(结果)
    打印("\n")
    
    返回 0
}

// 测试列表
函数 测试_列表() : 整数 {
    打印("=== 测试列表 ===")
    
    定义 我的列表: 列表 = rt_list_new()
    rt_list_append(我的列表, "苹果")
    rt_list_append(我的列表, "香蕉")
    rt_list_append(我的列表, "橙子")
    
    打印("列表长度: ")
    打印整数(rt_list_len(我的列表))
    打印("\n")
    
    打印("第一个元素: ")
    打印(rt_list_get(我的列表, 0))
    打印("\n")
    
    返回 0
}

// 主函数
函数 主() : 整数 {
    打印("========================================")
    打印("徐语编译器自举综合测试")
    打印("========================================")
    打印("")
    
    测试_基本类型()
    打印("")
    
    测试_运算符()
    打印("")
    
    测试_条件判断()
    打印("")
    
    测试_循环()
    打印("")
    
    测试_函数调用()
    打印("")
    
    测试_列表()
    打印("")
    
    打印("========================================")
    打印("所有测试完成!")
    打印("========================================")
    
    返回 0
}
