/**
 * @file test_data_structures.xy
 * @brief 测试数据结构
 */

函数 测试列表(): 整数 {
    定义 list: 列表 = 创建列表()

    列表添加(list, 10)
    列表添加(list, 20)
    列表添加(list, 30)

    定义 len: 整数 = 列表长度(list)

    若 len == 3 则 {
        定义 first: 整数 = 列表获取(list, 0)
        若 first == 10 则 {
            返回 1
        }
    }

    返回 0
}

函数 测试栈操作(): 整数 {
    定义 stack: 列表 = 创建列表()

    列表添加(stack, 1)
    列表添加(stack, 2)
    列表添加(stack, 3)

    定义 len: 整数 = 列表长度(stack)
    若 len == 3 则 {
        返回 1
    }

    返回 0
}

函数 测试队列操作(): 整数 {
    定义 queue: 列表 = 创建列表()

    列表添加(queue, 1)
    列表添加(queue, 2)
    列表添加(queue, 3)

    定义 len: 整数 = 列表长度(queue)
    若 len == 3 则 {
        返回 1
    }

    返回 0
}

函数 主(): 整数 {
    定义 total: 整数 = 0

    total = total + 测试列表()
    total = total + 测试栈操作()
    total = total + 测试队列操作()

    打印("数据结构测试完成: ")
    打印整数(total)
    打印("/3\n")

    返回 0
}
