函数 主() : 整数 {
    打印("Hello, World!\n")
    
    定义 score: 整数 = 85
    打印("Score = ")
    打印整数(score)
    打印("\n")
    
    若 score > 60 则 {
        打印("Pass\n")
    } 否则 {
        打印("Fail\n")
    }
    
    定义 sum: 整数 = 0
    定义 i: 整数 = 1
    当 i <= 10 则 {
        sum = sum + i
        i = i + 1
    }
    打印("Sum 1-10 = ")
    打印整数(sum)
    打印("\n")
    
    返回 0
}