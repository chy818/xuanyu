/**
 * @file test_struct_field.xy
 * @brief 测试结构体字段访问
 */

// 定义结构体
结构体 Token {
    名称: 文本,
    内容: 文本,
    行号: 整数,
    列号: 整数,
}

函数 主 函数(): 整数 {
  定义 token: Token
  token.名称 = "标识符"
  token.内容 = "主"
  token.行号 = 1
  token.列号 = 1
  
  // 访问字段
  定义 类型名: 文本
  类型名 = token.名称
  
  打印("Token名称: ")
  打印(类型名)
  
  打印("Token行号: ")
  打印整数(token.行号)
  
  返回 0
}
