/**
 * @file test_recursion.xy
 * @brief 测试递归
 */

函数 阶乘(n: 整数): 整数 {
    若 n <= 1 则 {
        返回 1
    }
    返回 n * 阶乘(n - 1)
}

函数 main(): 整数 {
    定义 result: 整数 = 阶乘(5)

    打印("阶乘(5) = ")
    打印整数(result)
    打印("\n")

    若 result == 120 则 {
        打印("递归测试通过!\n")
        返回 0
    }
    打印("递归测试失败!\n")
    返回 1
}
