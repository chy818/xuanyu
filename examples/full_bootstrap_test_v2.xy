/**
 * 徐语编译器自举测试程序 v2
 * 使用编译器完全支持的语言特性
 */

函数 主() : 整数 {
    打印("========================================")
    打印("徐语编译器自举综合测试 v2")
    打印("========================================")
    打印("")
    
    定义 整数测试: 整数 = 42
    打印("=== 测试整数 ===")
    打印("整数: ")
    打印整数(整数测试)
    打印("\n")
    
    定义 x: 整数 = 10
    定义 y: 整数 = 3
    
    打印("=== 测试运算符 ===")
    定义 加: 整数 = x + y
    定义 减: 整数 = x - y
    定义 乘: 整数 = x * y
    定义 除: 整数 = x / y
    定义 余: 整数 = x % y
    
    打印("10 + 3 = ")
    打印整数(加)
    打印("\n")
    
    打印("10 - 3 = ")
    打印整数(减)
    打印("\n")
    
    打印("10 * 3 = ")
    打印整数(乘)
    打印("\n")
    
    打印("10 / 3 = ")
    打印整数(除)
    打印("\n")
    
    打印("10 % 3 = ")
    打印整数(余)
    打印("\n")
    
    定义 分数: 整数 = 85
    打印("=== 测试条件判断 ===")
    
    若 分数 >= 90 则 {
        打印("优秀")
    } 否则 {
        若 分数 >= 80 则 {
            打印("良好")
        } 否则 {
            若 分数 >= 60 则 {
                打印("及格")
            } 否则 {
                打印("不及格")
            }
        }
    }
    打印("\n")
    
    定义 总和: 整数 = 0
    定义 i: 整数 = 1
    打印("=== 测试循环 ===")
    
    当 i <= 10 则 {
        总和 = 总和 + i
        i = i + 1
    }
    
    打印("1到10的和: ")
    打印整数(总和)
    打印("\n")
    
    定义 我的列表: 列表 = rt_list_new()
    rt_list_append(我的列表, "苹果")
    rt_list_append(我的列表, "香蕉")
    rt_list_append(我的列表, "橙子")
    
    打印("=== 测试列表 ===")
    打印("列表长度: ")
    打印整数(rt_list_len(我的列表))
    打印("\n")
    
    打印("========================================")
    打印("所有测试完成!")
    打印("========================================")
    
    返回 0
}
