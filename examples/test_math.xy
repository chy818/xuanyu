/**
 * @file test_math.xy
 * @brief 测试数学运算
 */

函数 测试算术运算(): 整数 {
    定义 a: 整数 = 10
    定义 b: 整数 = 3

    定义 sum: 整数 = a + b
    定义 diff: 整数 = a - b
    定义 prod: 整数 = a * b
    定义 quot: 整数 = a / b
    定义 rem: 整数 = a % b

    若 sum == 13 && diff == 7 && prod == 30 && quot == 3 && rem == 1 则 {
        返回 1
    }
    返回 0
}

函数 测试比较运算(): 整数 {
    定义 a: 整数 = 10
    定义 b: 整数 = 20

    若 a < b && b > a && a <= 10 && b >= 20 则 {
        若 a == 10 && b != 15 则 {
            返回 1
        }
    }
    返回 0
}

函数 测试逻辑运算(): 整数 {
    若 真 && 真 则 {
        若 真 || 假 则 {
            若 假 == 假 则 {
                返回 1
            }
        }
    }
    返回 0
}

函数 主(): 整数 {
    定义 total: 整数 = 0

    total = total + 测试算术运算()
    total = total + 测试比较运算()
    total = total + 测试逻辑运算()

    打印("数学运算测试完成: ")
    打印整数(total)
    打印("/3\n")

    返回 0
}
