/**
 * @file evaluator.xy
 * @brief 表达式求值器 - 自举用例
 * @description 使用枚举和模式匹配实现算术表达式求值器
 *              这是 XY 语言自举的"第一口奶"
 */

// 定义表达式枚举类型
枚举 表达式 {
    // 数字字面量
    数字,
    // 一元负号
    负号,
    // 二元运算
    加法,
    减法,
    乘法,
    除法,
}

/**
 * 主函数 - 测试表达式求值
 */
函数 主 函数(): 整数 {
    // 测试枚举变体（不带成员访问）
    定义 e = 数字
    打印("测试枚举")

    // 创建带字段的表达式（简化处理）
    定义 n = 1
    打印("求值测试")

    返回 0
}
