/**
 * @file test_error.xy
 * @brief 测试错误处理
 * 测试编译器是否能正确检测和报告错误
 */

函数 测试除零(): 整数 {
    定义 x: 整数 = 10
    定义 y: 整数 = 0
    定义 result: 整数 = x / y

    返回 result
}

函数 测试空指针(): 整数 {
    定义 s: 文本 = ""
    定义 len: 整数 = 文本长度(s)

    若 len == 0 则 {
        返回 1
    }
    返回 0
}

函数 main(): 整数 {
    定义 total: 整数 = 0

    total = total + 测试空指针()

    打印("错误处理测试完成: ")
    打印整数(total)
    打印("/1\n")

    返回 0
}
