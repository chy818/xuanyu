// 测试 parser.xy 的前半部分 (第1-400行)
枚举 TokenType {
    标识符 = 0,
    数字 = 1,
    字符串 = 2,
    关键字 = 3,
    运算符 = 4,
    符号 = 5,
    结束 = 6,
    注释 = 7
}

枚举 AST节点类型 {
    程序 = 0,
    函数定义 = 1,
    参数列表 = 2,
    变量定义 = 3,
    赋值语句 = 4,
    if语句 = 5,
    while语句 = 6,
    循环语句 = 7,
    返回语句 = 8,
    表达式语句 = 9,
    二元表达式 = 10,
    一元表达式 = 11,
    调用表达式 = 12,
    标识符表达式 = 13,
    字面量表达式 = 14,
    类型转换 = 15,
    break语句 = 16,
    continue语句 = 17,
    块语句 = 18,
    赋值表达式 = 19,
    for循环 = 20,
    结构体定义 = 21,
    枚举定义 = 22,
    结构体字段 = 23,
    枚举成员 = 24,
    match语句 = 25,
    match分支 = 26,
    match默认分支 = 27,
    导入语句 = 28,
    模块定义 = 29
}

定义 类型 NodeId = 整数
定义 类型 NodeCounter = 整数

结构体 AST节点 {
    id: 整数,
    kind: 整数,
    name: 文本,
    value: 文本,
    intValue: 整数,
    line: 整数,
    children: 整数
}

结构体 Token {
    类型: 整数,
    值: 文本,
    行号: 整数,
    列号: 整数,
    开始位置: 整数,
    结束位置: 整数
}

结构体 Parser {
    tokens: 列表,
    pos: 整数,
    errors: 列表,
    nodeCount: 整数,
    tokenCount: 整数
}

函数 是关键字(text: 文本): 整数 {
    若 text == "若" 则 { 返回 1 }
    若 text == "则" 则 { 返回 1 }
    若 text == "否则" 则 { 返回 1 }
    若 text == "当" 则 { 返回 1 }
    若 text == "循环" 则 { 返回 1 }
    若 text == "从" 则 { 返回 1 }
    若 text == "到" 则 { 返回 1 }
    若 text == "返回" 则 { 返回 1 }
    若 text == "定义" 则 { 返回 1 }
    若 text == "可变" 则 { 返回 1 }
    若 text == "函数" 则 { 返回 1 }
    若 text == "结构体" 则 { 返回 1 }
    若 text == "枚举" 则 { 返回 1 }
    若 text == "真" 则 { 返回 1 }
    若 text == "假" 则 { 返回 1 }
    若 text == "跳过" 则 { 返回 1 }
    若 text == "退出" 则 { 返回 1 }
    若 text == "引入" 则 { 返回 1 }
    若 text == "模块" 则 { 返回 1 }
    若 text == "导出" 则 { 返回 1 }
    返回 0
}

函数 getKeywordType(text: 文本): 整数 {
    若 text == "若" 则 { 返回 1 }
    若 text == "则" 则 { 返回 2 }
    若 text == "否则" 则 { 返回 3 }
    若 text == "当" 则 { 返回 4 }
    若 text == "循环" 则 { 返回 5 }
    若 text == "从" 则 { 返回 6 }
    若 text == "到" 则 { 返回 7 }
    若 text == "返回" 则 { 返回 8 }
    若 text == "定义" 则 { 返回 9 }
    若 text == "函数" 则 { 返回 10 }
    若 text == "真" 则 { 返回 11 }
    若 text == "假" 则 { 返回 12 }
    若 text == "跳过" 则 { 返回 13 }
    若 text == "退出" 则 { 返回 14 }
    若 text == "引入" 则 { 返回 15 }
    若 text == "模块" 则 { 返回 16 }
    若 text == "导出" 则 { 返回 17 }
    若 text == "整数" 则 { 返回 20 }
    若 text == "浮点数" 则 { 返回 21 }
    若 text == "双精度" 则 { 返回 22 }
    若 text == "布尔" 则 { 返回 23 }
    若 text == "文本" 则 { 返回 24 }
    若 text == "无返回" 则 { 返回 25 }
    若 text == "字符" 则 { 返回 26 }
    若 text == "指针" 则 { 返回 27 }
    若 text == "列表" 则 { 返回 28 }
    若 text == "长整数" 则 { 返回 29 }
    返回 0
}

函数 parserInit(tokens: 列表): Parser {
    定义 p: Parser
    p.pos = 0
    p.tokens = tokens
    p.errors = 列表()
    p.nodeCount = 0
    p.tokenCount = 列表长度(tokens)
    返回 p
}

函数 parserPeekToken(p: Parser): Token {
    定义 tok: Token
    tok.类型 = 0
    tok.值 = ""
    tok.行号 = 0
    tok.列号 = 0
    tok.开始位置 = 0
    tok.结束位置 = 0

    若 p.pos < p.tokenCount 则 {
        定义 t: Token
        t = p.tokens[p.pos]
        返回 t
    }

    tok.类型 = 6
    tok.值 = "EOF"
    返回 tok
}

函数 main(): 整数 {
    返回 0
}
