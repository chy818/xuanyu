/**
 * @file parser.xy
 * @brief 语法解析器 - 自展编译器
 * @description 递归下降解析器，实现表达式、语句、函数的解析
 */

/* ============ Token 类型 (与 lexer 一致) ============ */

枚举 TokenType {
    标识符 = 0,
    数字 = 1,
    字符串 = 2,
    关键字 = 3,
    运算符 = 4,
    符号 = 5,
    结束 = 6,
    注释 = 7
}

/* ============ AST 节点类型 ============ */

枚举 AST节点类型 {
    程序 = 0,
    函数定义 = 1,
    参数列表 = 2,
    变量定义 = 3,
    赋值语句 = 4,
    if语句 = 5,
    while语句 = 6,
    循环语句 = 7,
    返回语句 = 8,
    表达式语句 = 9,
    二元表达式 = 10,
    一元表达式 = 11,
    调用表达式 = 12,
    标识符表达式 = 13,
    字面量表达式 = 14,
    类型转换 = 15,
    break语句 = 16,
    continue语句 = 17,
    块语句 = 18,
    赋值表达式 = 19,
    for循环 = 20,
    结构体定义 = 21,
    枚举定义 = 22,
    结构体字段 = 23,
    枚举成员 = 24,
    match语句 = 25,
    match分支 = 26,
    match默认分支 = 27,
    导入语句 = 28,
    模块定义 = 29
}

/* 节点ID类型 */
定义 类型 NodeId = 整数

/* 节点计数 */
定义 类型 NodeCounter = 整数

结构体 AST节点 {
    id: 整数,
    kind: 整数,
    name: 文本,
    value: 文本,
    intValue: 整数,
    line: 整数,
    children: 列表
}

/* ============ Token 结构 (与 lexer 一致) ============ */

结构体 Token {
    类型: 整数,
    值: 文本,
    行号: 整数,
    列号: 整数,
    开始位置: 整数,
    结束位置: 整数
}

/* ============ Parser 结构 ============ */

结构体 Parser {
    tokens: 列表,
    pos: 整数,
    errors: 列表,
    nodeCount: 整数,
    tokenCount: 整数
}

/* ============ 关键字表 ============ */

/* 关键字识别 */
函数 是关键字(text: 文本): 整数 {
    若 text == "若" 则 { 返回 1 }
    若 text == "则" 则 { 返回 1 }
    若 text == "否则" 则 { 返回 1 }
    若 text == "当" 则 { 返回 1 }
    若 text == "循环" 则 { 返回 1 }
    若 text == "从" 则 { 返回 1 }
    若 text == "到" 则 { 返回 1 }
    若 text == "返回" 则 { 返回 1 }
    若 text == "定义" 则 { 返回 1 }
    若 text == "可变" 则 { 返回 1 }
    若 text == "函数" 则 { 返回 1 }
    若 text == "结构体" 则 { 返回 1 }
    若 text == "枚举" 则 { 返回 1 }
    若 text == "真" 则 { 返回 1 }
    若 text == "假" 则 { 返回 1 }
    若 text == "跳过" 则 { 返回 1 }
    若 text == "退出" 则 { 返回 1 }
    若 text == "引入" 则 { 返回 1 }
    若 text == "模块" 则 { 返回 1 }
    若 text == "导出" 则 { 返回 1 }
    返回 0
}

/* 获取关键字类型 */
函数 getKeywordType(text: 文本): 整数 {
    若 text == "若" 则 { 返回 1 }     // IF
    若 text == "则" 则 { 返回 2 }     // THEN
    若 text == "否则" 则 { 返回 3 }   // ELSE
    若 text == "当" 则 { 返回 4 }    // WHILE
    若 text == "循环" 则 { 返回 5 }   // LOOP
    若 text == "从" 则 { 返回 6 }    // FROM
    若 text == "到" 则 { 返回 7 }    // TO
    若 text == "返回" 则 { 返回 8 }   // RETURN
    若 text == "定义" 则 { 返回 9 }   // LET
    若 text == "函数" 则 { 返回 10 }  // FUNC
    若 text == "真" 则 { 返回 11 }   // TRUE
    若 text == "假" 则 { 返回 12 }   // FALSE
    若 text == "跳过" 则 { 返回 13 }  // CONTINUE
    若 text == "退出" 则 { 返回 14 }  // BREAK
    若 text == "引入" 则 { 返回 15 }  // IMPORT
    若 text == "模块" 则 { 返回 16 }  // MODULE
    若 text == "导出" 则 { 返回 17 }  // EXPORT
    若 text == "整数" 则 { 返回 20 }  // TYPE_INT
    若 text == "浮点数" 则 { 返回 21 } // TYPE_FLOAT
    若 text == "双精度" 则 { 返回 22 } // TYPE_DOUBLE
    若 text == "布尔" 则 { 返回 23 }  // TYPE_BOOL
    若 text == "文本" 则 { 返回 24 }  // TYPE_STRING
    若 text == "无返回" 则 { 返回 25 } // TYPE_VOID
    若 text == "字符" 则 { 返回 26 }  // TYPE_CHAR
    若 text == "指针" 则 { 返回 27 }  // TYPE_POINTER
    若 text == "列表" 则 { 返回 28 }  // TYPE_LIST
    若 text == "长整数" 则 { 返回 29 } // TYPE_LONG
    返回 0
}

/* ============ 初始化 ============ */

函数 parserInit(tokens: 列表): Parser {
    定义 p: Parser
    p.pos = 0
    p.tokens = tokens
    p.errors = 列表()
    p.nodeCount = 0
    p.tokenCount = 列表长度(tokens)
    返回 p
}

/* ============ Token 访问辅助函数 ============ */

/* 获取当前 token */
函数 parserPeekToken(p: Parser): Token {
    定义 tok: Token
    tok.类型 = 0
    tok.值 = ""
    tok.行号 = 0
    tok.列号 = 0
    tok.开始位置 = 0
    tok.结束位置 = 0

    若 p.pos < p.tokenCount 则 {
        定义 t: Token
        t = p.tokens[p.pos]
        返回 t
    }

    tok.类型 = 6  // 结束
    tok.值 = "EOF"
    返回 tok
}

/* 消费 token 并前进 */
函数 parserConsume(p: Parser): Token {
    定义 tok: Token
    tok = parserPeekToken(p)
    p.pos = p.pos + 1
    返回 tok
}

/* 检查当前 token 是否为指定值 */
函数 parserCheck(p: Parser, 值: 文本): 整数 {
    定义 tok: Token
    tok = parserPeekToken(p)
    若 tok.值 == 值 则 {
        返回 1
    }
    返回 0
}

/* 检查当前 token 是否为指定类型 */
函数 parserCheckType(p: Parser, 类型: 整数): 整数 {
    定义 tok: Token
    tok = parserPeekToken(p)
    若 tok.类型 == 类型 则 {
        返回 1
    }
    返回 0
}

/* 匹配并消费 token */
函数 parserMatch(p: Parser, 值: 文本): 整数 {
    若 parserCheck(p, 值) == 1 则 {
        定义 tok: Token
        tok = parserConsume(p)
        返回 1
    }
    返回 0
}

/* 生成新的 AST 节点 ID */
函数 parserNewNodeId(p: Parser): 整数 {
    p.nodeCount = p.nodeCount + 1
    返回 p.nodeCount
}

/* 创建 AST 节点 */
函数 parserCreateNode(kind: 整数, name: 文本, value: 文本, line: 整数): AST节点 {
    定义 node: AST节点
    node.id = 0
    node.kind = kind
    node.name = name
    node.value = value
    node.intValue = 0
    node.line = line
    node.children = 列表()
    返回 node
}

/* ============ 表达式解析 ============ */

/* 解析主表达式 (标识符、数字、字符串、括号) */
函数 parsePrimary(p: Parser): AST节点 {
    定义 tok: Token
    tok = parserPeekToken(p)

    定义 node: AST节点
    node = parserCreateNode(0, "", "", tok.行号)

    /* 标识符 */
    若 tok.类型 == 0 则 {
        node.kind = 13  // 标识符表达式
        node.name = tok.值
        node.value = tok.值
        parserConsume(p)

        /* 检查是否是函数调用 */
        tok = parserPeekToken(p)
        若 tok.值 == "(" 则 {
            node = parseCall(p, node)
        }
        返回 node
    }

    /* 数字 */
    若 tok.类型 == 1 则 {
        node.kind = 14  // 字面量表达式
        node.value = tok.值
        node.intValue = 文本转整数(tok.值)
        parserConsume(p)
        返回 node
    }

    /* 字符串 */
    若 tok.类型 == 2 则 {
        node.kind = 14  // 字面量表达式
        node.value = tok.值
        parserConsume(p)
        返回 node
    }

    /* 左括号 - 括号表达式 */
    若 tok.值 == "(" 则 {
        parserConsume(p)
        node = parseExpression(p)
        tok = parserPeekToken(p)
        若 tok.值 == ")" 则 {
            parserConsume(p)
        }
        返回 node
    }

    /* 一元减号 */
    若 tok.值 == "-" 则 {
        parserConsume(p)
        定义 operand: AST节点
        operand = parsePrimary(p)
        node.kind = 11  // 一元表达式
        node.name = "-"
        返回 node
    }

    /* 空表达式 */
    返回 node
}

/* 解析函数调用 */
函数 parseCall(p: Parser, funcNode: AST节点): AST节点 {
    定义 tok: Token

    /* 消费 ( */
    tok = parserPeekToken(p)
    若 tok.值 == "(" 则 {
        parserConsume(p)
    } 否则 {
        报错("期望 '('")
    }

    funcNode.kind = 12  // 调用表达式
    funcNode.children = 列表()

    /* 循环解析参数 */
    循环 {
        tok = parserPeekToken(p)

        // 结束条件：遇到 )
        若 tok.值 == ")" 则 {
            跳出
        }

        // 文件末尾，缺少 )
        若 tok.值 == "" 则 {
            报错("函数调用未闭合，期望 ')'")
        }

        // 解析一个参数
        定义 arg = parseExpression(p)
        funcNode.children.append(arg)  // ✅ 追加，不是覆盖

        // 看下一个 token：逗号 or 结束
        tok = parserPeekToken(p)
        若 tok.值 == "," 则 {
            parserConsume(p)  // 吃掉逗号，继续下一个参数
        } 否则 若 tok.值 != ")" 则 {
            报错("参数后期望逗号或右括号")
        }
    }

    /* 消费 ) */
    tok = parserPeekToken(p)
    若 tok.值 == ")" 则 {
        parserConsume(p)
    } 否则 {
        报错("期望 ')' 结束函数调用")
    }

    返回 funcNode
}

/* 解析一元表达式 */
函数 parseUnary(p: Parser): AST节点 {
    定义 tok: Token
    tok = parserPeekToken(p)

    /* 一元运算符 */
    若 tok.值 == "!" 或 tok.值 == "-" 则 {
        定义 op: 文本
        op = tok.值
        parserConsume(p)
        定义 operand: AST节点
        operand = parseUnary(p)
        定义 node: AST节点
        node = parserCreateNode(11, op, "", tok.行号)
        node.children = operand
        返回 node
    }

    返回 parsePrimary(p)
}

/* 获取运算符优先级 */
函数 getOpPriority(op: 文本): 整数 {
    若 op == "或" 则 { 返回 1 }
    若 op == "且" 则 { 返回 2 }
    若 op == "==" 或 op == "!=" 则 { 返回 3 }
    若 op == "<" 或 op == ">" 或 op == "<=" 或 op == ">=" 则 { 返回 4 }
    若 op == "+" 或 op == "-" 则 { 返回 5 }
    若 op == "*" 或 op == "/" 或 op == "%" 则 { 返回 6 }
    返回 0
}

/* 是右结合运算符 */
函数 是右结合(op: 文本): 整数 {
    若 op == "=" 则 { 返回 1 }
    返回 0
}

